if not Lib or not MyHubInstance then 
    warn("ERRO: Lib principal não encontrada. Verifique se a Parte 1 usou _G.HubLib")
    return 
end

-- Injeta a função de seletor na biblioteca global
function Lib:AddToolSelector(page, callback)
    local Container = Instance.new("Frame", page)
    Container.Size = UDim2.new(0.95, 0, 0, 120)
    Container.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", Container)

    local Title = Instance.new("TextLabel", Container)
    Title.Size = UDim2.new(1, 0, 0, 20)
    Title.Text = "EQUIPAR ARMA (BACKPACK)"
    Title.TextColor3 = self.AccentColor
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 10
    Title.BackgroundTransparency = 1

    local Scroll = Instance.new("ScrollingFrame", Container)
    Scroll.Size = UDim2.new(1, -10, 1, -25)
    Scroll.Position = UDim2.new(0, 5, 0, 22)
    Scroll.BackgroundTransparency = 1
    Scroll.ScrollBarThickness = 2

    local layout = Instance.new("UIGridLayout", Scroll)
    layout.CellSize = UDim2.new(0, 85, 0, 30)
    layout.Padding = UDim2.new(0, 5, 0, 5)

    local function updateTools()
        for _, v in pairs(Scroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        for _, tool in pairs(game.Players.LocalPlayer.Backpack:GetChildren()) do
            if tool:IsA("Tool") and not tool.Name:find("Fruit") then
                local b = Instance.new("TextButton", Scroll)
                b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                b.Text = tool.Name
                b.TextColor3 = Color3.new(1, 1, 1)
                b.Font = Enum.Font.Gotham
                b.TextSize = 8
                Instance.new("UICorner", b)
                
                b.MouseButton1Click:Connect(function()
                    for _, btn in pairs(Scroll:GetChildren()) do 
                        if btn:IsA("TextButton") then btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end 
                    end
                    b.BackgroundColor3 = Lib.AccentColor
                    callback(tool.Name)
                end)
            end
        end
        Scroll.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 5)
    end

    updateTools()
    game.Players.LocalPlayer.Backpack.ChildAdded:Connect(updateTools)
    game.Players.LocalPlayer.Backpack.ChildRemoved:Connect(updateTools)
end

-- CRIAÇÃO DA ABA MAIN
local MainTab = MyHubInstance:CreateTab("Main")
local selectedToolV2 = ""

MyHubInstance:AddToggle(MainTab, "Auto Farm Level", function(s) _G.VtxFarm = s end)

-- Agora a função existe!
Lib:AddToolSelector(MainTab, function(t) selectedToolV2 = t end)

MyHubInstance:AddToggle(MainTab, "Auto Equip (0.1s)", function(s)
    _G.VtxEquip = s
    task.spawn(function()
        while _G.VtxEquip do
            if selectedToolV2 ~= "" then
                pcall(function()
                    local t = game.Players.LocalPlayer.Backpack:FindFirstChild(selectedToolV2)
                    if t then t.Parent = game.Players.LocalPlayer.Character end
                end)
            end
            task.wait(0.1)
        end
    end)
end)

MyHubInstance:AddToggle(MainTab, "Auto Click", function(s)
    _G.VtxClick = s
    task.spawn(function()
        while _G.VtxClick do
            pcall(function()
                local tool = game.Players.LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end)
            task.wait(0.1)
        end
    end)
end)

