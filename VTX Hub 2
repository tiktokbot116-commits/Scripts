-- [[ ABA FARM - VTX HUB ]]

local FarmTab = MyHub:CreateTab("Farm")

-- Variáveis Internas
local selectedMob = "None"
local mobsList = {}
local lp = game:GetService("Players").LocalPlayer

-- Função para atualizar lista de Mobs ao redor
local function updateMobsList()
    mobsList = {}
    -- Procura na pasta padrão de Mobs do King Legacy
    local mobFolder = workspace:FindFirstChild("Mobs") or workspace:FindFirstChild("Enemy")
    if mobFolder then
        for _, v in pairs(mobFolder:GetChildren()) do
            if v:IsA("Model") and not table.find(mobsList, v.Name) then
                table.insert(mobsList, v.Name)
            end
        end
    end
    return mobsList
end

-- 1. SELETOR DE MOB (DINÂMICO)
MyHub:AddTextBox(FarmTab, "Nome do Mob (Exato)", "Soldier [Lv. 1]", function(v)
    selectedMob = v
end)

-- 2. AUTO FARM LEVEL
MyHub:AddToggle(FarmTab, "Auto Farm Selected Mob", function(state)
    _G.MainFarm = state
    
    task.spawn(function()
        while _G.MainFarm do
            pcall(function()
                local char = lp.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")
                
                -- Busca o alvo
                local target = nil
                local mobFolder = workspace:FindFirstChild("Mobs") or workspace:FindFirstChild("Enemy")
                
                if mobFolder then
                    for _, v in pairs(mobFolder:GetChildren()) do
                        if v.Name == selectedMob and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
                            target = v
                            break
                        end
                    end
                end

                if target and root then
                    -- Teleporte para cima do mob (Distância configurável na Config ou fixa aqui)
                    local dist = _G.FarmDistance or 8
                    root.CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, dist, 0) * CFrame.Angles(math.rad(-90), 0, 0)
                    
                    -- Ataque Automático (Se o Auto Click estiver off, ele força aqui)
                    local tool = char:FindFirstChildOfClass("Tool")
                    if tool then tool:Activate() end
                end
            end)
            task.wait()
        end
    end)
end)

-- 3. AUTO ATTACK (APENAS CLIQUE)
MyHub:AddToggle(FarmTab, "Auto Attack (Fast)", function(state)
    _G.FastAttack = state
    task.spawn(function()
        while _G.FastAttack do
            pcall(function()
                local tool = lp.Character:FindFirstChildOfClass("Tool")
                if tool then tool:Activate() end
            end)
            task.wait(0.1)
        end
    end)
end)

-- 4. CONFIGURAÇÕES DE SUPORTE AO FARM
MyHub:AddToggle(FarmTab, "Auto Buso (Haki)", function(state)
    _G.AutoBuso = state
    task.spawn(function()
        while _G.AutoBuso do
            if not lp.Character:FindFirstChild("BusoBody") then -- Nome padrão do efeito de Haki
                game:GetService("ReplicatedStorage").Remotes.Functions.Buso:InvokeServer()
            end
            task.wait(5)
        end
    end)
end)

-- 5. ANTI-QUEDA (NECESSÁRIO PARA FARM NO AR)
game:GetService("RunService").Stepped:Connect(function()
    if _G.MainFarm then
        pcall(function()
            if lp.Character and lp.Character:FindFirstChild("Humanoid") then
                lp.Character.Humanoid:ChangeState(11)
            end
        end)
    end
end)

print("ABA FARM CARREGADA COM SUCESSO!")
