-- [[ MONITOR DE PITY GACHA - ADICIONAR NA ABA GACHA ]]

local GachaMonitor = Instance.new("Frame", GachaTab)
GachaMonitor.Size = UDim2.new(0.95, 0, 0, 150)
GachaMonitor.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Instance.new("UICorner", GachaMonitor)

local GTitle = Instance.new("TextLabel", GachaMonitor)
GTitle.Size = UDim2.new(1, 0, 0, 25)
GTitle.Text = "MONITOR DE PITY (1-10)"
GTitle.TextColor3 = _G.HubLib.AccentColor
GTitle.Font = Enum.Font.GothamBold
GTitle.TextSize = 10
GTitle.BackgroundTransparency = 1

local GScroll = Instance.new("ScrollingFrame", GachaMonitor)
GScroll.Size = UDim2.new(1, -10, 1, -30)
GScroll.Position = UDim2.new(0, 5, 0, 25)
GScroll.BackgroundTransparency = 1
GScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
GScroll.ScrollBarThickness = 2

local GList = Instance.new("UIListLayout", GScroll)
GList.Padding = UDim.new(0, 3)

local function UpdateGachaList()
    -- Limpa a lista antiga no Hub
    for _, v in pairs(GScroll:GetChildren()) do 
        if v:IsA("TextLabel") then v:Destroy() end 
    end

    pcall(function()
        local Folder = game:GetService("Players").LocalPlayer.PlayerGui.MainGui.StarterFrame.Gacha_Frame.Frame.ViewFrame.List
        
        -- Varre os itens da lista do jogo
        for _, item in pairs(Folder:GetChildren()) do
            if item:IsA("Frame") and item:FindFirstChild("IndexLabel") and item:FindFirstChild("FruitNameLabel") then
                local index = item.IndexLabel.Text
                local fruit = item.FruitNameLabel.Text
                
                local Label = Instance.new("TextLabel", GScroll)
                Label.Size = UDim2.new(1, 0, 0, 18)
                Label.BackgroundTransparency = 0.9
                Label.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Label.Text = "  [" .. index .. "] " .. fruit
                Label.TextColor3 = Color3.new(1, 1, 1)
                Label.Font = Enum.Font.GothamSemibold
                Label.TextSize = 10
                Label.TextXAlignment = Enum.TextXAlignment.Left
                Instance.new("UICorner", Label)
            end
        end
    end)
    GScroll.CanvasSize = UDim2.new(0, 0, 0, GList.AbsoluteContentSize.Y)
end

-- Atualiza automaticamente quando o inventário de Gacha mudar ou abrir
task.spawn(function()
    while true do
        if GachaTab.Visible then
            UpdateGachaList()
        end
        task.wait(2) -- Atualiza a cada 2 segundos para não dar lag
    end
end)
