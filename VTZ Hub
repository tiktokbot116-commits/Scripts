_G.FruitCollectorEnabled = false
local function LoadFruitEngine()
    local player = Players.LocalPlayer
    task.spawn(function()
        while _G.FruitCollectorEnabled do
            local f1, f2 = workspace:FindFirstChild("AllspawnDF"), workspace:FindFirstChild("AllDroppedFruit")
            local mapFruits = {}
            if f1 then for _, f in ipairs(f1:GetChildren()) do if f:IsA("Model") then table.insert(mapFruits, f) end end end
            if f2 then for _, f in ipairs(f2:GetChildren()) do if f:IsA("Model") then table.insert(mapFruits, f) end end end

            if #mapFruits > 0 and player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                for _, fruit in ipairs(mapFruits) do
                    if not _G.FruitCollectorEnabled then break end
                    local part = fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart")
                    if fruit.Parent and part then
                        player.Character.HumanoidRootPart.CFrame = part.CFrame
                        task.wait(0.5)
                    end
                end
            end
            task.wait(1)
        end
    end)
end

