-- EXECUÇÃO DA GUI E LÓGICA DE FARM
-- ==========================================
local MyHub = HubLib:Init("KING LEGACY", "VTZ HUB")
local MainTab = MyHub:CreateTab("Main Farm")

_G.AutoCollectAll = false

local function GlobalChestCollector()
    task.spawn(function()
        while _G.AutoCollectAll do
            local IslandFolder = workspace:FindFirstChild("Island")
            if IslandFolder then
                for _, island in ipairs(IslandFolder:GetChildren()) do
                    if island.Name ~= "Gacha" then
                        for _, obj in ipairs(island:GetDescendants()) do
                            if obj:IsA("BasePart") and string.find(obj.Name, "Chest") then
                                local char = Players.LocalPlayer.Character
                                if char and char:FindFirstChild("HumanoidRootPart") then
                                    char.HumanoidRootPart.CFrame = obj.CFrame
                                    task.wait(0.25)
                                end
                            end
                            if not _G.AutoCollectAll then break end
                        end
                    end
                    if not _G.AutoCollectAll then break end
                end
            end
            task.wait(1)
        end
    end)
end

MyHub:AddToggle(MainTab, "Auto Collect All Chests", function(state)
    _G.AutoCollectAll = state
    if state then
        GlobalChestCollector()
    end
end)

local StatusFrame = Instance.new("Frame", MainTab)
StatusFrame.Size = UDim2.new(0.95, 0, 0, 40)
StatusFrame.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
Instance.new("UICorner", StatusFrame).CornerRadius = UDim.new(0, 5)

local StatusLabel = Instance.new("TextLabel", StatusFrame)
