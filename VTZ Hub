function HubLib:AddGridSelector(page, title, options, callback)
    local Container = Instance.new("Frame", page)
    Container.Size = UDim2.new(0.95, 0, 0, 65)
    Container.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UICorner", Container)

    local Label = Instance.new("TextLabel", Container)
    Label.Size = UDim2.new(1, 0, 0, 20)
    Label.Text = title:upper()
    Label.TextColor3 = self.AccentColor
    Label.Font = Enum.Font.GothamBold
    Label.TextSize = 10
    Label.BackgroundTransparency = 1

    local Grid = Instance.new("Frame", Container)
    Grid.Size = UDim2.new(1, -10, 0, 35)
    Grid.Position = UDim2.new(0, 5, 0, 22)
    Grid.BackgroundTransparency = 1
    local layout = Instance.new("UIListLayout", Grid)
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.Padding = UDim.new(0, 4)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    local btns = {}
    for _, opt in pairs(options) do
        local b = Instance.new("TextButton", Grid)
        b.Size = UDim2.new(0, 60, 1, 0)
        b.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        b.Text = opt:gsub(" Key", "")
        b.TextColor3 = Color3.new(0.7,0.7,0.7)
        b.Font = Enum.Font.GothamSemibold
        b.TextSize = 8
        Instance.new("UICorner", b)
        
        b.MouseButton1Click:Connect(function()
            for _, v in pairs(btns) do v.BackgroundColor3 = Color3.fromRGB(40, 40, 40) v.TextColor3 = Color3.new(0.7,0.7,0.7) end
            b.BackgroundColor3 = self.AccentColor
            b.TextColor3 = Color3.new(1,1,1)
            callback(opt)
        end)
        table.insert(btns, b)
    end
end

