local function makeDraggable(frame, parentFrame)
    local dragging, mousePos, framePos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = parentFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - mousePos
            parentFrame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)
end

function HubLib:Init(hubTitle, subTitle)
    local targetParent = nil
    pcall(function() targetParent = CoreGui end)
    if not targetParent then targetParent = Players.LocalPlayer:WaitForChild("PlayerGui") end
    if targetParent:FindFirstChild("VxezeHub") then targetParent.VxezeHub:Destroy() end

    local ScreenGui = Instance.new("ScreenGui", targetParent)
    ScreenGui.Name = "VxezeHub"
    ScreenGui.ResetOnSpawn = false

    local ToggleBtn = Instance.new("TextButton", ScreenGui)
    ToggleBtn.Name = "VxezeToggle"
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45)
    ToggleBtn.Position = UDim2.new(0, 10, 0.5, -22)
    ToggleBtn.BackgroundColor3 = self.AccentColor
    ToggleBtn.Text = "VX"
    ToggleBtn.TextColor3 = Color3.new(1,1,1)
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.TextSize = 14
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 10)
    makeDraggable(ToggleBtn, ToggleBtn)

    local MainFrame = Instance.new("Frame", ScreenGui)
    MainFrame.Name = "MainFrame"
    MainFrame.Size = UDim2.new(0, 480, 0, 320)
    MainFrame.Position = UDim2.new(0.5, -240, 0.5, -160)
    MainFrame.BackgroundColor3 = self.MainColor
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

    ToggleBtn.MouseButton1Click:Connect(function() MainFrame.Visible = not MainFrame.Visible end)

    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Size = UDim2.new(0, 120, 1, -35)
    Sidebar.Position = UDim2.new(0, 0, 0, 35)
    Sidebar.BackgroundColor3 = self.SidebarColor
    Instance.new("UIListLayout", Sidebar).HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 10)

    self.PagesFolder = Instance.new("Frame", MainFrame)
    self.PagesFolder.Size = UDim2.new(1, -130, 1, -45)
    self.PagesFolder.Position = UDim2.new(0, 125, 0, 40)
    self.PagesFolder.BackgroundTransparency = 1

    self.Sidebar = Sidebar
    return self
end

function HubLib:CreateTab(name)
    local TabBtn = Instance.new("TextButton", self.Sidebar)
    TabBtn.Size = UDim2.new(0.9, 0, 0, 30)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name:upper()
    TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 11

    local Page = Instance.new("ScrollingFrame", self.PagesFolder)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ScrollBarThickness = 0
    local layout = Instance.new("UIListLayout", Page)
    layout.Padding = UDim.new(0, 6)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(self.PagesFolder:GetChildren()) do p.Visible = false end
        for _, b in pairs(self.Sidebar:GetChildren()) do if b:IsA("TextButton") then b.TextColor3 = Color3.fromRGB(150, 150, 150) end end
        Page.Visible = true
        TabBtn.TextColor3 = self.AccentColor
    end)
    return Page
end

function HubLib:AddToggle(page, text, callback)
    local ToggleFrame = Instance.new("Frame", page)
    ToggleFrame.Size = UDim2.new(0.95, 0, 0, 38)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", ToggleFrame)

    local Label = Instance.new("TextLabel", ToggleFrame)
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.Text = text
    Label.TextColor3 = self.TextColor
    Label.BackgroundTransparency = 1
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Outer = Instance.new("TextButton", ToggleFrame)
    Outer.Size = UDim2.new(0, 38, 0, 18)
    Outer.Position = UDim2.new(1, -48, 0.5, -9)
    Outer.BackgroundColor3 = self.ToggleOffColor
    Outer.Text = ""
    Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)

    local Inner = Instance.new("Frame", Outer)
    Inner.Size = UDim2.new(0, 14, 0, 14)
    Inner.Position = UDim2.new(0, 2, 0, 2)
    Inner.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

    local state = false
    Outer.MouseButton1Click:Connect(function()
        state = not state
        pcall(callback, state)
        local targetPos = state and UDim2.new(1, -16, 0, 2) or UDim2.new(0, 2, 0, 2)
        local targetColor = state and self.AccentColor or self.ToggleOffColor
        TweenService:Create(Outer, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(Inner, TweenInfo.new(0.2), {Position = targetPos}):Play()
    end)
end

function HubLib:AddButton(page, text, callback)
    local Btn = Instance.new("TextButton", page)
    Btn.Size = UDim2.new(0.95, 0, 0, 38)
    Btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    Btn.Text = text
    Btn.TextColor3 = self.TextColor
    Btn.Font = Enum.Font.GothamSemibold
    Btn.TextSize = 12
    Instance.new("UICorner", Btn)
    Btn.MouseButton1Click:Connect(callback)
end

function HubLib:AddTextBox(page, text, placeholder, callback)
    local TFrame = Instance.new("Frame", page)
    TFrame.Size = UDim2.new(0.95, 0, 0, 45)
    TFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", TFrame)
    
    local Box = Instance.new("TextBox", TFrame)
    Box.Size = UDim2.new(1, -24, 0, 20)
    Box.Position = UDim2.new(0, 12, 0, 18)
    Box.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    Box.PlaceholderText = placeholder
    Box.Text = ""
    Box.TextColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", Box)
    Box.FocusLost:Connect(function() callback(Box.Text) end)
end

function HubLib:AddDropdown(page, text, options, callback)
    local DropFrame = Instance.new("Frame", page)
    DropFrame.Size = UDim2.new(0.95, 0, 0, 38)
    DropFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Instance.new("UICorner", DropFrame)

    local Btn = Instance.new("TextButton", DropFrame)
    Btn.Size = UDim2.new(0, 120, 0, 28)
    Btn.Position = UDim2.new(1, -125, 0, 5)
    Btn.Text = "Selecionar..."
    Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    Btn.TextColor3 = self.AccentColor
    Instance.new("UICorner", Btn)

    local List = Instance.new("Frame", page)
    List.Size = UDim2.new(0.95, 0, 0, 0)
    List.Visible = false
    List.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Instance.new("UIListLayout", List)
    Instance.new("UICorner", List)

    Btn.MouseButton1Click:Connect(function()
        List.Visible = not List.Visible
        if List.Visible then
            for _, v in pairs(List:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
            for _, opt in pairs(options) do
                local oBtn = Instance.new("TextButton", List)
                oBtn.Size = UDim2.new(1, 0, 0, 30)
                oBtn.Text = opt
                oBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
                oBtn.TextColor3 = Color3.new(1,1,1)
                oBtn.MouseButton1Click:Connect(function()
                    Btn.Text = opt
                    callback(opt)
                    List.Visible = false
                end)
            end
            List.Size = UDim2.new(0.95, 0, 0, #List:GetChildren() * 30)
        end
    end)
end

