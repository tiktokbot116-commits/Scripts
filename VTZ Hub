-- [[ VXEZE-STYLE HUB ENGINE - ULTRA COMPATIBLE VERSION ]]

local Players = game:GetService("Players")
local CoreGui = game:GetService("CoreGui")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local HubLib = {}

-- Configurações de Cores
HubLib.MainColor = Color3.fromRGB(20, 20, 20)
HubLib.SidebarColor = Color3.fromRGB(15, 15, 15)
HubLib.AccentColor = Color3.fromRGB(81, 74, 255) 
HubLib.ToggleOffColor = Color3.fromRGB(45, 45, 45)
HubLib.TextColor = Color3.fromRGB(255, 255, 255)

-- Função de Arraste
local function makeDraggable(frame, parentFrame)
    local dragging, dragInput, mousePos, framePos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            mousePos = input.Position
            framePos = parentFrame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - mousePos
            parentFrame.Position = UDim2.new(framePos.X.Scale, framePos.X.Offset + delta.X, framePos.Y.Scale, framePos.Y.Offset + delta.Y)
        end
    end)
end

function HubLib:Init(hubTitle, subTitle)
    local player = Players.LocalPlayer
    
    -- Tenta CoreGui primeiro, se falhar vai para PlayerGui
    local parent = nil
    local success, _ = pcall(function() 
        parent = CoreGui
    end)
    if not success or not parent then 
        parent = player:WaitForChild("PlayerGui")
    end
    
    if parent:FindFirstChild("VxezeHub") then parent.VxezeHub:Destroy() end

    local ScreenGui = Instance.new("ScreenGui")
    ScreenGui.Name = "VxezeHub"
    ScreenGui.IgnoreGuiInset = true
    ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    ScreenGui.Parent = parent

    local MainFrame = Instance.new("Frame")
    MainFrame.Name = "MainFrame"
    MainFrame.Parent = ScreenGui
    MainFrame.Size = UDim2.new(0, 480, 0, 320)
    MainFrame.Position = UDim2.new(0.5, -240, 0.5, -160)
    MainFrame.BackgroundColor3 = self.MainColor
    MainFrame.BorderSizePixel = 0
    Instance.new("UICorner", MainFrame).CornerRadius = UDim.new(0, 10)

    local TopBar = Instance.new("Frame", MainFrame)
    TopBar.Size = UDim2.new(1, 0, 0, 35)
    TopBar.BackgroundTransparency = 1
    makeDraggable(TopBar, MainFrame)

    local Title = Instance.new("TextLabel", TopBar)
    Title.Size = UDim2.new(1, -20, 1, 0)
    Title.Position = UDim2.new(0, 15, 0, 0)
    Title.Text = string.upper(hubTitle or "HUB") .. " | " .. (subTitle or "SCRIPT")
    Title.TextColor3 = self.TextColor
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 13
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.BackgroundTransparency = 1

    local Sidebar = Instance.new("Frame", MainFrame)
    Sidebar.Size = UDim2.new(0, 120, 1, -35)
    Sidebar.Position = UDim2.new(0, 0, 0, 35)
    Sidebar.BackgroundColor3 = self.SidebarColor
    Sidebar.BorderSizePixel = 0
    local SidebarLayout = Instance.new("UIListLayout", Sidebar)
    SidebarLayout.Padding = UDim.new(0, 5)
    SidebarLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    Instance.new("UIPadding", Sidebar).PaddingTop = UDim.new(0, 10)

    self.PagesFolder = Instance.new("Frame", MainFrame)
    self.PagesFolder.Size = UDim2.new(1, -130, 1, -45)
    self.PagesFolder.Position = UDim2.new(0, 125, 0, 40)
    self.PagesFolder.BackgroundTransparency = 1

    -- [[ BOTÃO VX - DEFINIDO APÓS O MAINFRAME ]]
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Name = "VxezeToggle"
    ToggleBtn.Parent = ScreenGui
    ToggleBtn.Size = UDim2.new(0, 45, 0, 45)
    ToggleBtn.Position = UDim2.new(0, 10, 0.5, -22)
    ToggleBtn.BackgroundColor3 = self.AccentColor
    ToggleBtn.Text = "VX"
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.TextSize = 14
    ToggleBtn.AutoButtonColor = false
    ToggleBtn.ZIndex = 10
    
    Instance.new("UICorner", ToggleBtn).CornerRadius = UDim.new(0, 10)
    local Stroke = Instance.new("UIStroke", ToggleBtn)
    Stroke.Color = Color3.fromRGB(255, 255, 255)
    Stroke.Transparency = 0.5
    Stroke.Thickness = 1.5

    ToggleBtn.MouseButton1Click:Connect(function()
        MainFrame.Visible = not MainFrame.Visible
    end)

    makeDraggable(ToggleBtn, ToggleBtn)

    print("VTZ Hub: Inicializado com sucesso!")
    self.Sidebar = Sidebar
    return self
end

function HubLib:CreateTab(name)
    local TabBtn = Instance.new("TextButton", self.Sidebar)
    TabBtn.Size = UDim2.new(0.9, 0, 0, 30)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = name:upper()
    TabBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
    TabBtn.Font = Enum.Font.GothamSemibold
    TabBtn.TextSize = 11

    local Page = Instance.new("ScrollingFrame", self.PagesFolder)
    Page.Size = UDim2.new(1, 0, 1, 0)
    Page.BackgroundTransparency = 1
    Page.Visible = false
    Page.ScrollBarThickness = 0
    Page.CanvasSize = UDim2.new(0, 0, 0, 0)
    
    local layout = Instance.new("UIListLayout", Page)
    layout.Padding = UDim.new(0, 6)
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center

    TabBtn.MouseButton1Click:Connect(function()
        for _, p in pairs(self.PagesFolder:GetChildren()) do p.Visible = false end
        for _, b in pairs(self.Sidebar:GetChildren()) do 
            if b:IsA("TextButton") then b.TextColor3 = Color3.fromRGB(150, 150, 150) end 
        end
        Page.Visible = true
        TabBtn.TextColor3 = self.AccentColor
    end)

    if #self.Sidebar:GetChildren() <= 2 then 
        Page.Visible = true 
        TabBtn.TextColor3 = self.AccentColor 
    end

    return Page
end

function HubLib:AddToggle(page, text, callback)
    local ToggleFrame = Instance.new("Frame", page)
    ToggleFrame.Size = UDim2.new(0.95, 0, 0, 38)
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    ToggleFrame.BorderSizePixel = 0
    Instance.new("UICorner", ToggleFrame).CornerRadius = UDim.new(0, 5)

    local Label = Instance.new("TextLabel", ToggleFrame)
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 12, 0, 0)
    Label.Text = text
    Label.TextColor3 = self.TextColor
    Label.BackgroundTransparency = 1
    Label.Font = Enum.Font.Gotham
    Label.TextSize = 12
    Label.TextXAlignment = Enum.TextXAlignment.Left

    local Outer = Instance.new("TextButton", ToggleFrame)
    Outer.Size = UDim2.new(0, 38, 0, 18)
    Outer.Position = UDim2.new(1, -48, 0.5, -9)
    Outer.BackgroundColor3 = self.ToggleOffColor
    Outer.Text = ""
    Outer.AutoButtonColor = false
    Instance.new("UICorner", Outer).CornerRadius = UDim.new(1, 0)

    local Inner = Instance.new("Frame", Outer)
    Inner.Size = UDim2.new(0, 14, 0, 14)
    Inner.Position = UDim2.new(0, 2, 0, 2)
    Inner.BackgroundColor3 = Color3.new(1, 1, 1)
    Instance.new("UICorner", Inner).CornerRadius = UDim.new(1, 0)

    local state = false
    Outer.MouseButton1Click:Connect(function()
        state = not state
        pcall(callback, state)
        local targetPos = state and UDim2.new(1, -16, 0, 2) or UDim2.new(0, 2, 0, 2)
        local targetColor = state and self.AccentColor or self.ToggleOffColor
        TweenService:Create(Outer, TweenInfo.new(0.2), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(Inner, TweenInfo.new(0.2), {Position = targetPos}):Play()
    end)

    local layout = page:FindFirstChildWhichIsA("UIListLayout")
    if layout then
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
    end
end

return HubLib
