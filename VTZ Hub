task.spawn(function()
    while true do
        local f1 = workspace:FindFirstChild("AllspawnDF")
        local f2 = workspace:FindFirstChild("AllDroppedFruit")
        local lines = {}

        -- Verifica Frutas de Spawn
        if f1 then
            for _, f in ipairs(f1:GetChildren()) do
                if f:IsA("Model") then
                    table.insert(lines, "[SPAWN] " .. f.Name:upper())
                end
            end
        end
        
        -- Verifica Frutas Dropadas
        if f2 then
            for _, f in ipairs(f2:GetChildren()) do
                if f:IsA("Model") then
                    table.insert(lines, "[DROP] " .. f.Name:upper())
                end
            end
        end

        -- Atualiza o texto do Quadrado
        if #lines > 0 then
            FruitList.Text = table.concat(lines, "\n")
            FruitList.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            FruitList.Text = "NENHUMA FRUTA DETECTADA"
            FruitList.TextColor3 = Color3.fromRGB(100, 100, 100)
        end
        
        task.wait(1.5)
    end
end)
