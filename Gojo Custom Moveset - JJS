-- // SETUP E RESPAWN
local function connectButtons()
    local playerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
    if not playerGui then return end
    local mapping = {["Lapse Blue"] = SkillLapseBlue, ["Reversal Red"] = SkillReversalRed, ["Rapid Punches"] = SkillRapidPunches, ["Twofold Kick"] = SkillTwofoldKick}
    for name, func in pairs(mapping) do
        local btn = playerGui:FindFirstChild("Main", true) and playerGui.Main.Moveset[name] and playerGui.Main.Moveset[name].ItemName
        if btn then btn.MouseButton1Down:Connect(func) end
    end
end

LocalPlayer.CharacterAdded:Connect(function() isBusy = false; task.wait(2); connectButtons() end)
connectButtons()

