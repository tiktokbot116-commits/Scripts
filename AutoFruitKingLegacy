-- [[ KING LEGACY COLLECTOR - ENGINE APENAS ]]
local Players = game:GetService("Players")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local VirtualUser = game:GetService("VirtualUser")
local task = task

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- [TRAVA DE SEGURANÇA]
local TARGET_IDS = {4520749081, 6381829480}
local isCorrectGame = false
for _, id in ipairs(TARGET_IDS) do if game.PlaceId == id then isCorrectGame = true break end end
if not isCorrectGame then return end

-- [ANTI-AFK]
if not _G.AntiAFKConnected then
    player.Idled:Connect(function()
        VirtualUser:CaptureController()
        VirtualUser:ClickButton2(Vector2.new())
    end)
    _G.AntiAFKConnected = true
end

-- [FUNÇÃO DE SELEÇÃO E ATIVAÇÃO]
local function SafeActivate(button)
    if button and button.Visible then
        pcall(function()
            GuiService.SelectedObject = button
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
            task.wait(0.1)
            GuiService.SelectedObject = nil
        end)
    end
end

-- [VERIFICAÇÃO DE ARMAZENAMENTO]
local function IsStored(fName)
    if not fName then return true end
    local clean = string.gsub(fName, "Fruit", "")
    local stats = player:FindFirstChild("PlayerStats")
    if stats and stats:FindFirstChild("DFName") and stats.DFName.Value == clean then return true end
    
    local mainGui = playerGui:FindFirstChild("MainGui")
    local invFrame = mainGui and mainGui:FindFirstChild("StarterFrame") and mainGui.StarterFrame:FindFirstChild("Inventory_Frame")
    local scrolling = invFrame and invFrame:FindFirstChild("ScrollingFrameFruits")
    
    if scrolling then
        for _, item in ipairs(scrolling:GetChildren()) do
            if string.find(item.Name, clean) or (item:IsA("TextLabel") and string.find(item.Text, clean)) then
                return true
            end
        end
    end
    return false
end

-- [AÇÃO DE GUARDAR]
local function ForceStore(tool)
    local startTick = tick()
    while tool.Parent == player.Character or tool.Parent == player.Backpack do
        if not _G.FruitCollectorEnabled or tick() - startTick > 15 then break end 
        
        player.Character.Humanoid:EquipTool(tool)
        task.wait(0.5)
        
        local vp = workspace.CurrentCamera.ViewportSize
        VirtualInputManager:SendMouseButtonEvent(vp.X/2, (vp.Y/2) + 58, 0, true, game, 0)
        VirtualInputManager:SendMouseButtonEvent(vp.X/2, (vp.Y/2) + 58, 0, false, game, 0)
        task.wait(0.8)

        local menu = playerGui:FindFirstChild("EatFruitBecky")
        if menu and menu.Enabled then
            local btn = menu.Dialogue:FindFirstChild("Collect")
            if btn and btn.Visible then SafeActivate(btn) end
        end
        task.wait(1)
        if IsStored(tool.Name) then break end
    end
end

-- [INICIADOR DO LOOP]
local function StartFruitLoop()
    while _G.FruitCollectorEnabled do
        local f1, f2 = workspace:FindFirstChild("AllspawnDF"), workspace:FindFirstChild("AllDroppedFruit")
        local mapFruits = {}
        if f1 then for _, f in ipairs(f1:GetChildren()) do if f:IsA("Model") then table.insert(mapFruits, f) end end end
        if f2 then for _, f in ipairs(f2:GetChildren()) do if f:IsA("Model") then table.insert(mapFruits, f) end end end

        if #mapFruits > 0 then
            local loading = playerGui:FindFirstChild("LoadingGUI")
            if loading and loading.Enabled then
                local b = loading:FindFirstChild("Play")
                if b then SafeActivate(b) end
            elseif player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
                for _, fruit in ipairs(mapFruits) do
                    if not _G.FruitCollectorEnabled then break end
                    if fruit.Parent then
                        player.Character.HumanoidRootPart.CFrame = (fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart")).CFrame
                        task.wait(0.5)
                    end
                end
            end
        else
            local pending = {}
            for _, t in ipairs(player.Backpack:GetChildren()) do
                if string.find(t.Name, "Fruit") and not IsStored(t.Name) then table.insert(pending, t) end
            end
            for _, t in ipairs(player.Character:GetChildren()) do
                if t:IsA("Tool") and string.find(t.Name, "Fruit") and not IsStored(t.Name) then table.insert(pending, t) end
            end

            if #pending > 0 then
                for _, f in ipairs(pending) do ForceStore(f) end
            end
        end
        task.wait(2)
    end
end

