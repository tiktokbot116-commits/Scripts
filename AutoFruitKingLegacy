-- King Legacy Ultra Collector (Guaranteed Selection System - Anti-Fail)
local Players = game:GetService("Players")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")
local CoreGui = game:GetService("CoreGui")
local VirtualUser = game:GetService("VirtualUser")
local task = task

-- [TRAVA DE SEGURANÇA]
local TARGET_ID = 4520749081
if game.PlaceId ~= TARGET_ID then return end

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

-- [ANTI-AFK MOBILE]
player.Idled:Connect(function()
    VirtualUser:CaptureController()
    VirtualUser:ClickButton2(Vector2.new())
end)

-- --- INTERFACE EM CORE GUI ---
local parent = (pcall(function() return CoreGui.Name end) and CoreGui) or playerGui
if parent:FindFirstChild("FruitCollector_Overlay") then parent.FruitCollector_Overlay:Destroy() end

