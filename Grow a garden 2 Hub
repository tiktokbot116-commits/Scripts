-- Helper: aplica transparência APENAS nos Models de plantas
-- (identificados pelo HarvestPrompt dentro deles, igual ao Auto Coletar)
local function SetTransparenciaPlantasDoPlot(plotModel, transparencia)
    local jaProcessado = {}
    for _, desc in ipairs(plotModel:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Name == "HarvestPrompt" then
            local plantModel = desc:FindFirstAncestorOfClass("Model")
            if plantModel and not jaProcessado[plantModel] then
                jaProcessado[plantModel] = true
                for _, part in ipairs(plantModel:GetDescendants()) do
                    if part:IsA("BasePart") or part:IsA("MeshPart") then
                        pcall(function() part.Transparency = transparencia end)
                    end
                    if part:IsA("Decal") or part:IsA("Texture") then
                        pcall(function() part.Transparency = transparencia end)
                    end
                end
            end
        end
    end
end

-- Lê os SeedName únicos das plantas do meu plot (mesmo atributo do filtro de Bamboo)
local function ObterPlantasDoMeuPlot()
    local tipos, seen = {}, {}
    local mP = Plots.GetMeuPlot()
    if not mP or not Gardens or not Gardens:FindFirstChild(mP) then return tipos end
    for _, desc in ipairs(Gardens[mP]:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Name == "HarvestPrompt" then
            local plantModel = desc:FindFirstAncestorOfClass("Model")
            if plantModel then
                local sName = plantModel:GetAttribute("SeedName")
                if sName and not seen[sName] then
                    seen[sName] = true
                    table.insert(tipos, sName)
                end
            end
        end
    end
    table.sort(tipos)
    return tipos
end

-- Equipa o Shovel (move do Backpack para o Character)
local function EquiparShovel()
    local meuChar = LocalPlayer.Character
    if not meuChar then return nil end
    local shovel = meuChar:FindFirstChild("Shovel")
    if not shovel then
        shovel = LocalPlayer.Backpack:FindFirstChild("Shovel")
        if shovel then
            pcall(function() shovel.Parent = meuChar end)
            task.wait(0.05)
            shovel = meuChar:FindFirstChild("Shovel")
        end
    end
    return shovel
end

