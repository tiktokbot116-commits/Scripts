local Plots = {}
local PlotCache = {}

local function RebuildPlotCache()
    table.clear(PlotCache)
    for _, p in ipairs(Players:GetPlayers()) do
        local pid = p:GetAttribute("PlotId")
        if pid then PlotCache[tonumber(pid)] = p.Name end
    end
end

RebuildPlotCache()
Players.PlayerAdded:Connect(RebuildPlotCache)
Players.PlayerRemoving:Connect(RebuildPlotCache)

for _, p in ipairs(Players:GetPlayers()) do
    p.AttributeChanged:Connect(function(a)
        if a == "PlotId" then RebuildPlotCache() end
    end)
end

function Plots.DonoDoPlot(plot)
    if not plot then return nil end
    local n = tonumber(string.match(plot.Name, "%d+"))
    return n and PlotCache[n] or nil
end

function Plots.GetMeuPlot()
    local pid = LocalPlayer:GetAttribute("PlotId")
    return pid and ("Plot"..tostring(pid)) or nil
end

function Plots.ListarParaDropdown()
    if not Gardens then return {} end
    local t = {}
    for _, pl in ipairs(Gardens:GetChildren()) do
        if pl.Name:match("^Plot%d+$") then
            local o = Plots.DonoDoPlot(pl)
            if o then
                table.insert(t, o == LocalPlayer.Name and o.." (meu)" or o.." ("..pl.Name..")")
            end
        end
    end
    table.sort(t); return t
end

------------------------------------------------------------------------
-- MÓDULO: PROMPTS
------------------------------------------------------------------------
local PromptDebounce = {}

local function AtivarPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    if PromptDebounce[prompt] and tick() - PromptDebounce[prompt] < 0.5 then return false end
    PromptDebounce[prompt] = tick()
    
    pcall(function()
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 999999
        prompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
    end)

    if fireproximityprompt then
        pcall(fireproximityprompt, prompt, 1, true)
        return true
    end

    pcall(function()
        prompt.HoldDuration = 0;
        prompt:InputHoldBegin();
        prompt:InputHoldEnd()
    end)

    if VIM then
        pcall(function()
            VIM:SendKeyEvent(true, Enum.KeyCode.E, false, game)
            task.wait(0.01)
            VIM:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        end)
    end
    return true
end

