GM.VerificarEstoque = function(itemFrame)
    local stockLabel = itemFrame:FindFirstChild("Main_Frame") and itemFrame.Main_Frame:FindFirstChild("Stock_Text")
    if not stockLabel then return true end
    local txt = string.lower(stockLabel.Text)
    if string.find(txt, "sold out")
    or string.find(txt, "out of stock")
    or txt == "0"
    or string.find(txt, "^0/")
    or string.find(txt, "^0%s") then
        return false
    end
    local n = tonumber(string.match(txt, "^(%d+)"))
    if n and n <= 0 then return false end
    return true
end

GM.ObterListaDeSementes = function()
    local sementes = {}
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui or not pGui:FindFirstChild("SeedShop") then return sementes end

    local shopGui   = pGui.SeedShop
    local wasEnabled = shopGui.Enabled
    shopGui.Enabled = true   
    task.wait(0.05)

    local normalShop = shopGui:FindFirstChild("Frame") and shopGui.Frame:FindFirstChild("NormalShop")
    if normalShop then
        for _, item in ipairs(normalShop:GetChildren()) do
            if item:IsA("Frame")
            and item.Name ~= "ItemTemplate"
            and item.Name ~= "Padding"
            and item.Name ~= "Robux & Sheckels_Shelf" then
                if GM.VerificarEstoque(item) then
                    table.insert(sementes, item.Name)
                end
            end
        end
    end

    shopGui.Enabled = wasEnabled  
    table.sort(sementes)
    return sementes
end

GM.ComprarSemente = function(nomeDaSemente)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui or not pGui:FindFirstChild("SeedShop") then return false end
    
    local shopGui = pGui.SeedShop
    local normalShop = shopGui:FindFirstChild("Frame") and shopGui.Frame:FindFirstChild("NormalShop")
    if not normalShop then return false end

    local sementeFrame = normalShop:FindFirstChild(nomeDaSemente)
    if not sementeFrame then return false end

    if GM.StockCooldowns[nomeDaSemente] and tick() - GM.StockCooldowns[nomeDaSemente] < 20 then
        return false 
    end

    local wasEnabled = shopGui.Enabled
    shopGui.Enabled = true
    task.wait(0.08)

    if not GM.VerificarEstoque(sementeFrame) then
        GM.StockCooldowns[nomeDaSemente] = tick()
        shopGui.Enabled = wasEnabled
        local targets = GM.Library.Flags["SementesAlvo"]
        if type(targets) == "table" then
            local idx = table.find(targets, nomeDaSemente)
            if idx then table.remove(targets, idx) end
        end
        return false
    end

    local seedBtn = sementeFrame:FindFirstChild("Main_Frame") and sementeFrame.Main_Frame:FindFirstChild("TextButton")
    local buyBtn = normalShop:FindFirstChild("Sheckles_Shelf") 
                   and normalShop.Sheckles_Shelf:FindFirstChild("Main_Frame")
                   and normalShop.Sheckles_Shelf.Main_Frame:FindFirstChild("Buttons")
                   and normalShop.Sheckles_Shelf.Main_Frame.Buttons:FindFirstChild("BuyButton")

    if seedBtn and buyBtn then
        if typeof(firesignal) == "function" then
            pcall(firesignal, seedBtn.MouseButton1Click)
            task.wait(0.05)
            pcall(firesignal, buyBtn.MouseButton1Click)
            task.wait(0.05)
        else
            GuiService.SelectedObject = seedBtn
            task.wait(0.05)
            if VirtualInputManager then
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
            end
            task.wait(0.05)

            GuiService.SelectedObject = buyBtn
            task.wait(0.05)
            if VirtualInputManager then
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
                task.wait(0.02)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
            end
            task.wait(0.05)
        end
    end
    
    GuiService.SelectedObject = nil
    shopGui.Enabled = wasEnabled  
    return true
end

