-- MODULO: PLOTS [CÓDIGO ORIGINAL MANTIDO]
------------------------------------------------------------------------
local Plots = {}
function Plots.ResolverMeuPlot()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if plotId then
        local num = tonumber(plotId)
        if num then State.meuPlotNome = "Plot" .. tostring(num); return end
    end
end

local CachePlayersPorPlotId = {}
local function reconstruirCachePlayers()
    table.clear(CachePlayersPorPlotId)
    for _, p in ipairs(Players:GetPlayers()) do
        local pid = p:GetAttribute("PlotId")
        if pid then CachePlayersPorPlotId[tonumber(pid)] = p.Name end
    end
end
reconstruirCachePlayers()
Players.PlayerAdded:Connect(reconstruirCachePlayers)
Players.PlayerRemoving:Connect(reconstruirCachePlayers)
Players.PlayerAdded:Connect(function(p)
    p.AttributeChanged:Connect(function(attr) if attr == "PlotId" then reconstruirCachePlayers() end end)
end)
for _, p in ipairs(Players:GetPlayers()) do
    p.AttributeChanged:Connect(function(attr) if attr == "PlotId" then reconstruirCachePlayers() end end)
end

function Plots.DonoDoPlot(plot)
    if not plot then return nil end
    local plotNum = tonumber(string.match(plot.Name, "%d+"))
    if not plotNum then return nil end
    return CachePlayersPorPlotId[plotNum]
end

function Plots.ListarParaDropdown()
    if not Gardens then return {} end
    local itens = {}
    for _, plot in ipairs(Gardens:GetChildren()) do
        if string.match(plot.Name, "^Plot%d+$") then
            local dono = Plots.DonoDoPlot(plot)
            local rotulo
            if dono then
                if dono == LocalPlayer.Name then rotulo = dono .. " (meu plot)" else rotulo = dono .. " (" .. plot.Name .. ")" end
            else
                rotulo = "Sem Dono (" .. plot.Name .. ")"
            end
            table.insert(itens, rotulo)
        end
    end
    table.sort(itens)
    return itens
end

------------------------------------------------------------------------
-- MODULOS DE ACAO [CÓDIGO ORIGINAL MANTIDO]
------------------------------------------------------------------------
local Acoes = {}
function Acoes.ProcessarTeleporteEPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    local sucesso = Char.TeleportarParaPrompt(prompt)
    if not sucesso then return false end
    task.wait(0.1)
    Prompt.AtivarImediato(prompt)
    return true
end

local Venda = {}
function Venda.Processar()
    if not State.autoVenda then return false end
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return false end
    if #backpack:GetChildren() >= State.quantidadeVenda then
        if Networking and Networking.NPCS then pcall(function() Networking.NPCS.SellAll:Fire() end) end
        return true
    end
    return false
end

local Coleta = {}
function Coleta.Processar()
    if not State.autoColeta or not State.meuPlotNome or not Gardens then return false end
    local plot = Gardens:FindFirstChild(State.meuPlotNome)
    if not plot then return false end
    for _, inst in ipairs(plot:GetDescendants()) do
        if inst:IsA("ProximityPrompt") and inst.Name == "HarvestPrompt" then return Acoes.ProcessarTeleporteEPrompt(inst) end
    end
    return false
end

local IgnoredPrompts = {}
local Roubo = {}
function Roubo.Processar()
    if not State.autoRoubo or not State.plotAlvoNome then return false end
    if Workspace:GetAttribute("ActivePhase") ~= "Night" then return false end
    if not Gardens then return false end
    local plot = Gardens:FindFirstChild(State.plotAlvoNome)
    if not plot then return false end
    for _, inst in ipairs(plot:GetDescendants()) do
        if inst:IsA("ProximityPrompt") and inst.Name == "StealPrompt" then
            if not IgnoredPrompts[inst] then
                local isBamboo, ancestral = false, inst.Parent
                while ancestral and ancestral ~= Workspace do
                    local seedName = ancestral:GetAttribute("SeedName")
                    if seedName ~= nil then
                        if seedName == "Bamboo" then isBamboo = true; IgnoredPrompts[inst] = true end
                        break
                    end
                    ancestral = ancestral.Parent
                end
                if not isBamboo and not IgnoredPrompts[inst] then
                    if Acoes.ProcessarTeleporteEPrompt(inst) then return true end
                end
            end
        end
    end
    return false
end

local FarmMap = {}
function FarmMap.Processar()
    if not State.autoSeedPack then return false end
    local mapFolder = Workspace:FindFirstChild("Map")
    if not mapFolder then return false end
    local seedFolder = mapFolder:FindFirstChild("SeedPackSpawnServerLocations")
    if not seedFolder then return false end
    for _, inst in ipairs(seedFolder:GetDescendants()) do
        if inst:IsA("ProximityPrompt") then return Acoes.ProcessarTeleporteEPrompt(inst) end
    end
    return false
end

local CollectAll = {}
function CollectAll.Processar()
    if not State.autoCollectAll or not DroppedItems then return false end
    for _, item in ipairs(DroppedItems:GetChildren()) do
        local anchor = item:FindFirstChild("PromptAnchor")
        local prompt = anchor and anchor:FindFirstChild("PickupPrompt") or item:FindFirstChildOfClass("ProximityPrompt", true)
        if prompt then return Acoes.ProcessarTeleporteEPrompt(prompt) end
    end
    return false
end

local Retorno = {}
function Retorno.Processar()
    if not State.autoRetorno or not State.meuPlotNome or not Gardens then return false end
    local plot = Gardens:FindFirstChild(State.meuPlotNome)
    local root = Char.Root()
    if plot and root then
        local destino = plot:GetPivot().Position + Vector3.new(0, 3, 0)
        if (root.Position - destino).Magnitude > 35 then
            Char.Teleportar(destino)
            return true
        end
    end
    return false
end

