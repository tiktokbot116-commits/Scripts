GM.ConfigSystem.Listar = function()
    local lista = {}
    if listfiles and isfolder(GM.Config.Pasta) then
        pcall(function()
            for _, arquivo in ipairs(listfiles(GM.Config.Pasta)) do
                local nome = string.match(arquivo, "([^/\\]+)%.json$")
                if nome then table.insert(lista, nome) end
            end
        end)
    end
    if #lista == 0 then table.insert(lista, "Nenhuma config") end
    return lista
end

