local Prompt = {}
function Prompt.AtivarImediato(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    pcall(function() prompt.RequiresLineOfSight = false; prompt.MaxActivationDistance = 999999 end)
    if fireproximityprompt then fireproximityprompt(prompt); return true end
    pcall(function() prompt.HoldDuration = 0; prompt:InputHoldBegin(); prompt:InputHoldEnd() end)
    Input.PressionarE()
    return true
end

------------------------------------------------------------------------
-- MODULO: PERSONAGEM / TELEPORTE [CÓDIGO ORIGINAL MANTIDO]
------------------------------------------------------------------------
local Char = {}
function Char.Root()
    local character = LocalPlayer.Character
    return character and character:FindFirstChild("HumanoidRootPart")
end
function Char.Teleportar(posicao)
    local root = Char.Root()
    if not root then return end
    root.Anchored = false
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero
    root.CFrame = CFrame.new(posicao)
end
function Char.TeleportarParaPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    local parentPart = prompt.Parent
    if parentPart and parentPart:IsA("BasePart") then Char.Teleportar(parentPart.Position + Vector3.new(0, 1.5, 0)); return true end
    local model = prompt:FindFirstAncestorOfClass("Model")
    if model then
        local pPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
        if pPart then Char.Teleportar(pPart.Position + Vector3.new(0, 1.5, 0)); return true end
    end
    local cursor = prompt.Parent
    while cursor and cursor ~= Workspace do
        if cursor:IsA("BasePart") then Char.Teleportar(cursor.Position + Vector3.new(0, 1.5, 0)); return true end
        cursor = cursor.Parent
    end
    return false
end
function Char.AncorarRaiz(estado)
    local root = Char.Root()
    if root then root.Anchored = estado end
end

