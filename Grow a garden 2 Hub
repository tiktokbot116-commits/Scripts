-- 8. LOOPS DE EXECUÇÃO EM BACKGROUND (TICKERS)
------------------------------------------------------------------------
-- Ticker Principal de Ações
task.spawn(function()
    while task.wait(0.1) do
        -- 1. Colheita
        ExecutarAutoHarvest()
        
        -- 2. Steal
        if NightTime() then
            if Config.AutoStealAll then
                for Index = 1, 10 do -- Limite por ciclo para não travar
                    local Valuable = GetValuableForSteal(nil)
                    if Valuable then ExecutarStealItem(Valuable) else break end
                end
                if Config.AutoRetorno then ReturnToPlot() end
            elseif Config.AutoRoubo and Config.PlotAlvo ~= "" then
                -- Extrai nome real do plot se vier do dropdown Ex: "Nome (Plot1)"
                local plotName = string.match(Config.PlotAlvo, "%((Plot%d+)%)")
                local targetPlot = Gardens:FindFirstChild(plotName or "")
                
                if targetPlot then
                    for Index = 1, 10 do
                        local Valuable = GetValuableForSteal(targetPlot)
                        if Valuable then ExecutarStealItem(Valuable) else break end
                    end
                end
                if Config.AutoRetorno then ReturnToPlot() end
            end
        end
        
        -- 3. Venda Automática
        if Config.AutoVenda then
            local bk = LocalPlayer:FindFirstChild("Backpack")
            if bk and #bk:GetChildren() >= (tonumber(Config.QtdVenda) or 100) then
                if Networking and Networking.NPCS then 
                    pcall(function() Networking.NPCS.SellAll:Fire() end) 
                end
            end
        end
    end
end)

-- Ticker de Compra
task.spawn(function()
    while task.wait(0.5) do
        ExecutarAutoBuy()
    end
end)

