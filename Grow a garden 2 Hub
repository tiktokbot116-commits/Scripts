------------------------------------------------------------------------
-- LOOP PRINCIPAL
------------------------------------------------------------------------
task.spawn(function()
    while task.wait(0.1) do
        -- Interrompe ciclo principal se dependências vitais não existirem
        if not Gardens then continue end
        
        local isNight = Workspace:GetAttribute("ActivePhase")=="Night"
        if IsFlinging then continue end
        
        -- 1. FUGA / FLING ao detectar dono enquanto rouba
        if Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"] then
            local pos = Char.Root() and Char.Root().Position
            if pos then
                for i=1,8 do
                    local pm=Gardens:FindFirstChild("Plot"..i)
                    if pm and IsInPlotArea2D(pm,pos) and pm.Name~=Plots.GetMeuPlot() then
                        if not isNight then
                            IsPerformingAction=false
                            local mP=Plots.GetMeuPlot()
                            if mP and Gardens:FindFirstChild(mP) then
                                Char.Teleportar(Gardens[mP]:GetPivot().Position+Vector3.new(0,5,0))
                                task.wait(1)
                            end
                        else
                            local dn=Plots.DonoDoPlot(pm)
                            local dp=GetPlayerCharacterPos(dn)
                            if dp and IsInPlotArea2D(pm,dp) then
                                local donoP=Players:FindFirstChild(dn)
                                if donoP and not IsFlinging then
                                    task.spawn(function() FlingPlayer(donoP) end)
                                end
                            end
                        end
                        break
                    end
                end
            end
        end
        
        -- Mutex timeout (3s)
        if IsPerformingAction and tick()-ActionTimestamp<3 then continue end
        if IsPerformingAction then IsPerformingAction=false end
        
        local executou=false
        
        -- 2. HARVEST PRÓPRIO
        if Library.Flags["AutoColeta"] then
            task.spawn(PerformHarvest)
        end
        
        -- 3. ITENS SOLTOS
        if Library.Flags["AutoCollectAll"] and DroppedItems then
            for _,i in ipairs(DroppedItems:GetDescendants()) do
                if i:IsA("ProximityPrompt") and i.Enabled then
                    if ExecutarInteracao(i) then executou=true; break end
                end
            end
        end
        if executou then continue end
        
        -- 4. SEED PACKS
        if Library.Flags["AutoSeedMap"] then
            local sf=Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("SeedPackSpawnServerLocations")
            if sf then
                for _,i in ipairs(sf:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Enabled then
                        if ExecutarInteracao(i) then executou=true; break end
                    end
                end
            end
        end
        if executou then continue end
        
        -- 5. ROUBO INTELIGENTE
        if isNight and (Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"]) then
            if Library.Flags["AutoStealAll"] then
                local lista=GetStealablePlants()
                for _,data in ipairs(lista) do
                    if not BLOk(data.Plot.Name) then continue end
                    local dn=Plots.DonoDoPlot(data.Plot)
                    local dp=GetPlayerCharacterPos(dn)
                    if dp and IsInPlotArea2D(data.Plot,dp) then
                        local donoP=Players:FindFirstChild(dn)
                        if donoP and not IsFlinging then
                            task.spawn(function() FlingPlayer(donoP) end)
                        end
                    end
                    if ExecutarInteracao(data.Prompt) then
                        executou=true; break
                    else
                        BLAdd(data.Plot.Name)
                    end
                end
            elseif Library.Flags["AutoRoubo"] and Library.Flags["PlotAlvo"]~="" then
                local rn=string.match(Library.Flags["PlotAlvo"],"%(Plot(%d+)%)")
                local alvo=rn and Gardens:FindFirstChild("Plot"..rn)
                if alvo and BLOk(alvo.Name) then
                    local dn=Plots.DonoDoPlot(alvo)
                    local dp=GetPlayerCharacterPos(dn)
                    if dp and IsInPlotArea2D(alvo,dp) then
                        local donoP=Players:FindFirstChild(dn)
                        if donoP and not IsFlinging then
                            task.spawn(function() FlingPlayer(donoP) end)
                        end
                    end
                    local pf=alvo:FindFirstChild("Plants")
                    if pf then
                        local ign=Library.Flags["PlantsIgnorar"] or {}
                        for _,plant in ipairs(pf:GetChildren()) do
                            local sn=plant:GetAttribute("SeedName")
                            if sn and table.find(ign,sn) then continue end
                            local p=plant:FindFirstChild("StealPrompt",true)
                            if p and p.Enabled then
                                if ExecutarInteracao(p) then executou=true; break end
                            end
                        end
                    end
                    if not executou then BLAdd(alvo.Name) end
                end
            end
        end
        if executou then continue end
        
        -- 6. VENDA
        if Library.Flags["AutoVenda"] then
            local bk=LocalPlayer:FindFirstChild("Backpack")
            if bk and #bk:GetChildren()>=(tonumber(Library.Flags["QtdVenda"]) or 100) then
                if Networking and Networking.NPCS then
                    pcall(function() Networking.NPCS.SellAll:Fire() end)
                    task.wait(0.4); executou=true
                end
            end
        end
        if executou then continue end
        
        -- 7. COMPRA
        if Library.Flags["AutoBuyToggle"] then
            local tgts=Library.Flags["SementesAlvo"]
            if type(tgts)=="table" then
                for _,s in ipairs(tgts) do
                    if ComprarSemente(s) then task.wait(0.3); break end
                end
            end
        end
        
        -- 8. RETORNO
        if Library.Flags["AutoRetorno"] then
            local mP=Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local home=Gardens[mP]:GetPivot().Position+Vector3.new(0,5,0)
                if Char.Root() and (Char.Root().Position-home).Magnitude>35 then
                    Char.Teleportar(home)
                end
            end
        end
    end
end)
