local function GetPlayerCharacterPos(name)
    local p = Players:FindFirstChild(name)
    return p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.HumanoidRootPart.Position or nil
end

local function IsInPlotArea2D(model, pos)
    if not model or not pos then return false end
    local ok, cf, sz
    ok, cf = pcall(function() return (model:GetBoundingBox()) end)
    if not ok or not cf then return false end
    ok, sz = pcall(function() local _,s = model:GetBoundingBox(); return s end)
    if not ok or not sz then return false end
    
    local lp = cf:PointToObjectSpace(pos)
    return math.abs(lp.X) <= sz.X/2 + 2 and math.abs(lp.Z) <= sz.Z/2 + 2
end

