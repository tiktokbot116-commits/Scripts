local Plots = {}
local CachePlayersPorPlotId = {}
local function reconstruirCachePlayers()
    table.clear(CachePlayersPorPlotId)
    for _, p in ipairs(Players:GetPlayers()) do
        local pid = p:GetAttribute("PlotId")
        if pid then CachePlayersPorPlotId[tonumber(pid)] = p.Name end
    end
end
reconstruirCachePlayers()
Players.PlayerAdded:Connect(reconstruirCachePlayers)
Players.PlayerRemoving:Connect(reconstruirCachePlayers)
for _, p in ipairs(Players:GetPlayers()) do
    p.AttributeChanged:Connect(function(attr) if attr == "PlotId" then reconstruirCachePlayers() end end)
end

function Plots.DonoDoPlot(plot)
    if not plot then return nil end
    local num = tonumber(string.match(plot.Name, "%d+"))
    return num and CachePlayersPorPlotId[num] or nil
end

function Plots.GetMeuPlot()
    local pid = LocalPlayer:GetAttribute("PlotId")
    return pid and "Plot" .. tostring(pid) or nil
end

function Plots.ListarParaDropdown()
    if not Gardens then return {} end
    local itens = {}
    for _, plot in ipairs(Gardens:GetChildren()) do
        if string.match(plot.Name, "^Plot%d+$") then
            local dono = Plots.DonoDoPlot(plot)
            table.insert(itens, dono and (dono == LocalPlayer.Name and dono.." (meu plot)" or dono.." ("..plot.Name..")") or "Sem Dono ("..plot.Name..")")
        end
    end
    table.sort(itens)
    return itens
end

local function ObterPlantasDoMeuPlot()
    local tipos, seen = {}, {}
    local mP = Plots.GetMeuPlot()
    if mP and Gardens and Gardens:FindFirstChild(mP) then
        local pastaPlants = Gardens[mP]:FindFirstChild("Plants")
        if pastaPlants then
            for _, model in ipairs(pastaPlants:GetChildren()) do
                local sName = model:GetAttribute("SeedName")
                if sName and not seen[sName] then
                    seen[sName] = true
                    table.insert(tipos, sName)
                end
            end
        end
    end
    table.sort(tipos)
    return tipos
end

