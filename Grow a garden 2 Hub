local Plots = {}

function Plots.ResolverMeuPlot()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if plotId then
        local num = tonumber(plotId)
        if num then
            State.meuPlotNome = "Plot" .. tostring(num)
            return
        end
    end
end

local CachePlayersPorPlotId = {}

local function reconstruirCachePlayers()
    table.clear(CachePlayersPorPlotId)
    for _, p in ipairs(Players:GetPlayers()) do
        local pid = p:GetAttribute("PlotId")
        if pid then
            CachePlayersPorPlotId[tonumber(pid)] = p.Name
        end
    end
end

reconstruirCachePlayers()
Players.PlayerAdded:Connect(reconstruirCachePlayers)
Players.PlayerRemoving:Connect(reconstruirCachePlayers)

Players.PlayerAdded:Connect(function(p)
    p.AttributeChanged:Connect(function(attr)
        if attr == "PlotId" then reconstruirCachePlayers() end
    end)
end)
for _, p in ipairs(Players:GetPlayers()) do
    p.AttributeChanged:Connect(function(attr)
        if attr == "PlotId" then reconstruirCachePlayers() end
    end)
end

function Plots.DonoDoPlot(plot)
    if not plot then return nil end
    local plotNum = tonumber(string.match(plot.Name, "%d+"))
    if not plotNum then return nil end
    return CachePlayersPorPlotId[plotNum]
end

function Plots.ListarParaDropdown()
    if not Gardens then return {} end
    local itens = {}

    for _, plot in ipairs(Gardens:GetChildren()) do
        if string.match(plot.Name, "^Plot%d+$") then
            local dono = Plots.DonoDoPlot(plot)
            local rotulo

            if dono then
                if dono == LocalPlayer.Name then
                    rotulo = dono .. " (meu plot)"
                else
                    rotulo = dono .. " (" .. plot.Name .. ")"
                end
            else
                rotulo = "Sem Dono (" .. plot.Name .. ")"
            end
            table.insert(itens, rotulo)
        end
    end
    table.sort(itens)
    return itens
end

