    Multiple = false,
    Values = ConfigSystem.Listar(),
    Callback = function(escolha)
        if escolha and escolha ~= "Nenhuma config" and escolha ~= "" then
            local path = ConfigSystem.Pasta .. "/" .. escolha .. ".json"
            if isfile and isfile(path) then
                local conteudo = readfile(path)
                local ok, dados = pcall(HttpService.JSONDecode, HttpService, conteudo)
                if ok and type(dados) == "table" then
                    for k, v in pairs(dados) do
                        local el = Library.Elements[k]
                        if el and el.SetValue then pcall(function() el:SetValue(v) end) end
                    end
                end
            end
        end
    end
})

TabConfig:AddButton({
    Title = "Atualizar Lista de Arquivos",
    Callback = atualizarDropdownConfigs
})

atualizarDropdownConfigs()

