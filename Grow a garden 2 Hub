    Multiple = true,
    Values = ObterListaDeSementes(),
    Callback = function(selected) end
})

TabAutos:AddToggle("AutoBuySeeds", {
    Title = "Auto Comprar Sementes Selecionadas",
    Default = false,
    Callback = function(state)
        if state then
            task.spawn(function()
                while Library.Flags["AutoBuySeeds"] do
                    local escolhidas = Library.Flags["SementesAlvo"]
                    if type(escolhidas) == "table" and #escolhidas > 0 then
                        for _, sem in ipairs(escolhidas) do
                            if not Library.Flags["AutoBuySeeds"] then break end
                            ComprarSemente(sem)
                            task.wait(0.2)
                        end
                    end
                    task.wait(1)
                end
            end)
        end
    end
})

