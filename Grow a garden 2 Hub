local function PerformHarvest()
    if not Networking or not Networking.Garden then return end
    local OwnerPlot = nil
    for _, plot in pairs(Gardens:GetChildren()) do
        if plot:GetAttribute("Owner") == LocalPlayer.Name then OwnerPlot = plot; break end
    end
    if not OwnerPlot then return end
    
    local plantsFolder = OwnerPlot:FindFirstChild("Plants")
    if not plantsFolder then return end

    for _, plant in ipairs(plantsFolder:GetChildren()) do
        if not plant:IsDescendantOf(Workspace) then continue end
        local plantId = plant:GetAttribute("PlantId")
        if not plantId then continue end

        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                local maxAge = fruit:GetAttribute("MaxAge")
                local currentAge = fruit:GetAttribute("Age")
                if not (fruit:IsA("Model") and maxAge and currentAge and currentAge >= maxAge) then continue end
                
                local fruitId = fruit:GetAttribute("FruitId") or ""
                pcall(function() Networking.Garden.CollectFruit:Fire(plantId, fruitId) end)
                task.wait(0.2)
            end
        end
    end
end

local function ObterListaDeSementes()
    local sementes = {}
    pcall(function()
        local items = ReplicatedStorage:WaitForChild("StockValues", 5):WaitForChild("SeedShop", 5):WaitForChild("Items", 5)
        for _, item in ipairs(items:GetChildren()) do table.insert(sementes, item.Name) end
    end)
    table.sort(sementes)
    return sementes
end

local function ComprarSemente(nome)
    local ok = false
    pcall(function()
        local items = ReplicatedStorage:FindFirstChild("StockValues") and ReplicatedStorage.StockValues:FindFirstChild("SeedShop") and ReplicatedStorage.StockValues.SeedShop:FindFirstChild("Items")
        if not items then return end
        local item = items:FindFirstChild(nome)
        if not item or item.Value <= 0 then return end
        if Networking and Networking.SeedShop and Networking.SeedShop.PurchaseSeed then
            Networking.SeedShop.PurchaseSeed:Fire(nome)
            ok = true
        end
    end)
    return ok
end

