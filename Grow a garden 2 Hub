task.spawn(function()
    while task.wait(0.1) do
        local executou = false
        local isNight = (Workspace:GetAttribute("ActivePhase") == "Night")

        if (GM.Library.Flags["AutoStealAll"] or GM.Library.Flags["AutoRoubo"]) then
            local pPos = GM.Char.Root() and GM.Char.Root().Position
            if pPos then
                local currentPlot = nil
                for i=1, 8 do
                    local pModel = Gardens:FindFirstChild("Plot"..i)
                    if pModel and GM.IsInPlotArea2D(pModel, pPos) then
                        currentPlot = pModel
                        break
                    end
                end

                if currentPlot and currentPlot.Name ~= GM.Plots.GetMeuPlot() then
                    local needEscape = false
                    if not isNight then needEscape = true 
                    else
                        local dName = GM.Plots.DonoDoPlot(currentPlot)
                        local dPos = GM.GetPlayerCharacterPos(dName)
                        if dPos and GM.IsInPlotArea2D(currentPlot, dPos) then
                            GM.BlacklistSteal[currentPlot.Name] = true
                            needEscape = true 
                        end
                    end

                    if needEscape then
                        GM.IsPerformingAction = false
                        local mP = GM.Plots.GetMeuPlot()
                        if mP and Gardens:FindFirstChild(mP) then 
                            GM.Char.Teleportar(Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)) 
                            task.wait(1) 
                        end
                        continue
                    end
                end
            end
        end

        if GM.IsPerformingAction then continue end

        if GM.Library.Flags["AutoColeta"] then
            local mP = GM.Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local ignorar = GM.Library.Flags["PlantsIgnorar"] or {}
                for _, i in ipairs(Gardens[mP]:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Name == "HarvestPrompt" and i.Enabled then
                        local plantModel = i:FindFirstAncestorOfClass("Model")
                        local sName = plantModel and plantModel:GetAttribute("SeedName")
                        if sName and table.find(ignorar, sName) then continue end
                        if GM.ExecutarInteracao(i) then executou = true; break end
                    end
                end
            end
        end
        if executou then continue end

        if GM.Library.Flags["AutoCollectAll"] and DroppedItems then
            for _, i in ipairs(DroppedItems:GetDescendants()) do
                if i:IsA("ProximityPrompt") and i.Enabled then
                    if GM.ExecutarInteracao(i) then executou = true; break end
                end
            end
        end
        if executou then continue end

        if GM.Library.Flags["AutoSeedMap"] then
            local sf = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("SeedPackSpawnServerLocations")
            if sf then
                for _, i in ipairs(sf:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Enabled then
                        if GM.ExecutarInteracao(i) then executou = true; break end
                    end
                end
            end
        end
        if executou then continue end

        if isNight and (GM.Library.Flags["AutoStealAll"] or GM.Library.Flags["AutoRoubo"]) then
            local alvo = nil
            if GM.Library.Flags["AutoStealAll"] then
                local plotsLivres = {}
                local meuP = GM.Plots.GetMeuPlot()
                for i=1, 8 do
                    local pN = "Plot"..i
                    if pN ~= meuP and not GM.BlacklistSteal[pN] then
                        local model = Gardens:FindFirstChild(pN)
                        if model and GM.Plots.DonoDoPlot(model) then table.insert(plotsLivres, model) end
                    end
                end
                if #plotsLivres > 0 then alvo = plotsLivres[math.random(1, #plotsLivres)] end
            elseif GM.Library.Flags["AutoRoubo"] and GM.Library.Flags["PlotAlvo"] ~= "" then
                local realName = string.match(GM.Library.Flags["PlotAlvo"], "%((Plot%d+)%)")
                if realName and not GM.BlacklistSteal[realName] then alvo = Gardens:FindFirstChild(realName) end
            end

            if alvo then
                local donoName = GM.Plots.DonoDoPlot(alvo)
                local dPos = GM.GetPlayerCharacterPos(donoName)
                if dPos and GM.IsInPlotArea2D(alvo, dPos) then
                    GM.BlacklistSteal[alvo.Name] = true
                else
                    for _, i in ipairs(alvo:GetDescendants()) do
                        if i:IsA("ProximityPrompt") and i.Name == "StealPrompt" and i.Enabled then
                            local plantModel = i:FindFirstAncestorOfClass("Model")
                            local sName = plantModel and plantModel:GetAttribute("SeedName")
                            local ignorar = GM.Library.Flags["PlantsIgnorar"] or {}
                            if sName and table.find(ignorar, sName) then continue end
                            if GM.ExecutarInteracao(i) then executou = true; break end
                        end
                    end
                    if not executou then GM.BlacklistSteal[alvo.Name] = true end
                end
            end
        end
        if executou then continue end

        if GM.Library.Flags["AutoVenda"] then
            local bk = LocalPlayer:FindFirstChild("Backpack")
            if bk and #bk:GetChildren() >= (tonumber(GM.Library.Flags["QtdVenda"]) or 100) then
                if Networking and Networking.NPCS then 
                    pcall(function() Networking.NPCS.SellAll:Fire() end) 
                    task.wait(0.5) 
                    executou = true 
                end
            end
        end
        if executou then continue end

        if GM.Library.Flags["AutoBuyToggle"] then
            local targets = GM.Library.Flags["SementesAlvo"]
            if type(targets) == "table" then
                for _, semente in ipairs(targets) do
                    if GM.ComprarSemente(semente) then task.wait(0.5); executou = true; break end
                end
            end
        end
        if executou then continue end

        if GM.Library.Flags["AutoRetorno"] then
            local mP = GM.Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local p = Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)
                if GM.Char.Root() and (GM.Char.Root().Position - p).Magnitude > 35 then GM.Char.Teleportar(p) end
            end
        end
    end
end)

