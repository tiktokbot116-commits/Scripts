------------------------------------------------------------------------
-- 4. FUNÇÕES UTILITÁRIAS GERAIS (PLAYER & PLOTS)
------------------------------------------------------------------------
local function GetHumanoid(Player)
    local Character = Player and Player.Character
    return Character and Character:FindFirstChildOfClass("Humanoid")
end

local function GetRoot(Player)
    local Humanoid = GetHumanoid(Player)
    return Humanoid and Humanoid.RootPart
end

local function GetPlot(Player)
    if not Gardens or not Player then return nil end
    for _, Plot in next, Gardens:GetChildren() do
        if Plot:GetAttribute("OwnerUserId") == Player.UserId then
            return Plot
        end
    end
    return nil
end

local function GetMeuPlot()
    return GetPlot(LocalPlayer)
end

local function GetPlotName(Player)
    local plot = GetPlot(Player)
    return plot and plot.Name or nil
end

local function PlotUnlocked(Player)
    local Plot = GetPlot(Player)
    local Area = Plot and Plot:FindFirstChild("Visual") and Plot.Visual:FindFirstChild("PlotSizeReferenceVisual")
    local Unlocked = true

    if Area and Player.Character then
        for _, Touching in next, Workspace:GetPartBoundsInBox(Area.CFrame, Area.Size) do
            if Touching:IsDescendantOf(Player.Character) then
                Unlocked = false
                break
            end
        end
    end
    return Unlocked
end

local function NightTime()
    local Night = ReplicatedStorage:FindFirstChild("Night")
    return Night and Night.Value or false
end

local function GetPlayerCharacterPos(playerName)
    local p = Players:FindFirstChild(playerName)
    if p and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
        return p.Character.HumanoidRootPart.Position
    end
    return nil
end

local function ReturnToPlot()
    local mP = GetMeuPlot()
    if mP then
        for Index = 1, 10 do
            local Root = GetRoot(LocalPlayer)
            if Root and mP:FindFirstChild("PlotSizeReference") then
                Root.CFrame = mP.PlotSizeReference.CFrame        
                task.wait(0.05)
            end
        end
    end
end

------------------------------------------------------------------------
-- 5. SISTEMA DE COMPRA (WHITELIST / LÓGICA INVERTIDA)
------------------------------------------------------------------------
local Prices = {}
local PlayerData = nil

pcall(function()
    for _, v in pairs(getgc()) do
        if type(v) == "function" and debug.info(v, "s"):match("RestockStoreController") then
            if debug.info(v, "l") == 575 then
                table.insert(Prices, debug.getupvalue(v, 3))
                PlayerData = debug.getupvalue(v, 9)
            end
        end
    end
end)

local function CanAfford(itemName)
    if not PlayerData then return false end
    for _, opts in pairs(Prices) do
        if opts[itemName] and (PlayerData.Data.Sheckles or 0) >= opts[itemName].price then
            return true
        end
    end
    return false
end

local function GetTodasAsSementesDoJogo()
    local sementes = {}
    pcall(function()
        local seedShopItems = ReplicatedStorage:WaitForChild("StockValues", 5):WaitForChild("SeedShop", 5):WaitForChild("Items", 5)
        for _, item in ipairs(seedShopItems:GetChildren()) do
            -- Ignoramos a checagem de estoque aqui para o Dropdown mostrar tudo
            table.insert(sementes, item.Name)
        end
    end)
    table.sort(sementes)
    return sementes
end

local function ExecutarAutoBuy()
    if not Config.AutoBuy then return end
    
    local Shops = {
        {Stock = ReplicatedStorage.StockValues.SeedShop.Items, List = Config.SelectedSeeds, Net = Networking.SeedShop.PurchaseSeed},
        {Stock = ReplicatedStorage.StockValues.GearShop.Items, List = Config.SelectedGears, Net = Networking.GearShop.PurchaseGear},
        {Stock = ReplicatedStorage.StockValues.CrateShop.Items, List = Config.SelectedCrates, Net = Networking.CrateShop.PurchaseCrate}
    }
    
    for _, shop in pairs(Shops) do
        for _, item in pairs(shop.Stock:GetChildren()) do
            if item.Value > 0 and table.find(shop.List, item.Name) and CanAfford(item.Name) then
                pcall(function()
                    shop.Net:Fire(item.Name)
                end)
            end
        end
    end
end

------------------------------------------------------------------------
-- 6. SISTEMA DE COLHEITA (HARVEST POR ID - SEM TELEPORTE)
------------------------------------------------------------------------
local function IsGrown(plant)
    local maxAge = plant:GetAttribute("MaxAge")
    local currentAge = plant:GetAttribute("Age")
    if not maxAge or not currentAge then return false end
    return currentAge >= maxAge
end

local function GetHarvestablePlants()
    local plants = {}
    local OwnerPlot = GetMeuPlot()
    
    if not OwnerPlot then return plants end
    
    local plantsFolder = OwnerPlot:FindFirstChild("Plants")
    if not plantsFolder then return plants end

    for _, plant in pairs(plantsFolder:GetChildren()) do
        local fruitsFolder = plant:FindFirstChild("Fruits")
        
        if fruitsFolder then
            for _, fruit in pairs(fruitsFolder:GetChildren()) do
                if fruit:IsA("Model") and IsGrown(fruit) then
                    table.insert(plants, fruit)
                end
            end
        else
            if plant:IsA("Model") and IsGrown(plant) then
                table.insert(plants, plant)
            end
        end
    end
    return plants
end

local function ExecutarAutoHarvest()
    if not Config.AutoHarvest then return end
    
    for _, item in pairs(GetHarvestablePlants()) do
        if not item then continue end
        
        local plantId = item:GetAttribute("PlantId")
        local fruitId = item:GetAttribute("FruitId") or ""
        
        -- Aplica Filtro (Ignorar Plantas)
        local seedName = item:GetAttribute("SeedName") or item:GetAttribute("PlantName")
        if seedName and table.find(Config.PlantsIgnorar, seedName) then
            continue
        end
        
        if plantId and Networking and Networking.Garden then
            pcall(function()
                Networking.Garden.CollectFruit:Fire(plantId, fruitId)
            end)
        end
    end
end

------------------------------------------------------------------------
-- 7. SISTEMA DE ROUBO E FLING (CALCULO DE VALOR E ATAQUE)
------------------------------------------------------------------------
local function CalculateValueForSteal(Fruit)
    if not FruitValueCalc then return 0 end
    local FruitName = Fruit:GetAttribute("CorePartName") or Fruit:GetAttribute("PlantName")
    local SizeMultiplier = Fruit:GetAttribute("SizeMulti") or Fruit:GetAttribute("Age")
    local Mutation = Fruit:GetAttribute("Mutation")
    return FruitValueCalc(FruitName, SizeMultiplier, Mutation, LocalPlayer, 1)
end

local function GetValuableForSteal(TargetPlot)
    local Value = 0
    local Item = nil

    local plotsToSearch = {}
    if TargetPlot then
        table.insert(plotsToSearch, TargetPlot)
    else
        plotsToSearch = Gardens:GetChildren()
    end

    for _, Plot in next, plotsToSearch do
        local OwnerUserId = Plot:GetAttribute("OwnerUserId")
        if not OwnerUserId then continue end
        
        local Owner = Players:GetPlayerByUserId(OwnerUserId)
        local Humanoid = Owner and GetHumanoid(Owner)

        if not Owner or Owner == LocalPlayer then continue end
        if Humanoid and Humanoid.Sit then continue end

        local plantsFolder = Plot:FindFirstChild("Plants")
        if not plantsFolder then continue end

        for _, Plant in next, plantsFolder:GetChildren() do
            local Fruits = Plant:FindFirstChild("Fruits")
            local Found = {}

            if Fruits then
                for _, Fruit in next, Fruits:GetChildren() do
                    local HarvestPart = Fruit:FindFirstChild("HarvestPart")
                    local StealPrompt = HarvestPart and HarvestPart:FindFirstChild("StealPrompt")
                    if StealPrompt then
                        Found[Fruit] = CalculateValueForSteal(Fruit)
                    end
                end
            else
                local HarvestPart = Plant:FindFirstChild("HarvestPart")
                local StealPrompt = HarvestPart and HarvestPart:FindFirstChild("StealPrompt")
                if StealPrompt then
                    Found[Plant] = CalculateValueForSteal(Plant)
                end
            end

            for F, FruitValue in next, Found do
                if FruitValue > Value then
                    Value = FruitValue
                    Item = F
                end
            end
        end
    end

    return Item, Value
end

local function ExecutarFling(Player)
	local Flinging = true
    local Root = GetRoot(LocalPlayer)
    local Humanoid = GetHumanoid(LocalPlayer)
    if not Root or not Humanoid then return end
    
	local OldPosition = Root.CFrame

	task.spawn(function()
		local Movel = 0.1
        local Velocity = Root.Velocity

		repeat task.wait()
			Velocity = Root.Velocity
			Root.Velocity = Velocity * 10000 + Vector3.new(0, 10000, 0)
			RunService.RenderStepped:Wait()
			Root.Velocity = Velocity
			RunService.Stepped:Wait()
			Root.Velocity = Velocity + Vector3.new(0, Movel, 0)
			Movel = Movel * -1
		until not Flinging
	end)

    local _Humanoid = GetHumanoid(Player)
    local _Root = GetRoot(Player)
    local Start = tick()

    if _Humanoid and _Root then
        repeat task.wait()
            local Success, _Result = pcall(function()
                sethiddenproperty(Root, "PhysicsRepRootPart", _Root)
            end)

            local Magnitude = _Root.Velocity.Magnitude
            local Direction = _Humanoid.MoveDirection or Vector3.zero
            local PredictionOffset

            if Magnitude < 5 or Success then
                PredictionOffset = Vector3.new(0, math.random(-0.5, 0.4), 0)
            else
                PredictionOffset = Direction * (Magnitude / Random.new():NextNumber(0.7, 8)) - Vector3.new(0, math.random(-1, 1), 0)
            end

            local TargetCFrame = CFrame.new(_Root.Position)
            local PredictedCFrame = TargetCFrame * CFrame.new(PredictionOffset)

            Humanoid.Sit = false
            Workspace.CurrentCamera.CameraSubject = _Humanoid
            Root.CFrame = PredictedCFrame * CFrame.Angles(math.random(0, 360), 0, 0)
        until (tick() - Start >= 2) or (_Root.Velocity.Magnitude > 200) or not Root or not Root.Parent or not _Root or not _Root.Parent
    end

	Flinging = false
	Root.CFrame = OldPosition
	Workspace.CurrentCamera.CameraSubject = Humanoid

	pcall(function()
		sethiddenproperty(Root, "PhysicsRepRootPart", nil)
	end)
end

local function ExecutarStealItem(Fruit)
    if not Fruit then return end
    
    local HarvestPart = Fruit:FindFirstChild("HarvestPart")
    local StealPrompt = HarvestPart and HarvestPart:FindFirstChild("StealPrompt")

    if StealPrompt then
        local UserId = tonumber(Fruit:GetAttribute("UserId"))
        local PlantId = Fruit:GetAttribute("PlantId")
        local FruitId = Fruit:GetAttribute("FruitId")
        local Owner = Players:GetPlayerByUserId(UserId)

        if Owner and not PlotUnlocked(Owner) then
            ExecutarFling(Owner)
        end

        for Index = 1, 2 do
            local Root = GetRoot(LocalPlayer)
            if Root and HarvestPart then
                Root.CFrame = HarvestPart.CFrame
                pcall(function()
                    Networking.Steal.BeginSteal:Fire(UserId, PlantId, FruitId or "")
                    Networking.Steal.CompleteSteal:Fire()
                end)
                task.wait(0.05)
            end
        end
    end
end

