local StockCooldowns = {}
local function VerificarEstoque(itemFrame)
    local stockLabel = itemFrame:FindFirstChild("Main_Frame") and itemFrame.Main_Frame:FindFirstChild("Stock_Text")
    if not stockLabel then return true end
    local txt = string.lower(stockLabel.Text)
    if string.find(txt, "sold out") or string.find(txt, "out of stock") or txt == "0" or string.find(txt, "^0/") or string.find(txt, "^0%s") then return false end
    local n = tonumber(string.match(txt, "^(%d+)"))
    return not (n and n <= 0)
end

local function ObterListaDeSementes()
    local sementes = {}
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui or not pGui:FindFirstChild("SeedShop") then return sementes end
    local shopGui = pGui.SeedShop
    local wasEnabled = shopGui.Enabled
    shopGui.Enabled = true
    task.wait(0.05)
    local normalShop = shopGui:FindFirstChild("Frame") and shopGui.Frame:FindFirstChild("NormalShop")
    if normalShop then
        for _, item in ipairs(normalShop:GetChildren()) do
            if item:IsA("Frame") and item.Name ~= "ItemTemplate" and item.Name ~= "Padding" and item.Name ~= "Robux & Sheckels_Shelf" and VerificarEstoque(item) then
                table.insert(sementes, item.Name)
            end
        end
    end
    shopGui.Enabled = wasEnabled
    table.sort(sementes)
    return sementes
end

local function ComprarSemente(nomeDaSemente)
    local pGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not pGui or not pGui:FindFirstChild("SeedShop") then return false end
    local shopGui = pGui.SeedShop
    local normalShop = shopGui:FindFirstChild("Frame") and shopGui.Frame:FindFirstChild("NormalShop")
    if not normalShop then return false end
    local sementeFrame = normalShop:FindFirstChild(nomeDaSemente)
    if not sementeFrame then return false end

    if StockCooldowns[nomeDaSemente] and tick() - StockCooldowns[nomeDaSemente] < 20 then return false end

    local wasEnabled = shopGui.Enabled
    shopGui.Enabled = true
    task.wait(0.05)

    if not VerificarEstoque(sementeFrame) then
        StockCooldowns[nomeDaSemente] = tick()
        shopGui.Enabled = wasEnabled
        return false
    end

    local seedBtn = sementeFrame:FindFirstChild("Main_Frame") and sementeFrame.Main_Frame:FindFirstChild("TextButton")
    local buyBtn = normalShop:FindFirstChild("Sheckles_Shelf") and normalShop.Sheckles_Shelf:FindFirstChild("Main_Frame") and normalShop.Sheckles_Shelf.Main_Frame:FindFirstChild("Buttons") and normalShop.Sheckles_Shelf.Main_Frame.Buttons:FindFirstChild("BuyButton")

    if seedBtn and buyBtn and VirtualInputManager then
        GuiService.SelectedObject = seedBtn; task.wait(0.05)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game); task.wait(0.05); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        task.wait(0.05)
        GuiService.SelectedObject = buyBtn; task.wait(0.05)
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.Return, false, game); task.wait(0.05); VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
        task.wait(0.05)
    end
    
    GuiService.SelectedObject = nil
    shopGui.Enabled = wasEnabled
    return true
end

