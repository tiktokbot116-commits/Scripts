local function ObterPlantasDoMeuPlot()
    local tipos, seen = {}, {}
    local mP = Plots.GetMeuPlot()
    if not mP or not Gardens or not Gardens:FindFirstChild(mP) then return tipos end
    local plantsFolder = Gardens[mP]:FindFirstChild("Plants")
    if not plantsFolder then return tipos end
    for _, plant in ipairs(plantsFolder:GetChildren()) do
        local sName = plant:GetAttribute("SeedName")
        if sName and not seen[sName] then
            seen[sName] = true
            table.insert(tipos, sName)
        end
    end
    table.sort(tipos)
    return tipos
end

