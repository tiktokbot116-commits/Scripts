            local LL = Mk("UIListLayout",{Parent=LS,ZIndex=51})
            LL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
                LS.CanvasSize=UDim2.new(0,0,0,LL.AbsoluteContentSize.Y)
            end)
            
            local IH,MAXH = 26,130
            local isOpen = false
            local function RefreshLabel() HBtn.Text = " "..cfg.Title.." › "..CurrentLabel() end
            
            local function Close()
                isOpen=false
                Tw(List,0.18,{Size=UDim2.new(1,0,0,0)})
                task.delay(0.2,function() if not isOpen then List.Visible=false end end)
            end
            
            local function Open()
                isOpen=true; List.Visible=true
                Tw(List,0.18,{Size=UDim2.new(1,0,0,math.min(#opts*IH+4,MAXH))})
            end
            
            local function Build()
                if not LS:IsDescendantOf(game) then return end
                for _, c in ipairs(LS:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                
                for _, opt in ipairs(opts) do
                    local IB = Mk("TextButton",{Parent=LS,BackgroundTransparency=1, Size=UDim2.new(1,0,0,IH),Font=Enum.Font.Gotham,Text=" "..tostring(opt), TextColor3=CLR.TXT2,TextSize=12,TextXAlignment=Enum.TextXAlignment.Left, AutoButtonColor=false,ZIndex=52})
                    local Chk
                    if cfg.Multiple then
                        Chk = Mk("TextLabel",{Parent=IB,BackgroundTransparency=1, Position=UDim2.new(1,-22,0.5,-7),Size=UDim2.new(0,16,0,14), Font=Enum.Font.GothamBold,TextSize=12,ZIndex=53, TextColor3=CLR.ACC, Text=(type(Library.Flags[id])=="table" and table.find(Library.Flags[id],opt)) and "✓" or ""})
                    end
                    IB.MouseButton1Click:Connect(function()
                        if cfg.Multiple then
                            local tbl = Library.Flags[id]
                            -- CORREÇÃO CRÍTICA: Previne erro se a tabela foi corrompida no JSON
                            if type(tbl) ~= "table" then tbl = {} Library.Flags[id] = tbl end 
                            
                            local idx = table.find(tbl,opt)
                            if idx then table.remove(tbl,idx) else table.insert(tbl,opt) end
                            if Chk then Chk.Text=table.find(tbl,opt) and "✓" or "" end
                            RefreshLabel(); pcall(cfg.Callback,tbl)
                        else
                            Library.Flags[id]=opt; RefreshLabel(); pcall(cfg.Callback,opt); Close()
                        end
                    end)
                    IB.MouseEnter:Connect(function() Tw(IB,0.08,{TextColor3=CLR.TXT}) end)
                    IB.MouseLeave:Connect(function() Tw(IB,0.08,{TextColor3=CLR.TXT2}) end)
                end
            end
            Build()
            HBtn.MouseButton1Click:Connect(function() if isOpen then Close() else Open() end end)
            
            local obj = {
                Type="Dropdown",
                SetValue=function(_,v)
                    if cfg.Multiple then
                        Library.Flags[id] = (type(v)=="table") and v or {}
                    else
                        Library.Flags[id]=v
                    end
                    RefreshLabel(); pcall(cfg.Callback,v)
                end,
                SetValues=function(_,nv)
                    opts=nv
                    if isOpen then List.Size=UDim2.new(1,0,0,math.min(#opts*IH+4,MAXH)) end
                    pcall(Build); RefreshLabel()
                end
            }
            Library.Elements[id]=obj; return obj
        end
        
        function Elements:AddButton(cfg)
            local B = Mk("TextButton",{Parent=Page,BackgroundColor3=CLR.EL, Size=UDim2.new(1,0,0,34),Font=Enum.Font.GothamSemibold,Text=cfg.Title, TextColor3=CLR.TXT,TextSize=13,AutoButtonColor=false})
            Rnd(6,B); Stk(CLR.BDR,1,B)
            B.MouseButton1Click:Connect(function()
                Tw(B,0.08,{BackgroundColor3=CLR.ACC})
                task.delay(0.18,function() Tw(B,0.18,{BackgroundColor3=CLR.EL}) end)
                pcall(cfg.Callback)
            end)
        end
        return Elements
    end
    return ActiveWindow
end
