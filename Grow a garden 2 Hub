    local out = {}
    pcall(function()
        local items = ReplicatedStorage:WaitForChild("StockValues",5):WaitForChild("SeedShop",5):WaitForChild("Items",5)
        for _, item in ipairs(items:GetChildren()) do table.insert(out, item.Name) end
