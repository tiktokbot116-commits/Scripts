-- Função de Interação Híbrida (Modo "Hardened")
local VirtualInputManager = game:GetService("VirtualInputManager")

local function Interact(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    
    -- 1. A abordagem FireProximityPrompt (Nativa do Exploit)
    -- Se o executor for bom, ele ignora a validação de tempo do servidor.
    if fireproximityprompt then
        fireproximityprompt(prompt)
        return true
    end

    -- 2. A abordagem Virtual (Para quando fireproximityprompt não existe)
    -- Aqui não usamos Hold 0. Simulamos o ciclo de tempo real para o servidor aceitar.
    if VirtualInputManager then
        local originalDuration = prompt.HoldDuration
        
        -- Simulamos o início do segurar
        prompt:InputHoldBegin()
        
        -- O SEGREDO: O servidor precisa que você 'segure' por um tempo mínimo. 
        -- Se for 0.1s, ele geralmente aceita a replicação.
        task.wait(originalDuration > 0 and 0.1 or 0.05) 
        
        prompt:InputHoldEnd()
        return true
    end

    return false
end
