-- Captura upvalues do controller de loja via getgc (executor-specific)
local Prices     = {}
local PlayerData = nil
pcall(function()
    for _, v in pairs(getgc()) do
        if type(v) == "function" and debug.info(v,"s"):match("RestockStoreController") then
            if debug.info(v,"l") == 575 then
                table.insert(Prices, debug.getupvalue(v,3))
                PlayerData = debug.getupvalue(v,9)
            end
        end
    end
end)

local function CanAfford(itemName)
    if not PlayerData then return true end  -- sem dados = tenta comprar mesmo assim
    for _, opts in pairs(Prices) do
        if opts[itemName] and (PlayerData.Data.Sheckles or 0) >= opts[itemName].price then
            return true
        end
    end
    return false
end

-- Lista TODAS as sementes do jogo (StockValues, independente de ter estoque)
local function ObterListaDeSementes()
    local sementes = {}
    pcall(function()
        local items = ReplicatedStorage:WaitForChild("StockValues", 5)
                      :WaitForChild("SeedShop", 5)
                      :WaitForChild("Items", 5)
        for _, item in ipairs(items:GetChildren()) do
            table.insert(sementes, item.Name)   -- sem filtro de Value
        end
    end)
    table.sort(sementes)
    return sementes
end

-- Compra via Networking.SeedShop.PurchaseSeed diretamente (sem simular GUI)
local function ComprarSemente(nomeDaSemente)
    local ok = false
    pcall(function()
        local items = ReplicatedStorage:FindFirstChild("StockValues")
                      and ReplicatedStorage.StockValues:FindFirstChild("SeedShop")
                      and ReplicatedStorage.StockValues.SeedShop:FindFirstChild("Items")
        if not items then return end

        local item = items:FindFirstChild(nomeDaSemente)
        if not item or item.Value <= 0 then
            -- Remove da lista se esgotado
            local targets = Library.Flags["SementesAlvo"]
            if type(targets) == "table" then
                local idx = table.find(targets, nomeDaSemente)
                if idx then table.remove(targets, idx) end
            end
            return
        end

        if not CanAfford(nomeDaSemente) then return end

        if Networking and Networking.SeedShop and Networking.SeedShop.PurchaseSeed then
            Networking.SeedShop.PurchaseSeed:Fire(nomeDaSemente)
            ok = true
        end
    end)
    return ok
end

------------------------------------------------------------------------
-- FUNCOES DO CONTROLADOR DE INTERAÇÃO AFK MUTEX
------------------------------------------------------------------------
local function ExecutarInteracao(prompt)
    if IsPerformingAction then return false end
    IsPerformingAction = true
    
    local sucesso = false
    pcall(function()
        Char.AncorarRaiz(true)
        if Char.TeleportarParaPrompt(prompt) then
            task.wait(0.12) -- Permite posicionamento seguro na rede do jogo antes da ativação
            if prompt and prompt:IsDescendantOf(Workspace) and prompt.Enabled then
                Prompt.AtivarImediato(prompt)
                task.wait(0.18) -- Delay estável para processamento de resposta do servidor
                sucesso = true
            end
        end
    end)
    
    Char.AncorarRaiz(false)
    IsPerformingAction = false
    return sucesso
end

