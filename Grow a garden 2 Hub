local function ObterPlantasDoMeuPlot()
    local tipos,seen={},{}
    local mP=Plots.GetMeuPlot(); if not mP then return tipos end
    local pf=Gardens and Gardens:FindFirstChild(mP) and Gardens[mP]:FindFirstChild("Plants")
    if not pf then return tipos end
    for _, plant in ipairs(pf:GetChildren()) do
        local sn=plant:GetAttribute("SeedName")
        if sn and not seen[sn] then seen[sn]=true; table.insert(tipos,sn) end
    end
    table.sort(tipos); return tipos
end

