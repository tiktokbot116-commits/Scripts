local Char = {}

function Char.Root()
    return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
end

function Char.Teleportar(pos)
    local r = Char.Root();
    if not r then return false end
    pcall(function()
        r.Anchored = false
        r.AssemblyLinearVelocity = Vector3.zero
        r.AssemblyAngularVelocity = Vector3.zero
        r.CFrame = CFrame.new(pos)
    end)
    return true
end

function Char.TeleportarParaPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    local par = prompt.Parent
    if par and par:IsA("BasePart") then
        return Char.Teleportar(par.Position + Vector3.new(0, 2.5, 0))
    end
    local m = prompt:FindFirstAncestorOfClass("Model")
    if m then
        local bp = m.PrimaryPart or m:FindFirstChildWhichIsA("BasePart", true)
        if bp then
            return Char.Teleportar(bp.Position + Vector3.new(0, 2.5, 0))
        end
    end
    return false
end

function Char.AncorarRaiz(v)
    local r = Char.Root()
    if r then
        pcall(function() r.Anchored = v end)
    end
end

