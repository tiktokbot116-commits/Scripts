local function InjetarBotaoAlternancia()
    local mb1 = CoreGui:FindFirstChild("MobileToggleHubCustom")
    local mb2 = PlayerGui:FindFirstChild("MobileToggleHubCustom")
    if mb1 then mb1:Destroy() end; if mb2 then mb2:Destroy() end

    local ToggleScreen = Create("ScreenGui", { Name = "MobileToggleHubCustom", ResetOnSpawn = false })
    local alocado = pcall(function() ToggleScreen.Parent = CoreGui end)
    if not alocado then ToggleScreen.Parent = PlayerGui end

    local ToggleButton = Create("TextButton", { Parent = ToggleScreen, Size = UDim2.new(0, 50, 0, 50), Position = UDim2.new(0, 15, 0.4, 0), BackgroundColor3 = Color3.fromRGB(20, 20, 20), BackgroundTransparency = 0.2, Text = "HUB", TextColor3 = Color3.fromRGB(220, 220, 220), TextSize = 13, Font = Enum.Font.GothamBold })
    Create("UICorner", { Parent = ToggleButton, CornerRadius = UDim.new(0, 99) })
    local Stroke = Create("UIStroke", { Parent = ToggleButton, Color = Color3.fromRGB(150, 150, 150), Thickness = 2 })

    local drag, dragI, dragS, startP
    ToggleButton.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then
            drag = true; dragS = i.Position; startP = ToggleButton.Position
            i.Changed:Connect(function() if i.UserInputState == Enum.UserInputState.End then drag = false end end)
        end
    end)
    ToggleButton.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch then dragI = i end end)
    UserInputService.InputChanged:Connect(function(i)
        if i == dragI and drag then
            local d = i.Position - dragS; ToggleButton.Position = UDim2.new(startP.X.Scale, startP.X.Offset + d.X, startP.Y.Scale, startP.Y.Offset + d.Y)
        end
    end)

    ToggleButton.MouseButton1Click:Connect(function()
        AnimateClick(ToggleButton)
        if ActiveWindow and ActiveWindow.ToggleMinimize then
            ActiveWindow.ToggleMinimize()
        end
    end)
end

InjetarBotaoAlternancia()
