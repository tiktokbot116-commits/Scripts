local Config = {
    -- Geral
    AutoVenda = false,
    QtdVenda = 100,
    
    -- Colheita
    AutoHarvest = false,
    PlantsIgnorar = {},
    
    -- Compras (Lógica Invertida: Whitelist)
    AutoBuy = false,
    SelectedSeeds = {},
    SelectedGears = {},
