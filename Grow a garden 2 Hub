-- Anti-Steal Pá Attack
-- Detecta invasor no meu plot → equipa Shovel → teleporta em cima → ataca até sair
task.spawn(function()
    while task.wait(0.15) do
        if not Library.Flags["AntiStealShovel"] then continue end
        local mP = Plots.GetMeuPlot()
        if not mP or not Gardens or not Gardens:FindFirstChild(mP) then continue end
        local meuPlot = Gardens[mP]

        -- Procura o primeiro invasor dentro do meu plot
        local invasor = nil
        for _, pl in ipairs(game:GetService("Players"):GetPlayers()) do
            if pl == LocalPlayer then continue end
            local ch = pl.Character
            if not ch then continue end
            local rt = ch:FindFirstChild("HumanoidRootPart")
            if rt and IsInPlotArea2D(meuPlot, rt.Position) then
                invasor = pl; break
            end
        end
        if not invasor then continue end

        -- Equipa o Shovel antes de agir
        local shovel = EquiparShovel()
        if not shovel then continue end

        -- Confirma que invasor ainda está no plot antes de teleportar
        local iChar = invasor.Character
        if not iChar then continue end
        local iRoot = iChar:FindFirstChild("HumanoidRootPart")
        if not iRoot or not IsInPlotArea2D(meuPlot, iRoot.Position) then continue end

        -- Teleporta em cima e ataca
        pcall(Char.Teleportar, iRoot.Position + Vector3.new(0, 1, 0))
        task.wait(0.05)
        AtacarComShovel()
    end
end)
task.spawn(function()
    while task.wait(0.1) do
        local executou = false
        local isNight = (Workspace:GetAttribute("ActivePhase") == "Night")

        -- 1. Fuga Baseada no Dono OU se Ficou de Dia
        if (Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"]) then
            local pPos = Char.Root() and Char.Root().Position
            if pPos then
                local currentPlot = nil
                for i=1, 8 do
                    local pModel = Gardens:FindFirstChild("Plot"..i)
                    if pModel and IsInPlotArea2D(pModel, pPos) then
                        currentPlot = pModel
                        break
                    end
                end

                if currentPlot and currentPlot.Name ~= Plots.GetMeuPlot() then
                    local needEscape = false
                    
                    if not isNight then
                        needEscape = true -- Ficou de Dia! Foge imediatamente!
                    else
                        local dName = Plots.DonoDoPlot(currentPlot)
                        local dPos = GetPlayerCharacterPos(dName)
                        if dPos and IsInPlotArea2D(currentPlot, dPos) then
                            BlacklistSteal[currentPlot.Name] = true
                            needEscape = true -- Dono entrou! Foge!
                        end
                    end

                    if needEscape then
                        local mP = Plots.GetMeuPlot()
                        if mP and Gardens:FindFirstChild(mP) then 
                            -- Teleporta EXATAMENTE no meio do meu plot e espera 1 segundo
                            Char.Teleportar(Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)) 
                            task.wait(1) 
                        end
                        executou = true
                    end
                end
            end
        end

        if executou then continue end

        -- 2. Itens Soltos
        if Library.Flags["AutoCollectAll"] and DroppedItems then
            for _, i in ipairs(DroppedItems:GetDescendants()) do
                if i:IsA("ProximityPrompt") and i.Enabled then
                    if Char.TeleportarParaPrompt(i) then task.wait(0.05); Prompt.AtivarImediato(i); executou = true; break end
                end
            end
        end
        if executou then continue end

        -- 3. Sementes Pelo Mapa
        if Library.Flags["AutoSeedMap"] then
            local sf = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("SeedPackSpawnServerLocations")
            if sf then
                for _, i in ipairs(sf:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Enabled then
                        if Char.TeleportarParaPrompt(i) then task.wait(0.05); Prompt.AtivarImediato(i); executou = true; break end
                    end
                end
            end
        end
        if executou then continue end

        -- 4. Coleta Própria
        if Library.Flags["AutoColeta"] then
            local mP = Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local ignorar = Library.Flags["PlantsIgnorar"] or {}
                for _, i in ipairs(Gardens[mP]:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Name == "HarvestPrompt" and i.Enabled then
                        local plantModel = i:FindFirstAncestorOfClass("Model")
                        local sName = plantModel and plantModel:GetAttribute("SeedName")
                        if sName and table.find(ignorar, sName) then continue end
                        if Char.TeleportarParaPrompt(i) then task.wait(0.05); Prompt.AtivarImediato(i); executou = true; break end
                    end
                end
            end
        end
        if executou then continue end

        -- 5. Roubo Unitário ou All (Unidos)
        if isNight and (Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"]) then
            local alvo = nil
            if Library.Flags["AutoStealAll"] then
                local plotsLivres = {}
                local meuP = Plots.GetMeuPlot()
                for i=1, 8 do
                    local pN = "Plot"..i
                    if pN ~= meuP and not BlacklistSteal[pN] then
                        local model = Gardens:FindFirstChild(pN)
                        if model and Plots.DonoDoPlot(model) then table.insert(plotsLivres, model) end
                    end
                end
                if #plotsLivres > 0 then alvo = plotsLivres[math.random(1, #plotsLivres)] end
            elseif Library.Flags["AutoRoubo"] and Library.Flags["PlotAlvo"] ~= "" then
                local realName = string.match(Library.Flags["PlotAlvo"], "%((Plot%d+)%)")
                if realName and not BlacklistSteal[realName] then alvo = Gardens:FindFirstChild(realName) end
            end

            if alvo then
                local donoName = Plots.DonoDoPlot(alvo)
                local dPos = GetPlayerCharacterPos(donoName)
                if dPos and IsInPlotArea2D(alvo, dPos) then
                    BlacklistSteal[alvo.Name] = true
                else
                    for _, i in ipairs(alvo:GetDescendants()) do
                        if i:IsA("ProximityPrompt") and i.Name == "StealPrompt" and i.Enabled then
                            local plantModel = i:FindFirstAncestorOfClass("Model")
                            local sName = plantModel and plantModel:GetAttribute("SeedName")
                            local ignorar = Library.Flags["PlantsIgnorar"] or {}
                            if sName and table.find(ignorar, sName) then continue end
                            if Char.TeleportarParaPrompt(i) then 
                                task.wait(0.05)
                                Prompt.AtivarImediato(i)
                                executou = true 
                                break 
                            end
                        end
                    end
                    if not executou then BlacklistSteal[alvo.Name] = true end
                end
            end
        end
        if executou then continue end

        -- 6. Venda
        if Library.Flags["AutoVenda"] then
            local bk = LocalPlayer:FindFirstChild("Backpack")
            if bk and #bk:GetChildren() >= (tonumber(Library.Flags["QtdVenda"]) or 100) then
                if Networking and Networking.NPCS then pcall(function() Networking.NPCS.SellAll:Fire() end) executou = true end
            end
        end
        if executou then continue end

        -- 7. Buy
        if Library.Flags["AutoBuyToggle"] then
            local targets = Library.Flags["SementesAlvo"]
            if type(targets) == "table" then
                for _, semente in ipairs(targets) do
                    if ComprarSemente(semente) then task.wait(0.5); executou = true; break end
                end
            end
        end
        if executou then continue end

        -- 8. Retorno
        if Library.Flags["AutoRetorno"] then
            local mP = Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local p = Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)
                if Char.Root() and (Char.Root().Position - p).Magnitude > 35 then Char.Teleportar(p) end
            end
        end

    end
end)

