local Plots = {}
local CachePlayersPorPlotId = {}

local function reconstruirCachePlayers()
    table.clear(CachePlayersPorPlotId)
    for _, p in ipairs(Players:GetPlayers()) do
        local pid = p:GetAttribute("PlotId")
        if pid then CachePlayersPorPlotId[tonumber(pid)] = p.Name end
    end
end
reconstruirCachePlayers()
Players.PlayerAdded:Connect(reconstruirCachePlayers)
Players.PlayerRemoving:Connect(reconstruirCachePlayers)
for _, p in ipairs(Players:GetPlayers()) do
    p.AttributeChanged:Connect(function(attr) if attr == "PlotId" then reconstruirCachePlayers() end end)
end

function Plots.DonoDoPlot(plot)
    if not plot then return nil end
    local plotNum = tonumber(string.match(plot.Name, "%d+"))
    return plotNum and CachePlayersPorPlotId[plotNum] or nil
end

function Plots.GetMeuPlot()
    local pid = LocalPlayer:GetAttribute("PlotId")
    if pid then return "Plot" .. tostring(pid) end
    return nil
end

function Plots.ListarParaDropdown()
    if not Gardens then return {} end
    local itens = {}
    for _, plot in ipairs(Gardens:GetChildren()) do
        if string.match(plot.Name, "^Plot%d+$") then
            local dono = Plots.DonoDoPlot(plot)
            if dono then 
                table.insert(itens, dono == LocalPlayer.Name and dono.." (meu plot)" or dono.." ("..plot.Name..")")
            else 
                table.insert(itens, "Sem Dono ("..plot.Name..")")
            end
        end
    end
    table.sort(itens)
    return itens
end

local function ReturnToMyPlot()
    local myPlotName = Plots.GetMeuPlot()
    if not myPlotName then return end
    local myPlot = Gardens:FindFirstChild(myPlotName)
    if not myPlot then return end
    
    local cframe = myPlot:GetPivot()
    local mRoot = GetRoot(LocalPlayer)
    if mRoot then
        mRoot.Anchored = false
        mRoot.AssemblyLinearVelocity = Vector3.zero
        mRoot.CFrame = cframe + Vector3.new(0, 5, 0) -- Exact center, stable CFrame placement
    end
end

------------------------------------------------------------------------
-- FLING & COMBAT
------------------------------------------------------------------------
local function FlingPlayer(targetPlayer)
    if State.Flinging or not targetPlayer then return end
    State.Flinging = true
    
    local mRoot = GetRoot(LocalPlayer)
    local mHum = GetHumanoid(LocalPlayer)
    
    if not mRoot then State.Flinging = false return end
    if mHum then mHum.PlatformStand = true end

    local startTick = tick()
    local connection
    
    -- Extreme physics & continuous teleportation
    connection = RunService.Heartbeat:Connect(function()
        local tRoot = GetRoot(targetPlayer)
        if tRoot then
            mRoot.CFrame = tRoot.CFrame + Vector3.new(0, 0.5, 0)
            mRoot.AssemblyLinearVelocity = Vector3.new(math.random(-50000, 50000), math.random(15000, 50000), math.random(-50000, 50000))
            pcall(function() sethiddenproperty(mRoot, "PhysicsRepRootPart", tRoot) end)
        end
    end)

    -- Fling for EXACTLY 5 seconds
    repeat task.wait(0.1) until tick() - startTick >= 5 or not GetRoot(targetPlayer)
    
    connection:Disconnect()
    pcall(function() sethiddenproperty(mRoot, "PhysicsRepRootPart", nil) end)
    
    mRoot.AssemblyLinearVelocity = Vector3.zero
    if mHum then mHum.PlatformStand = false end
    
    State.Flinging = false
end

------------------------------------------------------------------------
-- ADVANCED AUTO STEAL SYSTEM
------------------------------------------------------------------------
local function GetStealableFruits()
    local fruits = {}
    local myPlot = Plots.GetMeuPlot()
    
    for _, plot in ipairs(Gardens:GetChildren()) do
        if plot.Name == myPlot or not string.match(plot.Name, "^Plot%d+$") then continue end
        local plantsFolder = plot:FindFirstChild("Plants")
        if not plantsFolder then continue end
        
        for _, plant in ipairs(plantsFolder:GetChildren()) do
            local sp = plant:FindFirstChild("StealPrompt", true)
            if sp and sp.Enabled then
                local value = 0
                if FruitValueCalc then pcall(function() value = FruitValueCalc.CalculateValue(plant) or 0 end) end
                if value == 0 then
                    value = tonumber(plant:GetAttribute("Value")) or tonumber(plant:GetAttribute("Worth")) or tonumber(plant:GetAttribute("PlantValue")) or 0
                end
                
                -- Value-based filtering
                if value >= State.MinValue then
                    table.insert(fruits, {Prompt = sp, Value = value, Plot = plot})
                end
            end
        end
    end
    
    table.sort(fruits, function(a, b) return a.Value > b.Value end)
    return fruits
end

local function ExecuteAutoSteal()
    local fruits = GetStealableFruits()
    if #fruits == 0 then return end
    
    local targetData = fruits[1] -- Most valuable fruit
    local targetPlot = targetData.Plot
    local ownerName = Plots.DonoDoPlot(targetPlot)
    local ownerPlayer = ownerName and Players:FindFirstChild(ownerName)
    local ownerPos = ownerPlayer and GetPlayerCharacterPos(ownerName)
    
    -- Check if owner is in the plot
    if ownerPos and IsInPlotArea2D(targetPlot, ownerPos) then
        FlingPlayer(ownerPlayer)
    end
    
    -- Re-check fruits after potential 5s fling
    local updatedFruits = GetStealableFruits()
    local collectedAny = false
    
    for _, f in ipairs(updatedFruits) do
        if f.Plot == targetPlot then
            local success = Interact(f.Prompt)
            if success then collectedAny = true end
        end
    end
    
    if collectedAny then
        ReturnToMyPlot()
    end
end

