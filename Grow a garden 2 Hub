------------------------------------------------------------------------
-- LÓGICA DE HARVEST (novo — via Networking, sem ProximityPrompt)
------------------------------------------------------------------------
local function isGrown(plant)
    local maxAge     = plant:GetAttribute("MaxAge")
    local currentAge = plant:GetAttribute("Age")
    if not maxAge or not currentAge then return false end
    return currentAge >= maxAge
end

local function PerformHarvest()
    if not Networking or not Networking.Garden then return end
    local OwnerPlot = nil
    for _, plot in pairs(Gardens:GetChildren()) do
        if plot:GetAttribute("Owner") == LocalPlayer.Name then OwnerPlot = plot; break end
    end
    if not OwnerPlot then return end
    local plantsFolder = OwnerPlot:FindFirstChild("Plants")
    if not plantsFolder then return end

    for _, plant in ipairs(plantsFolder:GetChildren()) do
        if not plant:IsDescendantOf(Workspace) then continue end
        local plantId = plant:GetAttribute("PlantId")
        if not plantId then continue end

        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in ipairs(fruits:GetChildren()) do
                if not (fruit:IsA("Model") and isGrown(fruit)) then continue end
                local fruitId = fruit:GetAttribute("FruitId") or ""
                -- Dispara imediatamente, zero teleporte
                pcall(function() Networking.Garden.CollectFruit:Fire(plantId, fruitId) end)
                -- Aguarda ESTA fruta sumir antes de mandar a próxima
                local removed = false
                local conn = fruit.AncestryChanged:Connect(function(_, parent)
                    if not parent then removed = true end
                end)
                local t0 = tick()
                while not removed and tick() - t0 < 2 do task.wait(0.04) end
                conn:Disconnect()
            end
        elseif plant:IsA("Model") and isGrown(plant) then
            pcall(function() Networking.Garden.CollectFruit:Fire(plantId, "") end)
            -- Planta sem pasta Fruits: aguarda mudança de Age como confirmação
            local oldAge = plant:GetAttribute("Age")
            local t0 = tick()
            while plant:GetAttribute("Age") == oldAge and tick() - t0 < 2 do task.wait(0.04) end
        end
    end
end

------------------------------------------------------------------------
-- FLING PLAYER — Anti-steal ofensivo (sethiddenproperty de física)
------------------------------------------------------------------------
        local function FlingPlayer(TargetPlayer)
    local myChar     = LocalPlayer.Character
    local targetChar = TargetPlayer and TargetPlayer.Character
    if not myChar or not targetChar then return end

    local myRoot     = myChar:FindFirstChild("HumanoidRootPart")
    local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
    if not myRoot or not targetRoot then return end

    local myHuman = myChar:FindFirstChildOfClass("Humanoid")
    if myHuman then myHuman.PlatformStand = true end

    local StartTick = tick()
    repeat
        if not targetRoot.Parent then break end
        -- Coloca nosso root DENTRO do alvo (causa colisão física a alta velocidade)
        myRoot.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 0.5, 0))
        -- Velocidade massiva → motor de física transfere momentum para o alvo
        myRoot.AssemblyLinearVelocity = Vector3.new(
            math.random(-999, 999),
            math.random(500, 999),
            math.random(-999, 999)
        )
        -- PhysicsRepRootPart faz o servidor enxergar o root dentro do alvo
        pcall(function() sethiddenproperty(myRoot, "PhysicsRepRootPart", targetRoot) end)
        task.wait(0.05)
        pcall(function() sethiddenproperty(myRoot, "PhysicsRepRootPart", nil) end)
    until (tick() - StartTick > 2) or (not targetRoot.Parent)

    if myHuman then myHuman.PlatformStand = false end
    -- Retorna ao meu plot após o fling
    local mP = Plots.GetMeuPlot()
    if mP and Gardens:FindFirstChild(mP) then
        myRoot.CFrame = CFrame.new(Gardens[mP]:GetPivot().Position + Vector3.new(0, 5, 0))
    end
end

-- Varre TODOS os plots do servidor e retorna o StealPrompt da planta de maior valor
local function FindMostValuablePlant()
    local bestPrompt = nil
    local bestValue  = -1
    local meuP   = Plots.GetMeuPlot()
    local ignorar = Library.Flags["PlantsIgnorar"] or {}

    for _, plot in ipairs(Gardens:GetChildren()) do
        if not plot.Name:match("^Plot%d+$") then continue end
        if plot.Name == meuP then continue end
        local plantsFolder = plot:FindFirstChild("Plants")
        if not plantsFolder then continue end

        for _, plant in ipairs(plantsFolder:GetChildren()) do
            local sName = plant:GetAttribute("SeedName")
            if sName and table.find(ignorar, sName) then continue end
            local sp = plant:FindFirstChild("StealPrompt", true)
            if not sp or not sp.Enabled then continue end

            local value = 0
            if FruitValueCalc then
                pcall(function() value = FruitValueCalc.CalculateValue(plant) or 0 end)
            end
            -- Fallback: tenta atributos comuns de valor
            if value == 0 then
                value = tonumber(plant:GetAttribute("Value"))
                   or tonumber(plant:GetAttribute("Worth"))
                   or tonumber(plant:GetAttribute("PlantValue"))
                   or 0
            end
            if value > bestValue then
                bestValue  = value
                bestPrompt = sp
            end
        end
    end
    return bestPrompt
end
