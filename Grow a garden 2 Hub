local Char = {}

function Char.Root()
    local character = LocalPlayer.Character
    return character and character:FindFirstChild("HumanoidRootPart")
end

function Char.Teleportar(posicao)
    local root = Char.Root()
    if not root then return end

    root.Anchored = false
    root.AssemblyLinearVelocity  = Vector3.zero
    root.AssemblyAngularVelocity = Vector3.zero

    root.CFrame = CFrame.new(posicao)
end

function Char.TeleportarParaPrompt(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end

    local parentPart = prompt.Parent
    if parentPart and parentPart:IsA("BasePart") then
        Char.Teleportar(parentPart.Position + Vector3.new(0, 1.5, 0))
        return true
    end

    local model = prompt:FindFirstAncestorOfClass("Model")
    if model then
        local pPart = model.PrimaryPart
        if not pPart then
            pPart = model:FindFirstChildWhichIsA("BasePart", true)
        end
        if pPart then
            Char.Teleportar(pPart.Position + Vector3.new(0, 1.5, 0))
            return true
        end
    end

    local cursor = prompt.Parent
    while cursor and cursor ~= Workspace do
        if cursor:IsA("BasePart") then
            Char.Teleportar(cursor.Position + Vector3.new(0, 1.5, 0))
            return true
        end
        cursor = cursor.Parent
    end

    return false
end

function Char.AncorarRaiz(estado)
    local root = Char.Root()
    if root then root.Anchored = estado end
end

