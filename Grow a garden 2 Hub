------------------------------------------------------------------------
-- LÓGICA DE HARVEST
------------------------------------------------------------------------
local function isGrown(plant)
    local maxAge     = plant:GetAttribute("MaxAge")
    local currentAge = plant:GetAttribute("Age")
    if not maxAge or not currentAge then return false end
    return currentAge >= maxAge
end

local function PerformHarvest()
    local OwnerPlot = nil
    for _, plot in pairs(Gardens:GetChildren()) do
        if plot:GetAttribute("Owner") == LocalPlayer.Name then
            OwnerPlot = plot; break
        end
    end
    if not OwnerPlot then return end

    local plantsFolder = OwnerPlot:FindFirstChild("Plants")
    if not plantsFolder then return end

    for _, plant in pairs(plantsFolder:GetChildren()) do
        local fruits = plant:FindFirstChild("Fruits")
        if fruits then
            for _, fruit in pairs(fruits:GetChildren()) do
                if fruit:IsA("Model") and isGrown(fruit) then
                    pcall(function()
                        Networking.Garden.CollectFruit:Fire(
                            plant:GetAttribute("PlantId"),
                            fruit:GetAttribute("FruitId") or ""
                        )
                    end)
                end
            end
        elseif plant:IsA("Model") and isGrown(plant) then
            pcall(function()
                Networking.Garden.CollectFruit:Fire(plant:GetAttribute("PlantId"), "")
            end)
        end
    end
end

------------------------------------------------------------------------
-- FLING PLAYER — Anti-steal ofensivo
------------------------------------------------------------------------
local function FlingPlayer(TargetPlayer)
    local Root       = GetRoot(LocalPlayer)
    local TargetRoot = GetRoot(TargetPlayer)
    if not Root or not TargetRoot then return end

    local StartTick = tick()
    repeat
        task.wait()
        pcall(function() sethiddenproperty(Root, "PhysicsRepRootPart", TargetRoot) end)
        Root.CFrame = CFrame.new(TargetRoot.Position) * CFrame.Angles(math.random(0, 360), 0, 0)
    until (tick() - StartTick > 2) or (not TargetRoot.Parent)
    pcall(function() sethiddenproperty(Root, "PhysicsRepRootPart", nil) end)
end

