local function configurarPlanta(modelo, invisivel)
    for _, parte in ipairs(modelo:GetDescendants()) do
        if parte:IsA("BasePart") then parte.Transparency = invisivel and 1 or 0; parte.CanCollide = not invisivel end
    end
end
local function toggleInvisPlants(ativo)
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if not plotId then return end
    local meuPlot = Gardens:FindFirstChild("Plot" .. tostring(plotId))
    if not meuPlot then return end
    local pastaPlants = meuPlot:FindFirstChild("Plants")
    if pastaPlants then for _, plantaModelo in ipairs(pastaPlants:GetChildren()) do configurarPlanta(plantaModelo, ativo) end end
end

