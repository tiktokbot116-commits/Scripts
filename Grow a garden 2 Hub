local function ComprarSemente(nome)
    local ok = false
    pcall(function()
        local items = ReplicatedStorage:FindFirstChild("StockValues") and ReplicatedStorage.StockValues:FindFirstChild("SeedShop") and ReplicatedStorage.StockValues.SeedShop:FindFirstChild("Items")
        if not items then return end
        local item = items:FindFirstChild(nome)
        if not item or item.Value <= 0 then return end
        
        if Networking and Networking.SeedShop then 
            Networking.SeedShop.PurchaseSeed:Fire(nome); ok = true 
        end
    end)
    return ok
end

------------------------------------------------------------------------
-- INTERAÇÃO COM MUTEX + TIMEOUT
------------------------------------------------------------------------
local function ExecutarInteracao(prompt)
    if IsFlinging then return false end
    if IsPerformingAction and tick()-ActionTimestamp < 3 then return false end
    IsPerformingAction = true; ActionTimestamp = tick()
    
    local ok = false
    pcall(function()
        Char.AncorarRaiz(true)
        if Char.TeleportarParaPrompt(prompt) then
            task.wait(0.12)
            if prompt and prompt:IsDescendantOf(Workspace) and prompt.Enabled then
                AtivarPrompt(prompt); task.wait(0.18); ok = true
            end
        end
    end)
    Char.AncorarRaiz(false); IsPerformingAction = false
    return ok
end

------------------------------------------------------------------------
-- BUSCA DE PLANTAS ROUBÁVEIS
------------------------------------------------------------------------
local function GetStealablePlants()
    local plants = {}
    if not Gardens then return plants end
    
    local meuP = Plots.GetMeuPlot()
    local ignorar = (Library and Library.Flags["PlantsIgnorar"]) or {}
    
    for _, plot in ipairs(Gardens:GetChildren()) do
        if plot.Name == meuP or not plot.Name:match("^Plot%d+$") then continue end
        if not Plots.DonoDoPlot(plot) then continue end
        
        local pf = plot:FindFirstChild("Plants");
        if not pf then continue end
        
        for _, plant in ipairs(pf:GetChildren()) do
            local sn = plant:GetAttribute("SeedName")
            if sn and table.find(ignorar, sn) then continue end
            
            local sp = plant:FindFirstChild("StealPrompt", true)
            if not sp or not sp.Enabled then continue end
            
            local v = 0
            if FruitValueCalc then
                pcall(function() v = FruitValueCalc.CalculateValue(plant) or 0 end)
            end
            
            if v == 0 then
                v = tonumber(plant:GetAttribute("Value")) or tonumber(plant:GetAttribute("Worth")) or tonumber(plant:GetAttribute("PlantValue")) or 0
            end
            
            table.insert(plants, {Prompt=sp, Value=v, Plot=plot})
        end
    end
    
    table.sort(plants, function(a,b) return (a.Value or 0) > (b.Value or 0) end)
    return plants
end

