            if pid and Gardens:FindFirstChild("Plot" .. tostring(pid)) and obj:IsDescendantOf(Gardens:FindFirstChild("Plot" .. tostring(pid))) then
                if obj:FindFirstAncestor("Plants") then configurarPlanta(obj.Parent, true) end
            end
        end)
