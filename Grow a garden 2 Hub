-- HARVEST
------------------------------------------------------------------------
local function isGrown(plant)
    local mx = plant:GetAttribute("MaxAge");
    local ag = plant:GetAttribute("Age")
    return mx and ag and ag >= mx
end

local function PerformHarvest()
    if HarvestRunning or not Networking or not Networking.Garden then return end
    HarvestRunning = true
    
    pcall(function()
        -- CORREÇÃO: Busca do plot padronizada usando a mesma lógica de Plots.GetMeuPlot()
        local meuP = Plots.GetMeuPlot()
        local ownPlot = meuP and Gardens:FindFirstChild(meuP)
        
        if not ownPlot then return end
        
        local pf = ownPlot:FindFirstChild("Plants");
        if not pf then return end
        
        for _, plant in ipairs(pf:GetChildren()) do
            if not plant:IsDescendantOf(Workspace) then continue end
            local pid = plant:GetAttribute("PlantId");
            if not pid then continue end
            
            local fruits = plant:FindFirstChild("Fruits")
            if fruits then
                for _, fruit in ipairs(fruits:GetChildren()) do
                    if not (fruit:IsA("Model") and isGrown(fruit)) then continue end
                    local fid = fruit:GetAttribute("FruitId") or ""
                    
                    pcall(function() Networking.Garden.CollectFruit:Fire(pid, fid) end)
                    
                    local gone = false
                    local conn = fruit.AncestryChanged:Connect(function(_, p)
                        if not p then gone = true end
                    end)
                    
                    local t0 = tick()
                    while not gone and tick()-t0 < 1.5 do task.wait(0.05) end
                    conn:Disconnect()
                end
            elseif plant:IsA("Model") and isGrown(plant) then
                local oldAge = plant:GetAttribute("Age")
                pcall(function() Networking.Garden.CollectFruit:Fire(pid, "") end)
                
                local t0 = tick()
                while plant:GetAttribute("Age") == oldAge and tick()-t0 < 1.5 do task.wait(0.05) end
            end
        end
    end)
    HarvestRunning = false
end

------------------------------------------------------------------------
-- FLING
------------------------------------------------------------------------
local function FlingPlayer(target)
    if IsFlinging then return end
    IsFlinging = true
    
    local mc = LocalPlayer.Character
    local tc = target and target.Character
    if not mc or not tc then 
        IsFlinging = false
        return 
    end
    
    local mr = mc:FindFirstChild("HumanoidRootPart")
    local tr = tc:FindFirstChild("HumanoidRootPart")
    local mh = mc:FindFirstChildOfClass("Humanoid")
    
    if not mr or not tr then 
        IsFlinging = false
        return 
    end

    -- CORREÇÃO CRÍTICA: Garantir limpeza de PlatformStand e Anchored mesmo se houver erro
    local success = pcall(function()
        if mh then mh.PlatformStand = true end
        mr.Anchored = false -- Garante que a física do Fling vai funcionar
        
        local t0 = tick()
        repeat
            if not tr.Parent then break end
            mr.CFrame = CFrame.new(tr.Position + Vector3.new(0, 0.5, 0))
            mr.AssemblyLinearVelocity = Vector3.new(
                math.random(-400, 400),
                math.random(200, 500),
                math.random(-400, 400)
            )
            pcall(function() sethiddenproperty(mr, "PhysicsRepRootPart", tr) end)
            task.wait(0.06)
            pcall(function() sethiddenproperty(mr, "PhysicsRepRootPart", nil) end)
        until tick()-t0 > 2 or not tr.Parent
    end)

    -- Cleanup Garantido
    if mh then mh.PlatformStand = false end
    pcall(function() mr.AssemblyLinearVelocity = Vector3.zero end)
    
    local mP = Plots.GetMeuPlot()
    if mP and Gardens:FindFirstChild(mP) then
        pcall(function()
            mr.CFrame = CFrame.new(Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0))
        end)
    end
    
    IsFlinging = false
end

