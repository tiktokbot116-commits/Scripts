GM.ExecutarInteracao = function(prompt)
    if GM.IsPerformingAction then return false end
    GM.IsPerformingAction = true
    
    local sucesso = false
    pcall(function()
        GM.Char.AncorarRaiz(true)
        if GM.Char.TeleportarParaPrompt(prompt) then
            task.wait(0.12)
            if prompt and prompt:IsDescendantOf(Workspace) and prompt.Enabled then
                GM.Prompt.AtivarImediato(prompt)
                task.wait(0.18)
                sucesso = true
            end
        end
    end)
    
    GM.Char.AncorarRaiz(false)
    GM.IsPerformingAction = false
    return sucesso
end

