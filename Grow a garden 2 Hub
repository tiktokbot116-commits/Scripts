local DropPlots = TabSteal:AddDropdown("PlotAlvo", "Selecionar Alvo Unico", {"Carregando..."}, false)
TabSteal:AddToggle("AutoRoubo", "Steal Alvo Especifico", false)

TabSteal:AddButton("Atualizar Lista de Plots", function()
    local lista = {}
    for _, plot in ipairs(Gardens:GetChildren()) do
        local pName = plot.Name
        local ownerId = plot:GetAttribute("OwnerUserId")
        local ownerPlayer = ownerId and Players:GetPlayerByUserId(ownerId)
        if ownerPlayer and ownerPlayer ~= LocalPlayer then
            table.insert(lista, ownerPlayer.Name .. " ("..pName..")")
        end
    end
    DropPlots:SetValues(lista)
end)

