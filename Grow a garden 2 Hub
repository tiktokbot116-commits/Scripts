GM.Char = {}
GM.Char.Root = function() return LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") end
GM.Char.Teleportar = function(posicao)
    local root = GM.Char.Root()
    if root then
        root.Anchored = false
        root.AssemblyLinearVelocity = Vector3.zero
        root.CFrame = CFrame.new(posicao)
    end
end
GM.Char.TeleportarParaPrompt = function(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    local parentPart = prompt.Parent
    if parentPart and parentPart:IsA("BasePart") then GM.Char.Teleportar(parentPart.Position + Vector3.new(0, 2, 0)); return true end
    local model = prompt:FindFirstAncestorOfClass("Model")
    if model then
        local pPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
        if pPart then GM.Char.Teleportar(pPart.Position + Vector3.new(0, 2, 0)); return true end
    end
    return false
end
GM.Char.AncorarRaiz = function(estado)
    local root = GM.Char.Root()
    if root then root.Anchored = estado end
end

