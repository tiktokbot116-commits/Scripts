-- Novo Sistema de Busca: Encontra todas as plantas roubáveis no servidor
local function GetStealablePlants()
    local plants = {}
    local meuP = Plots.GetMeuPlot()
    local ignorar = Library.Flags["PlantsIgnorar"] or {}
    
    for _, plot in ipairs(Gardens:GetChildren()) do
        if plot.Name == meuP or not string.match(plot.Name, "^Plot%d+$") then continue end
        local plantsFolder = plot:FindFirstChild("Plants")
        if not plantsFolder then continue end
        
        for _, plant in ipairs(plantsFolder:GetChildren()) do
            local sName = plant:GetAttribute("SeedName")
            if sName and table.find(ignorar, sName) then continue end
            local sp = plant:FindFirstChild("StealPrompt", true)
            if sp and sp.Enabled then
                local value = 0
                if FruitValueCalc then pcall(function() value = FruitValueCalc.CalculateValue(plant) or 0 end) end
                if value == 0 then
                    value = tonumber(plant:GetAttribute("Value")) or tonumber(plant:GetAttribute("Worth")) or tonumber(plant:GetAttribute("PlantValue")) or 0
                end
                table.insert(plants, {Prompt = sp, Value = value, Plot = plot})
            end
        end
    end
    -- Ordena da mais cara para a mais barata
    table.sort(plants, function(a, b) return a.Value > b.Value end)
    return plants
end

