function ConfigSystem.Listar()
    local lista = {}
    if listfiles and isfolder and isfolder(ConfigSystem.Pasta) then
        pcall(function()
            for _, f in ipairs(listfiles(ConfigSystem.Pasta)) do
                local n = string.match(f, "([^/\\]+)%.json$")
                if n then
                    table.insert(lista, n)
                end
            end
        end)
    end
    if #lista == 0 then table.insert(lista, "Nenhuma config") end
    return lista
