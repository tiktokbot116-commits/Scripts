------------------------------------------------------------------------
-- CORE FUNCTIONS & UTILITIES
------------------------------------------------------------------------
local function GetHumanoid(player)
    local char = player and player.Character
    return char and char:FindFirstChildOfClass("Humanoid")
end

local function GetRoot(player)
    local hum = GetHumanoid(player)
    return hum and hum.RootPart
end

local function GetPlayerCharacterPos(playerName)
    local p = Players:FindFirstChild(playerName)
    local root = GetRoot(p)
    return root and root.Position or nil
end

local function IsInPlotArea2D(model, targetPos)
    if not model or not targetPos then return false end
    local cf, size = model:GetBoundingBox()
    local localPos = cf:PointToObjectSpace(targetPos)
    return math.abs(localPos.X) <= (size.X / 2) + 2 and math.abs(localPos.Z) <= (size.Z / 2) + 2
end

local function Interact(prompt)
    if not prompt or not prompt:IsDescendantOf(Workspace) then return false end
    if not prompt.Enabled then return false end

    local model = prompt:FindFirstAncestorOfClass("Model")
    local parentPart = prompt.Parent:IsA("BasePart") and prompt.Parent or nil
    if not parentPart and model then
        parentPart = model.PrimaryPart or model:FindFirstChildWhichIsA("BasePart", true)
    end

    local mRoot = GetRoot(LocalPlayer)
    if not mRoot or not parentPart then return false end

    mRoot.Anchored = true
    mRoot.CFrame = CFrame.new(parentPart.Position + Vector3.new(0, 3, 0))
    task.wait(0.2) -- Anti-spam safety

    pcall(function() 
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 999999
        prompt.Exclusivity = Enum.ProximityPromptExclusivity.AlwaysShow
    end)

    if fireproximityprompt then 
        fireproximityprompt(prompt, 1, true)
    else
        pcall(function() prompt.HoldDuration = 0; prompt:InputHoldBegin(); prompt:InputHoldEnd() end)
        if VirtualInputManager then
            pcall(function()
                VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
                task.wait(0.01)
                VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
            end)
        end
    end

    task.wait(0.3)
    mRoot.Anchored = false
    return true
end

