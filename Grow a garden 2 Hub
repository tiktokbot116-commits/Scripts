-- LOOP PRINCIPAL TOTALMENTE REFATORADO
task.spawn(function()
    while task.wait(0.1) do
        local isNight = (Workspace:GetAttribute("ActivePhase") == "Night")

        -- Evita agir enquanto o player estiver sendo lançado (fling)
        if IsFlinging then continue end

        -- 1. FUGA DE EMERGÊNCIA (Defesa do próprio roubo ou ataque)
        if (Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"]) then
            local pPos = Char.Root() and Char.Root().Position
            if pPos then
                local currentPlot = nil
                for i=1, 8 do
                    local pModel = Gardens:FindFirstChild("Plot"..i)
                    if pModel and IsInPlotArea2D(pModel, pPos) then currentPlot = pModel; break end
                end

                if currentPlot and currentPlot.Name ~= Plots.GetMeuPlot() then
                    if not isNight then
                        IsPerformingAction = false
                        local mP = Plots.GetMeuPlot()
                        if mP and Gardens:FindFirstChild(mP) then Char.Teleportar(Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)) end
                        task.wait(1)
                        continue
                    else
                        -- Fling imediato se o dono aparecer no plot que você está roubando
                        local dName = Plots.DonoDoPlot(currentPlot)
                        local dPos  = GetPlayerCharacterPos(dName)
                        if dPos and IsInPlotArea2D(currentPlot, dPos) then
                            local donoPlayer = Players:FindFirstChild(dName)
                            if donoPlayer then task.spawn(function() FlingPlayer(donoPlayer) end) end
                        end
                    end
                end
            end
        end

        if IsPerformingAction then continue end
        local executou = false

        -- 2. COLETA PRÓPRIA (Passiva pela Rede)
        if Library.Flags["AutoColeta"] then
            task.spawn(PerformHarvest)
        end

        -- 3. ITENS SOLTOS
        if Library.Flags["AutoCollectAll"] and DroppedItems then
            for _, i in ipairs(DroppedItems:GetDescendants()) do
                if i:IsA("ProximityPrompt") and i.Enabled then
                    if ExecutarInteracao(i) then executou = true; break end
                end
            end
        end
        if executou then continue end

        -- 4. SEMENTES NO MAPA
        if Library.Flags["AutoSeedMap"] then
            local sf = Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("SeedPackSpawnServerLocations")
            if sf then
                for _, i in ipairs(sf:GetDescendants()) do
                    if i:IsA("ProximityPrompt") and i.Enabled then
                        if ExecutarInteracao(i) then executou = true; break end
                    end
                end
            end
        end
        if executou then continue end

        -- 5. NOVO SISTEMA INTELIGENTE DE ROUBO
        if isNight and (Library.Flags["AutoStealAll"] or Library.Flags["AutoRoubo"]) then
            if Library.Flags["AutoStealAll"] then
                local listaPlantas = GetStealablePlants()
                for _, data in ipairs(listaPlantas) do
                    local donoName = Plots.DonoDoPlot(data.Plot)
                    local dPos = GetPlayerCharacterPos(donoName)
                    
                    -- Se dono está no plot, usa Fling antes de roubar a dele
                    if dPos and IsInPlotArea2D(data.Plot, dPos) then
                        local donoPlayer = Players:FindFirstChild(donoName)
                        if donoPlayer then task.spawn(function() FlingPlayer(donoPlayer) end) end
                    end
                    
                    if ExecutarInteracao(data.Prompt) then executou = true; break end
                end

            elseif Library.Flags["AutoRoubo"] and Library.Flags["PlotAlvo"] ~= "" then
                local realName = string.match(Library.Flags["PlotAlvo"], "%((Plot%d+)%)")
                local alvo = realName and Gardens:FindFirstChild(realName)
                if alvo then
                    local donoName = Plots.DonoDoPlot(alvo)
                    local dPos = GetPlayerCharacterPos(donoName)
                    if dPos and IsInPlotArea2D(alvo, dPos) then
                        local donoPlayer = Players:FindFirstChild(donoName)
                        if donoPlayer then task.spawn(function() FlingPlayer(donoPlayer) end) end
                    end

                    local plantsFolder = alvo:FindFirstChild("Plants")
                    if plantsFolder then
                        local ignorar = Library.Flags["PlantsIgnorar"] or {}
                        for _, plant in ipairs(plantsFolder:GetChildren()) do
                            local sName = plant:GetAttribute("SeedName")
                            if sName and table.find(ignorar, sName) then continue end
                            local p = plant:FindFirstChild("StealPrompt", true)
                            if p and p.Enabled then
                                if ExecutarInteracao(p) then executou = true; break end
                            end
                        end
                    end
                end
            end
        end
        if executou then continue end

        -- 6. VENDA
        if Library.Flags["AutoVenda"] then
            local bk = LocalPlayer:FindFirstChild("Backpack")
            if bk and #bk:GetChildren() >= (tonumber(Library.Flags["QtdVenda"]) or 100) then
                if Networking and Networking.NPCS then 
                    pcall(function() Networking.NPCS.SellAll:Fire() end) 
                    task.wait(0.5) 
                    executou = true 
                end
            end
        end
        if executou then continue end

        -- 7. COMPRA (Estoque contínuo)
        if Library.Flags["AutoBuyToggle"] then
            local targets = Library.Flags["SementesAlvo"]
            if type(targets) == "table" then
                for _, semente in ipairs(targets) do
                    if ComprarSemente(semente) then task.wait(0.2); break end
                end
            end
        end

        -- 8. RETORNO OCIOSO
        if Library.Flags["AutoRetorno"] then
            local mP = Plots.GetMeuPlot()
            if mP and Gardens:FindFirstChild(mP) then
                local p = Gardens[mP]:GetPivot().Position + Vector3.new(0,5,0)
                if Char.Root() and (Char.Root().Position - p).Magnitude > 35 then Char.Teleportar(p) end
            end
        end
    end
end)
