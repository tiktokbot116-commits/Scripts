-------------------------------------------------------------------------
-- FUNÇÕES DE EFEITOS GERAIS
-------------------------------------------------------------------------
local function CreatePart(shape, mat, col, size, cf, t)
	local p = Instance.new("Part")
	p.Shape = shape; p.Material = mat; p.Color = col; p.Size = size; p.CFrame = cf; p.Transparency = t
	p.Anchored = true; p.CanCollide = false; p.Parent = workspace
	return p
end

local function TweenOut(part, duration, endSize)
	TweenService:Create(part, TweenInfo.new(duration, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out), {Size = endSize, Transparency = 1}):Play()
	Debris:AddItem(part, duration)
end

-------------------------------------------------------------------------
-- ANIMAÇÃO CUSTOMIZADA
-------------------------------------------------------------------------
local function GetMotor6D(character, poseName)
	local Torso = character:FindFirstChild("Torso")
	local HRP = character:FindFirstChild("HumanoidRootPart")
	if not Torso then return nil end
	if poseName == "Right Arm" then return Torso:FindFirstChild("Right Shoulder") end
	if poseName == "Left Arm" then return Torso:FindFirstChild("Left Shoulder") end
	if poseName == "Right Leg" then return Torso:FindFirstChild("Right Hip") end
	if poseName == "Left Leg" then return Torso:FindFirstChild("Left Hip") end
	if poseName == "Torso" then return HRP and HRP:FindFirstChild("RootJoint") end
	if poseName == "Head" then return Torso:FindFirstChild("Neck") end
	return Torso:FindFirstChild(poseName)
end

local function playCustomAnimation(character)
	local success, content = pcall(function() return readfile("AnimationsBackups/Granite Blast.json") end)
	if not success then return end
	local AnimData = HttpService:JSONDecode(content)
	local originalJoints = {}
	local partesR6 = {"Right Arm", "Left Arm", "Right Leg", "Left Leg", "Torso", "Head"}
	for _, poseName in ipairs(partesR6) do
		local joint = GetMotor6D(character, poseName)
		if joint and joint:IsA("Motor6D") then originalJoints[poseName] = joint.C0 end
	end
	task.spawn(function()
		local prevTime = 0
		for _, keyframe in ipairs(AnimData.Keyframes) do
			local currentTime = keyframe.Time or (prevTime + 0.05)
			local stepDuration = (currentTime - prevTime) / ANIMATION_SPEED
			if stepDuration <= 0.01 then stepDuration = 0.01 end
			for _, pose in ipairs(keyframe.Poses) do
				local joint = GetMotor6D(character, pose.Name)
				if joint and originalJoints[pose.Name] then
					TweenService:Create(joint, TweenInfo.new(stepDuration, Enum.EasingStyle.Linear), {C0 = originalJoints[pose.Name] * CFrame.new(unpack(pose.CFrame))}):Play()
				end
			end
			task.wait(stepDuration)
			prevTime = currentTime
		end
		task.wait(BEAM_DURATION) 
		for poseName, originalC0 in pairs(originalJoints) do
			local joint = GetMotor6D(character, poseName)
			if joint then TweenService:Create(joint, TweenInfo.new(0.5), {C0 = originalC0}):Play() end
		end
	end)
end

