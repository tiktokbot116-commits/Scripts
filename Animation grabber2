local Tabs = {}
local function createTab(name, posIdx)
    local TabBtn = createButton(SideBar, name, UDim2.new(0, 5, 0, 5 + (posIdx * 35)), UDim2.new(1, -10, 0, 30), Color3.fromRGB(45, 45, 45))
    local Frame = Instance.new("Frame", TabContainer)
    Frame.Size = UDim2.new(1, 0, 1, 0); Frame.BackgroundTransparency = 1; Frame.Visible = false
    
    TabBtn.MouseButton1Click:Connect(function()
        for _, t in pairs(Tabs) do t.Frame.Visible = false; t.Btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45) end
        Frame.Visible = true; TabBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    end)
    table.insert(Tabs, {Frame = Frame, Btn = TabBtn})
    return Frame
end

