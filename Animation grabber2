local function PlayAnim(id)
    local char = Player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if hum then
        local anim = Instance.new("Animation")
        anim.AnimationId = "rbxassetid://" .. id
        local track = hum:LoadAnimation(anim)
        track:Play()
    end
end

-- ================= ATUALIZAR BIBLIOTECA =================
local function AtualizarBiblioteca()
    for _, child in pairs(RightPanel:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    
    Selecionadas = {} -- Limpa seleções ao atualizar
    
    local yPosLib = 5
    for index, data in ipairs(Biblioteca) do
        local libItem = Instance.new("Frame", RightPanel)
        libItem.Size = UDim2.new(0.95, 0, 0, 45)
        libItem.Position = UDim2.new(0.025, 0, 0, yPosLib)
        libItem.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        
        local lbl = Instance.new("TextLabel", libItem)
        lbl.Size = UDim2.new(0.55, 0, 1, 0)
        lbl.BackgroundTransparency = 1
        lbl.Text = data.Name .. "\n(" .. data.ID .. ")"
        lbl.TextColor3 = Color3.fromRGB(200, 200, 200)
        lbl.TextScaled = true
        
        local playBtn = Instance.new("TextButton", libItem)
        playBtn.Size = UDim2.new(0.2, 0, 0.8, 0)
        playBtn.Position = UDim2.new(0.58, 0, 0.1, 0)
        playBtn.Text = "▶"
        playBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        playBtn.MouseButton1Click:Connect(function() PlayAnim(data.ID) end)
        
        local selBtn = Instance.new("TextButton", libItem)
        selBtn.Size = UDim2.new(0.2, 0, 0.8, 0)
        selBtn.Position = UDim2.new(0.79, 0, 0.1, 0)
        selBtn.Text = "Sel"
        selBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
        
        local isSelected = false
        selBtn.MouseButton1Click:Connect(function()
            isSelected = not isSelected
            if isSelected then
                selBtn.BackgroundColor3 = Color3.fromRGB(255, 170, 0)
                table.insert(Selecionadas, data)
            else
                selBtn.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
                for i, v in ipairs(Selecionadas) do
                    if v.ID == data.ID then
                        table.remove(Selecionadas, i)
                        break
                    end
                end
            end
        end)
        
        yPosLib = yPosLib + 50
    end
    RightPanel.CanvasSize = UDim2.new(0, 0, 0, yPosLib)
end

