-- SISTEMA CORE: CAPTURAR, SALVAR E REPRODUZIR
-- =======================================================================
local function updateSeqText()
    local t1 = selected1 and selected1.Name or "Nenhuma"
    local t2 = selected2 and selected2.Name or "Nenhuma"
    SeqInfo.Text = "Selecione duas animações na Biblioteca\n\nAnim 1: " .. t1 .. "\nAnim 2: " .. t2
end

local function refreshLibrary()
    for _, v in pairs(LibScroll:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
    LibScroll.CanvasSize = UDim2.new(0, 0, 0, #SavedAnims * 35)
    
    for _, anim in pairs(SavedAnims) do
        local btn = createButton(LibScroll, anim.Name, UDim2.new(0,0,0,0), UDim2.new(1, 0, 0, 30), Color3.fromRGB(50, 50, 50))
        btn.MouseButton1Click:Connect(function()
            if not selected1 then selected1 = anim; btn.BackgroundColor3 = Color3.fromRGB(200, 100, 0)
            elseif not selected2 then selected2 = anim; btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
            end
            updateSeqText()
        end)
    end
end

