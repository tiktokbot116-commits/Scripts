PlaySeqBtn.MouseButton1Click:Connect(function()
    if not selected1 or not selected2 then return end
    local char = LocalPlayer.Character
    local animator = char and char:FindFirstChild("Humanoid") and char.Humanoid:FindFirstChild("Animator")
    if not animator then return end
    
    local a1 = Instance.new("Animation"); a1.AnimationId = selected1.ID
    local a2 = Instance.new("Animation"); a2.AnimationId = selected2.ID
    
    local t1 = animator:LoadAnimation(a1)
    local t2 = animator:LoadAnimation(a2)
    
    t1:Play()
    t1.Stopped:Connect(function()
        t2:Play()
    end)
end)
