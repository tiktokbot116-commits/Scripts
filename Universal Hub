end

local function CreateDropdown(parent, text, options, callback)
    local DropFrame = create("Frame", { Parent = parent, Size = UDim2.new(1, 0, 0, 35), BackgroundColor3 = Color3.fromRGB(35, 35, 40), ClipsDescendants = true })
    create("UICorner", { Parent = DropFrame, CornerRadius = UDim.new(0, 6) })
    local MainBtn = create("TextButton", { Parent = DropFrame, Size = UDim2.new(1, 0, 0, 35), BackgroundTransparency = 1, Text = "  " .. text, TextColor3 = Color3.fromRGB(255, 255, 255), Font = Enum.Font.Gotham, TextSize = 14, TextXAlignment = Enum.TextXAlignment.Left })
    local ListFrame = create("ScrollingFrame", { Parent = DropFrame, Size = UDim2.new(1, 0, 1, -35), Position = UDim2.new(0, 0, 0, 35), BackgroundTransparency = 1, ScrollBarThickness = 2, CanvasSize = UDim2.new(0,0,0, #options * 30) })
    local ListLayout = create("UIListLayout", { Parent = ListFrame })
    
    local open = false
    MainBtn.MouseButton1Click:Connect(function()
        open = not open
        TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = open and UDim2.new(1, 0, 0, 35 + math.clamp(#options * 30, 0, 150)) or UDim2.new(1, 0, 0, 35)}):Play()
    end)
    
    local function populate(opts)
        for _, child in pairs(ListFrame:GetChildren()) do if child:IsA("TextButton") then child:Destroy() end end
        ListFrame.CanvasSize = UDim2.new(0,0,0, #opts * 30)
        for _, opt in pairs(opts) do
            local OptBtn = create("TextButton", { Parent = ListFrame, Size = UDim2.new(1, 0, 0, 30), BackgroundTransparency = 1, Text = "  " .. opt, TextColor3 = Color3.fromRGB(200, 200, 200), Font = Enum.Font.Gotham, TextSize = 12, TextXAlignment = Enum.TextXAlignment.Left })
            OptBtn.MouseButton1Click:Connect(function() MainBtn.Text = "  " .. text .. ": " .. opt; open = false; TweenService:Create(DropFrame, TweenInfo.new(0.2), {Size = UDim2.new(1, 0, 0, 35)}):Play(); callback(opt) end)
        end
    end
    populate(options)
    return populate
end

