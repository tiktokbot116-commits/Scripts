-- BOTÃO DE MINIMIZAR (50x50, Flutuante e Arrastável)
local MinimizeBtn = create("TextButton", {
    Parent = HubUI, Size = UDim2.new(0, 50, 0, 50),
    Position = UDim2.new(0, 20, 0, 20), BackgroundColor3 = Color3.fromRGB(30, 30, 35),
    Text = "-", TextColor3 = Color3.fromRGB(255, 255, 255),
