            CreateRow(0, "Speed", "WalkSpeed")
            CreateRow(0.16, "Jump Height", "JumpHeight")
            CreateCustomRow(0.32, "Fly Speed", function(val) if val then _G.FlySpeed = val end end)
            CreateToggle(0.48, "Fly", function(s) 
                _G.Fly = s 
                if not s and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    if Player.Character.HumanoidRootPart:FindFirstChild("FlyBV") then Player.Character.HumanoidRootPart.FlyBV:Destroy() end
                    if Player.Character.HumanoidRootPart:FindFirstChild("FlyBG") then Player.Character.HumanoidRootPart.FlyBG:Destroy() end
                end
            end)
            CreateToggle(0.64, "Noclip", function(s) _G.NC = s end)
            CreateToggle(0.80, "Anti-Lag Supremo", function(s) if s then ActivateAntiLag() end end)
        elseif name == "Visual" then
            CreateToggle(0, "Max Bright", function(s) Lighting.Brightness = s and 5 or 2 end)
            CreateToggle(0.18, "ESP Vermelho (Quadrado + Highlight)", function(s) ToggleESP(s) end)
        end
    end)
end

-- 6. LOOPS (FLY/NOCLIP)
RunService.Stepped:Connect(function()
    if _G.NC and Player.Character then for _,p in pairs(Player.Character:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end end
    if _G.Fly and Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
        local hrp, hum, cam = Player.Character.HumanoidRootPart, Player.Character:FindFirstChild("Humanoid"), workspace.CurrentCamera
        local bg = hrp:FindFirstChild("FlyBG") or Instance.new("BodyGyro", hrp); bg.Name = "FlyBG"; bg.P = 90000; bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); bg.CFrame = CFrame.new(hrp.Position, hrp.Position + cam.CFrame.LookVector)
        local bv = hrp:FindFirstChild("FlyBV") or Instance.new("BodyVelocity", hrp); bv.Name = "FlyBV"; bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        if hum and hum.MoveDirection.Magnitude > 0 then
            local fL = (cam.CFrame.LookVector * Vector3.new(1,0,1)).Unit; local fR = (cam.CFrame.RightVector * Vector3.new(1,0,1)).Unit
            local moveVec = (cam.CFrame.LookVector * hum.MoveDirection:Dot(fL)) + (cam.CFrame.RightVector * hum.MoveDirection:Dot(fR))
            bv.Velocity = moveVec.Unit * _G.FlySpeed
        else bv.Velocity = Vector3.new(0,0,0) end
    end
end)
