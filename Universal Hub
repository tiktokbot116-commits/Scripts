local function CreateToggle(yPos, text, callback)
    local Btn = Instance.new("TextButton", Content); Btn.Size = UDim2.new(0.95, 0, 0.13, 0); Btn.Position = UDim2.new(0.02, 0, yPos, 0); Btn.Text = text; Btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40); Btn.TextColor3 = Color3.new(1, 1, 1); Instance.new("UICorner", Btn)
    local active = false
    Btn.MouseButton1Click:Connect(function() active = not active; Btn.BackgroundColor3 = active and Color3.fromRGB(80, 80, 80) or Color3.fromRGB(40, 40, 40); callback(active) end)
end

-- 3. MOTOR DE ESP (QUADRADO + HIGHLIGHT VERMELHO)
_G.RedESP = false

local function ApplyESP(p)
    local function CreateVisuals(char)
        if not _G.RedESP then return end
        local hrp = char:WaitForChild("HumanoidRootPart", 10)
        if not hrp then return end

        -- Highlight Vermelho
        local hi = char:FindFirstChild("RedHighlight") or Instance.new("Highlight")
        hi.Name = "RedHighlight"; hi.Parent = char
        hi.FillColor = Color3.new(1, 0, 0); hi.FillTransparency = 0.5
        hi.OutlineColor = Color3.new(1, 0, 0); hi.OutlineTransparency = 0
        hi.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop

        -- Quadrado Vermelho (Box Adornment - Mais estável que Billboard)
        local box = hrp:FindFirstChild("RedBox") or Instance.new("BoxHandleAdornment")
        box.Name = "RedBox"; box.Parent = hrp
        box.AlwaysOnTop = true; box.Adornee = hrp; box.ZIndex = 10
        box.Size = Vector3.new(4.5, 6, 4.5) -- Tamanho do quadrado ao redor do player
        box.Color3 = Color3.new(1, 0, 0); box.Transparency = 0.7
    end
    
    p.CharacterAdded:Connect(CreateVisuals)
    if p.Character then CreateVisuals(p.Character) end
end

local function ToggleESP(state)
    _G.RedESP = state
    if state then
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= Player then ApplyESP(p) end
        end
    else
        -- Limpar tudo ao desligar
        for _, p in pairs(Players:GetPlayers()) do
            if p.Character then
                local hi = p.Character:FindFirstChild("RedHighlight")
                if hi then hi:Destroy() end
                local hrp = p.Character:FindFirstChild("HumanoidRootPart")
                if hrp and hrp:FindFirstChild("RedBox") then hrp.RedBox:Destroy() end
            end
        end
    end
end

-- Conectar novos players que entrarem
Players.PlayerAdded:Connect(function(p)
    if _G.RedESP then ApplyESP(p) end
end)

-- 4. ANTI-LAG MANTIDO
local function ActivateAntiLag()
    Lighting.GlobalShadows = false; Lighting.FogEnd = 9e9
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") or v:IsA("Atmosphere") or v:IsA("Sky") or v:IsA("Clouds") then v:Destroy() end
    end
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic; v.Reflectance = 0; v.CastShadow = false
        elseif v:IsA("Decal") or v:IsA("Texture") then v:Destroy()
        elseif v:IsA("ParticleEmitter") or v:IsA("Trail") then v.Enabled = false end
    end
    local terrain = workspace:FindFirstChildOfClass("Terrain")
    if terrain then terrain.Decoration = false; terrain.WaterWaveSize = 0; terrain.WaterWaveSpeed = 0 end
end

-- 5. ABAS
_G.FlySpeed = 50
local tabs = {"Main", "Visual"}
for i, name in pairs(tabs) do
    local b = Instance.new("TextButton", TabContainer); b.Size = UDim2.new(0.5, 0, 1, 0); b.Position = UDim2.new((i-1)*0.5, 0, 0, 0); b.Text = name; b.BackgroundColor3 = Color3.fromRGB(35, 35, 35); b.TextColor3 = Color3.new(1, 1, 1)
    b.MouseButton1Click:Connect(function()
