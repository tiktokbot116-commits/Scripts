local ESP_Instances = {}
CreateToggle(TabVisuals, "ESP Caixas (Boxes)", function(state) Features.ESP_Box = state end)
CreateToggle(TabVisuals, "ESP Nomes", function(state) Features.ESP_Name = state end)
CreateToggle(TabVisuals, "ESP Linhas (Tracers)", function(state) Features.ESP_Tracer = state end)

RunService.RenderStepped:Connect(function()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            if not ESP_Instances[p] then
                ESP_Instances[p] = { Box = Drawing.new("Square"), Name = Drawing.new("Text"), Tracer = Drawing.new("Line") }
                ESP_Instances[p].Box.Color = Color3.fromRGB(255, 50, 50); ESP_Instances[p].Box.Thickness = 1
                ESP_Instances[p].Name.Color = Color3.new(1, 1, 1); ESP_Instances[p].Name.Size = 16; ESP_Instances[p].Name.Center = true
                ESP_Instances[p].Tracer.Color = Color3.fromRGB(255, 50, 50); ESP_Instances[p].Tracer.Thickness = 1
            end

            local esp = ESP_Instances[p]
            if p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Head") then
                local rootPos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
                local headPos = Camera:WorldToViewportPoint(p.Character.Head.Position + Vector3.new(0, 0.5, 0))
                local legPos = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position - Vector3.new(0, 3, 0))

                if onScreen then
                    esp.Box.Visible = Features.ESP_Box; esp.Box.Size = Vector2.new(2000 / rootPos.Z, headPos.Y - legPos.Y)
                    esp.Box.Position = Vector2.new(rootPos.X - esp.Box.Size.X / 2, rootPos.Y - esp.Box.Size.Y / 2)
                    esp.Name.Visible = Features.ESP_Name; esp.Name.Position = Vector2.new(rootPos.X, headPos.Y - 25); esp.Name.Text = p.Name
                    esp.Tracer.Visible = Features.ESP_Tracer; esp.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y); esp.Tracer.To = Vector2.new(rootPos.X, legPos.Y)
                else
                    esp.Box.Visible = false; esp.Name.Visible = false; esp.Tracer.Visible = false
                end
            else
                esp.Box.Visible = false; esp.Name.Visible = false; esp.Tracer.Visible = false
            end
        end
    end
end)

