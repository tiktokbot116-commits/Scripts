local function setupUI()
    local hotbar = player.PlayerGui:WaitForChild("Hotbar", 5)
    if not hotbar then return end
    
    local hotbarFrame = hotbar:FindFirstChild("Backpack") and hotbar.Backpack:FindFirstChild("Hotbar")
    if not hotbarFrame then return end

    for id, name in pairs(skillNames) do
        if hotbarFrame:FindFirstChild(id) then
            pcall(function() hotbarFrame[id].Base.ToolName.Text = name end)
        end
    end

    if hotbarFrame:FindFirstChild("5") then pcall(function() hotbarFrame["5"].Visible = true end) end
end

