local function playSFX(soundId, startTime)
    if not soundId or soundId == "rbxassetid://0" then return end
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    task.spawn(function()
        local sound = Instance.new("Sound")
        sound.SoundId = soundId
        sound.Volume = 4
        sound.Parent = hrp

        if startTime then sound.TimePosition = startTime end
        sound:Play()
        sound.Ended:Connect(function() sound:Destroy() end)
        task.delay(5, function() if sound and sound.Parent then sound:Destroy() end end)
    end)
end

local function playTPEffects(position)
    local vfxPart = Instance.new("Part")
    vfxPart.Size = Vector3.new(1, 1, 1)
    vfxPart.Transparency = 1
    vfxPart.Anchored = true
    vfxPart.CanCollide = false
    vfxPart.Position = position
    vfxPart.Parent = workspace

    local char = player.Character
    if char then
        local charHandler = char:FindFirstChild("CharacterHandler")
        local PARTICLES = charHandler and charHandler:FindFirstChild("Particles")
        
        if PARTICLES then
            local fxList = {
                {obj = PARTICLES:FindFirstChild("CyborgUp") and PARTICLES.CyborgUp:FindFirstChild("SmokeDark"), special = true},
                {obj = PARTICLES:FindFirstChild("Vanish") and PARTICLES.Vanish:FindFirstChild("Silhouette"), special = false},
                {obj = PARTICLES:FindFirstChild("Vanish") and PARTICLES.Vanish:FindFirstChild("Afterimage_Flip_Black"), special = false},
                {obj = PARTICLES:FindFirstChild("Appear") and PARTICLES.Appear:FindFirstChild("Black_Shock"), special = false},
                {obj = PARTICLES:FindFirstChild("Appear") and PARTICLES.Appear:FindFirstChild("Smudge"), special = false},
            }

            for _, data in pairs(fxList) do
                local p = data.obj
                if p and p:IsA("ParticleEmitter") then
                    local clone = p:Clone()
                    if data.special then clone.Size = NumberSequence.new(clone.Size.Keypoints[1].Value * 0.5) end
                    clone.Parent = vfxPart
                    clone:Emit(3)
                end
            end
        end
    end

    task.delay(2, function() if vfxPart then vfxPart:Destroy() end end)
end

local function waitForTrack(track)
    if not track then return end
    local start = os.clock()
    while track.IsPlaying and (os.clock() - start) < 4 do task.wait(0.1) end
end

-- =======================================================================
-- 6. LÓGICA DE EXECUÇÃO DAS SKILLS
-- =======================================================================
local function runSkill(skillId)
    local char = player.Character
    if not char then return end
    
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChildWhichIsA("Humanoid")
    local animator = humanoid and humanoid:FindFirstChildOfClass("Animator")
    if not hrp or not humanoid then return end

    local charHandler = char:FindFirstChild("CharacterHandler")
    local ANIMATIONS = charHandler and charHandler:FindFirstChild("Animations")
    local anim2 = ANIMATIONS and ANIMATIONS:FindFirstChild("End", 5)

    if skillId == "1" then pcall(playSFX, SFX_IDS[skillId], 0.5) else pcall(playSFX, SFX_IDS[skillId]) end

    local track = nil

    if skillId == "1" then
        task.wait(1.5)
        playTPEffects(hrp.Position)
        hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -15)
        playTPEffects(hrp.Position)
    elseif skillId == "2" then
        task.wait(2.5)
        if anim2 and animator then
            pcall(function() track = animator:LoadAnimation(anim2) end)
            if track then track:Play() end
        end
        task.wait(0.5)
        local ray = workspace:Raycast(hrp.Position, Vector3.new(0, -1000, 0))
        if ray then
            playTPEffects(hrp.Position)
            hrp.CFrame = CFrame.new(ray.Position + Vector3.new(0, -0.3, 0))
            playTPEffects(hrp.Position)
        end
    elseif skillId == "3" then
        task.wait(1.5)
        playTPEffects(hrp.Position)
        hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -15)
        playTPEffects(hrp.Position)
    elseif skillId == "4" then
        hrp.Anchored = true
        task.wait(4)
        hrp.Anchored = false
    elseif skillId == "5" then
        task.wait(0.5)
        playTPEffects(hrp.Position)
        hrp.CFrame = hrp.CFrame * CFrame.new(0, 0, -15)
        playTPEffects(hrp.Position)
    end
    
    waitForTrack(track)
end

UserInputService.InputBegan:Connect(function(input)
    if isBusy then return end

    if input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1 then
        local pos = input.Position
        
        local hotbar = player.PlayerGui:FindFirstChild("Hotbar")
        local hotbarFrame = hotbar and hotbar:FindFirstChild("Backpack") and hotbar.Backpack:FindFirstChild("Hotbar")
        if not hotbarFrame then return end

        for _, btn in pairs(hotbarFrame:GetChildren()) do
            if btn:IsA("GuiButton") then
                local btnPos = btn.AbsolutePosition
                local btnSize = btn.AbsoluteSize

                if pos.X >= btnPos.X and pos.X <= (btnPos.X + btnSize.X) and pos.Y >= btnPos.Y and pos.Y <= (btnPos.Y + btnSize.Y) then
                    local skill = btn.Name

                    if skillNames[skill] then
                        local now = os.clock()
                        local cooldown = COOLDOWNS[skill] or 0
                        local last = lastUsed[skill]

                        if not (last and (now - last) < cooldown) then
                            lastUsed[skill] = now
                            isBusy = true
                            task.spawn(function()
                                local ok, err = pcall(runSkill, skill)
                                if not ok then warn("[Ability] Erro durante a skill: ", err) end
                                isBusy = false
                            end)
                        end
                        break
                    end
                end
            end
        end
    end
end)

-- =======================================================================
-- 7. PASSIVA: DETECTOR DE ANIMAÇÃO E AUTO-ESQUIVA
-- =======================================================================
local function performAutoDodge()
	-- Ignora isBusy propositalmente para o Auto-Dodge sempre te salvar
	local char = player.Character
	if not char then return end
	
	local myHRP = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildWhichIsA("Humanoid")
	if not myHRP or not hum then return end
	
	local now = tick()
	if (now - lastAutoDodgeTime) < AUTO_DODGE_COOLDOWN then return end
	lastAutoDodgeTime = now
	
	local moveDir = hum.MoveDirection
	local offset
	
	if moveDir.Magnitude > 0.1 then
		offset = moveDir.Unit * AUTO_DODGE_DISTANCE
	else
		offset = myHRP.CFrame.RightVector * AUTO_DODGE_DISTANCE
	end
	
	task.spawn(function()
		local ok, err = pcall(function()
			playTPEffects(myHRP.Position)
			myHRP.CFrame = myHRP.CFrame + offset
			playTPEffects(myHRP.Position)
		end)
		if not ok then warn("[Passiva] Erro na auto-esquiva: ", err) end
	end)
end

local function checkAnims()
    local myChar = player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character.Parent == workspace:FindFirstChild("Live") then
			local targetChar = plr.Character
			local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
			local hum = targetChar:FindFirstChildWhichIsA("Humanoid")
			
			if targetHRP and hum then
				local dist = (targetHRP.Position - myHRP.Position).Magnitude
				local targetAnimator = hum:FindFirstChildOfClass("Animator")
				
				if targetAnimator then
					local anims = {}
					for _, track in ipairs(targetAnimator:GetPlayingAnimationTracks()) do
						local id = tonumber(track.Animation.AnimationId:match("%d+"))
						if id then anims[id] = true end
					end

					local comboCount = 0
					for _, id in ipairs(comboIDs) do
						if anims[id] then comboCount += 1 end
					end
					
					local dodged = false

					for _, group in pairs(allIDs) do
						local normalHits = 0
						local special = anims[group.special]
						
						for i = 1, 4 do
							if anims[group[i]] then normalHits += 1 end
						end

						if comboCount == 2 and normalHits >= 2 and dist <= specialRange then
							performAutoDodge()
							dodged = true
							break
						elseif normalHits > 0 and dist <= normalRange then
							performAutoDodge()
							dodged = true
							break
						elseif special and dist <= specialRange then
							performAutoDodge()
							dodged = true
							break
						end
					end

					if not dodged then
						for animId in pairs(anims) do
							if skillIDs[animId] and dist <= skillRange then
								performAutoDodge()
								break
							end
						end
					end
				end
			end
		end
	end
end

RunService.Heartbeat:Connect(function()
	pcall(checkAnims)
end)
