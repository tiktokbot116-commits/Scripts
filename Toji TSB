-- 9. LISTENER DE ANIMAÇÕES PARA A PASSIVA
-- =======================================================================
local function evaluateAnimsAndDodge(anims, dist)
    local comboCount = 0
    for _, id in ipairs(comboIDs) do if anims[id] then comboCount += 1 end end

    for _, group in pairs(allIDs) do
        local normalHits = 0
        local special = anims[group.special]
        for i = 1, 4 do if anims[group[i]] then normalHits += 1 end end

        if (comboCount == 2 and normalHits >= 2 and dist <= specialRange) or 
           (normalHits > 0 and dist <= normalRange) or 
           (special and dist <= specialRange) then
            performAutoDodge()
            return true
        end
    end

    for animId in pairs(anims) do
        if skillIDs[animId] and dist <= skillRange then
            performAutoDodge()
            return true
        end
    end
    return false
end

local function getPlayingAnimsMap(targetAnimator)
    local anims = {}
    for _, track in ipairs(targetAnimator:GetPlayingAnimationTracks()) do
        local id = tonumber(track.Animation.AnimationId:match("%d+"))
        if id then anims[id] = true end
    end
    return anims
end

local function checkAnims()
    local myChar = player.Character
    if not myChar then return end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character and plr.Character.Parent == workspace:FindFirstChild("Live") then
			local targetChar = plr.Character
			local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
			local hum = targetChar:FindFirstChildWhichIsA("Humanoid")
			
			if targetHRP and hum then
				local dist = (targetHRP.Position - myHRP.Position).Magnitude
				local targetAnimator = hum:FindFirstChildOfClass("Animator")
				if targetAnimator then
					evaluateAnimsAndDodge(getPlayingAnimsMap(targetAnimator), dist)
				end
			end
		end
	end
end

local hookedAnimators = {}
local function hookAnimator(plr, targetAnimator)
    if hookedAnimators[targetAnimator] then return end
    hookedAnimators[targetAnimator] = true
    targetAnimator.AnimationPlayed:Connect(function(track)
        local id = tonumber(track.Animation.AnimationId:match("%d+"))
        if not id then return end
        local myChar, targetChar = player.Character, plr.Character
        if not myChar or not targetChar then return end
        local myHRP, targetHRP = myChar:FindFirstChild("HumanoidRootPart"), targetChar:FindFirstChild("HumanoidRootPart")
        if not myHRP or not targetHRP then return end

        local anims = getPlayingAnimsMap(targetAnimator)
        anims[id] = true
        evaluateAnimsAndDodge(anims, (targetHRP.Position - myHRP.Position).Magnitude)
    end)
end

local function hookPlayer(plr)
    if plr == player then return end
    local function hookChar(char)
        task.spawn(function()
            local hum = char:WaitForChild("Humanoid", 5)
            if hum then 
                local animator = hum:FindFirstChildOfClass("Animator") or hum:WaitForChild("Animator", 5)
                if animator then hookAnimator(plr, animator) end 
            end
        end)
    end
    if plr.Character then hookChar(plr.Character) end
    plr.CharacterAdded:Connect(hookChar)
