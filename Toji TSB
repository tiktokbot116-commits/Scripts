local function applyClothing(char)
    local s = char:FindFirstChildOfClass("Shirt") or Instance.new("Shirt", char)
    local p = char:FindFirstChildOfClass("Pants") or Instance.new("Pants", char)
    s.ShirtTemplate = "rbxassetid://" .. SHIRT_ID
    p.PantsTemplate = "rbxassetid://" .. PANTS_ID
end

local function makeInvisible(model)
    if not model then return end
    for _, obj in pairs(model:GetDescendants()) do
        if (obj:IsA("BasePart") or obj:IsA("Decal")) and obj.Name ~= "ISOH" then
            obj.Transparency = 1
        end
    end
end

local function createAccessory(name, data, char)
    local target = char:FindFirstChild(data.Part)
    if not target then return nil end
    local part = Instance.new("MeshPart")
    part.Name = name
    part.MeshId = "rbxassetid://" .. data.Mesh
    part.TextureID = "rbxassetid://" .. data.Texture
    part.Size = Vector3.new(1, 1, 1)
    part.CanCollide = false
    part.CFrame = target.CFrame * data.Offset * data.Rot
    part.Parent = char
    local weld = Instance.new("WeldConstraint", part)
    weld.Part0 = part; weld.Part1 = target
    return part
end

