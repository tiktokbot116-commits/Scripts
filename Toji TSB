local function performAutoDodge()
	if isBusy then return end 
	local char = player.Character
	if not char then return end
	local myHRP = char:FindFirstChild("HumanoidRootPart")
	local hum = char:FindFirstChildWhichIsA("Humanoid")
	if not myHRP or not hum then return end
	
	local now = tick()
	if (now - lastAutoDodgeTime) < AUTO_DODGE_COOLDOWN then return end
	lastAutoDodgeTime = now
	
	local moveDir = hum.MoveDirection
	local offset = (moveDir.Magnitude > 0.1) and (moveDir.Unit * AUTO_DODGE_DISTANCE) or (myHRP.CFrame.RightVector * AUTO_DODGE_DISTANCE)
	
	task.spawn(function()
		pcall(function()
			playTPEffects(myHRP.Position)
			myHRP.CFrame = myHRP.CFrame + offset
			playTPEffects(myHRP.Position)
		end)
	end)
end

local function setupHealthMonitor(char)
    local hum = char:WaitForChild("Humanoid", 5)
    if not hum then return end
    
    local lastHealth = hum.Health
    hum.HealthChanged:Connect(function(newHealth)
        if newHealth < lastHealth then -- Tomou dano
            if isBusy then
                -- Cancela a skill em execução e desabilita a trava de animações
                if currentSkillTrack then currentSkillTrack:Stop(); currentSkillTrack = nil end
                if currentAnimConn then currentAnimConn:Disconnect(); currentAnimConn = nil end
                if currentSkillThread then task.cancel(currentSkillThread); currentSkillThread = nil end
                
                isBusy = false
                performAutoDodge() 
            end
        end
        lastHealth = newHealth
    end)
end

