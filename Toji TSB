    local hl = Instance.new("Highlight", char)
    hl.FillColor = Color3.fromRGB(0, 0, 0)
    hl.OutlineColor = Color3.fromRGB(255, 255, 255)
    hl.FillTransparency = 0.5

    playFxFromList("Vanish")
    playFxFromList("Appear")

    local ultAnim = Instance.new("Animation")
    ultAnim.AnimationId = "rbxassetid://97401167464229"
    local ultTrack = animator:LoadAnimation(ultAnim)
    ultTrack.Priority = Enum.AnimationPriority.Action4
