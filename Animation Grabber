-- [[ LÓGICA ANTI-LAG ]] --
local function saveToClipboard()
    if not currentAnimID then return end
    
    task.spawn(function()
        title.Text = "LENDO DADOS..."
        local success, seq = pcall(function() 
            return KeyframeSequenceProvider:GetKeyframeSequenceAsync("rbxassetid://"..currentAnimID) 
        end)
        
        if success then
            local data = {Keyframes = {}}
            local keyframes = seq:GetKeyframes()
            
            for i, kf in ipairs(keyframes) do
                -- Pula frames desnecessários (Otimização de 50% no peso do arquivo)
                if i % 2 == 0 then continue end 
                
                local ps = {}
                local function scan(obj)
                    for _, v in ipairs(obj:GetChildren()) do
                        if v:IsA("Pose") then 
                            table.insert(ps, {
                                Name = v.Name, 
                                CFrame = {v.CFrame:GetComponents()} 
                            }) 
                            scan(v) 
                        end
                    end
                end
                scan(kf)
                table.insert(data.Keyframes, {Time = kf.Time, Poses = ps})
                
                -- Pausa forçada para o celular não fritar
                if i % 3 == 0 then 
                    title.Text = "LIMPANDO RAM: " .. i .. "/" .. #keyframes
                    task.wait(0.05) 
                end
            end
            
            title.Text = "GERANDO TEXTO..."
            task.wait(0.1)
            
            local json = HttpService:JSONEncode(data)
            data = nil -- DESTRÓI A TABELA PARA LIBERAR RAM
            
            if setclipboard then
                setclipboard(json)
                json = nil -- DESTRÓI O TEXTO
                title.Text = "SUCESSO! COPIADO."
                task.wait(1)
                isWaiting = false
                main:TweenPosition(UDim2.new(0.5, -150, 0, -100), "In", "Quad", 0.3)
            end
        else
            title.Text = "ERRO NO ID"
        end
    end)
end

createBtn("SALVAR", Color3.fromRGB(0, 120, 0), saveToClipboard)
createBtn("PULAR", Color3.fromRGB(120, 0, 0), function()
    if currentAnimID then sessionSkip[currentAnimID] = true end
    isWaiting = false
    main:TweenPosition(UDim2.new(0.5, -150, 0, -100), "In", "Quad", 0.3)
end)

-- [[ MONITOR ]] --
local function monitor(char)
    local hum = char:WaitForChild("Humanoid")
    hum.AnimationPlayed:Connect(function(track)
        if isWaiting then return end
        local id = track.Animation.AnimationId:match("%d+")
        if id and not sessionSkip[id] then
            if track.Name:lower():find("walk") or track.Name:lower():find("run") then return end
            
            isWaiting = true
            track.Stopped:Wait()
            currentAnimID = id
            title.Text = "ID: " .. id .. " (CAPTURADO)"
            main:TweenPosition(UDim2.new(0.5, -150, 0, 20), "Out", "Back", 0.4)
        end
    end)
end

player.CharacterAdded:Connect(monitor)
monitor(character)
