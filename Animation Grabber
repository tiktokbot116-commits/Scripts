-- Loop de Gravação (20 FPS para evitar crash no G53)
local lastCap = 0
RunService.Heartbeat:Connect(function()
    if recording and (tick() - lastCap) > (1/20) then
        lastCap = tick()
        captureFrame()
    end
end)

player.CharacterAdded:Connect(function(c) character = c end)
