-- [[ LÓGICA DE SALVAMENTO PARA ARQUIVO ]] --
local function saveAnimation()
    if not currentAnimID then return end
    
    -- Pega o nome digitado. Se estiver vazio, usa "Anim_ID" por segurança.
    local animName = nameInput.Text
    if animName == "" or animName:match("^%s*$") then
        animName = "Anim_" .. tostring(currentAnimID)
    end
    
    title.Text = "LENDO COMPONENTES..."
    
    local success, seq = pcall(function() 
        return KeyframeSequenceProvider:GetKeyframeSequenceAsync("rbxassetid://"..currentAnimID) 
    end)
    
    if success then
        local data = {Keyframes = {}}
        for _, kf in ipairs(seq:GetKeyframes()) do
            local ps = {}
            local function scan(obj)
                for _, v in ipairs(obj:GetChildren()) do
                    if v:IsA("Pose") then 
                        local cf = v.CFrame
                        local components = {cf:GetComponents()}
                        
                        table.insert(ps, {
                            Name = v.Name,
                            CFrame = components 
                        }) 
                        scan(v) 
                    end
                end
            end
            scan(kf)
            table.insert(data.Keyframes, {Time = kf.Time, Poses = ps})
        end
        
        local json = HttpService:JSONEncode(data)
        
        -- Salva no arquivo dentro da pasta
        if writefile then
            writefile("AnimationsBackups/" .. animName .. ".json", json)
        end
        
        -- Opcional: Mantém também copiando para o clipboard caso precise colar rápido
        if setclipboard then
            setclipboard(json)
        end
        
        title.Text = "SALVO COM SUCESSO!"
        task.wait(1.5)
        isWaiting = false
        main:TweenPosition(UDim2.new(0.5, -190, 0, -150), "In", "Quad", 0.3)
    else
        title.Text = "FALHA AO LER ANIMAÇÃO!"
        task.wait(1.5)
        isWaiting = false
        main:TweenPosition(UDim2.new(0.5, -190, 0, -150), "In", "Quad", 0.3)
    end
end

createBtn("PLAY", Color3.fromRGB(0, 100, 200), function()
    if currentAnimID then
        if currentTrack then currentTrack:Stop() end
        local a = Instance.new("Animation")
        a.AnimationId = "rbxassetid://" .. currentAnimID
        currentTrack = player.Character.Humanoid:LoadAnimation(a)
        currentTrack:Play()
    end
end)

createBtn("STOP", Color3.fromRGB(150, 0, 0), function()
    if currentTrack then currentTrack:Stop() end
end)

createBtn("SAVE", Color3.fromRGB(0, 150, 0), saveAnimation)

createBtn("SKIP", Color3.fromRGB(150, 100, 0), function()
    if currentAnimID then sessionSkip[currentAnimID] = true end
    isWaiting = false
    main:TweenPosition(UDim2.new(0.5, -190, 0, -150), "In", "Quad", 0.3)
end)

-- [[ MONITOR ]] --
local function setupMonitor(char)
    local hum = char:WaitForChild("Humanoid")
    hum.AnimationPlayed:Connect(function(track)
        if isWaiting then return end
        local id = track.Animation.AnimationId:match("%d+")
        if id and not sessionSkip[id] then
            local n = track.Name:lower()
            if n:find("walk") or n:find("idle") or n:find("run") then return end
            
            isWaiting = true
            track.Stopped:Wait()
            
            currentAnimID = id
            title.Text = "NOVA ANIMAÇÃO ENCONTRADA!"
            nameInput.Text = "" -- Limpa a caixa de texto para a nova animação
            main:TweenPosition(UDim2.new(0.5, -190, 0, 20), "Out", "Back", 0.4)
        end
    end)
end

player.CharacterAdded:Connect(setupMonitor)
setupMonitor(character)
