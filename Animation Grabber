-- [[ MONITORAMENTO E GRAVAÇÃO ]] --

local function setupMonitor(char)
    local hum = char:WaitForChild("Humanoid")
    
    hum.AnimationPlayed:Connect(function(track)
        if isWaiting then return end
        local id = track.Animation.AnimationId:match("%d+")
        
        if id and not sessionSkip[id] then
            local n = track.Name:lower()
            if n:find("walk") or n:find("idle") or n:find("run") then return end
            
            -- Inicia a gravação em tempo real
            currentAnimID = id
            buffer = {}
            startTick = tick()
            recording = true
            isWaiting = true
            title.Text = "GRAVANDO: " .. id
            
            main:TweenPosition(UDim2.new(0.5, -190, 0, 20), "Out", "Back", 0.4)
            
            track.Stopped:Connect(function()
                recording = false
                title.Text = "ID: " .. id .. " | SALVAR?"
            end)
        end
    end)
end

-- Loop de gravação (30 FPS para ser leve no G53)
RunService.Heartbeat:Connect(function()
    if recording then
        captureFrame()
    end
end)

player.CharacterAdded:Connect(function(c)
    character = c
    setupMonitor(c)
end)
setupMonitor(character)
