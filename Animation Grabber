-- Loop de Gravação (15 FPS - Suficiente para movimentos e salva muito espaço)
local lastCap = 0
RunService.Heartbeat:Connect(function()
    if recording and (tick() - lastCap) > (1/15) then
        lastCap = tick()
        captureFrame()
    end
end)

