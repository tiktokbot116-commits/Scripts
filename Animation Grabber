-- [[ LÓGICA DE COMPRESSÃO (7 COMPONENTES) ]] --
local function captureFrame()
    if not recording or not character then return end
    local ps = {}
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") and v.Part1 then
            -- Salva apenas X,Y,Z e Quaternion X,Y,Z,W (7 números em vez de 12)
            local cf = v.Transform
            local x,y,z = cf.X, cf.Y, cf.Z
            local qx, qy, qz, qw = cf:ToQuaternion()
            
            local comp = {x,y,z,qx,qy,qz,qw}
            for k, val in ipairs(comp) do comp[k] = math.floor(val * 100) / 100 end
            
            table.insert(ps, {
                Name = v.Part1.Name,
                CFrame = comp 
            })
        end
    end
    table.insert(buffer, {
        Time = math.floor((tick() - startTick) * 100) / 100,
        Poses = ps
    })
end

