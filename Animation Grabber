end)

createBtn("STOP", Color3.fromRGB(150, 0, 0), function()
    recording = false
    replaying = false
    buffer = {}
    title.Text = "RESETADO"
end)

-- Loop de Gravação (24 FPS)
local lastCap = 0
RunService.Heartbeat:Connect(function()
    if recording and (tick() - lastCap) > (1/24) then
        lastCap = tick()
        captureFrame()
    end
end)

player.CharacterAdded:Connect(function(c) character = c end)
