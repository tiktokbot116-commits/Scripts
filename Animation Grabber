-- [[ LÓGICA DE CAPTURA DE FRAME (BUFFER) ]] --
local function captureFrame()
    if not recording or not character then return end
    
    local currentTime = tick() - startTick
    local ps = {}
    
    -- Varre o personagem para pegar as transformações das juntas
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") and v.Part1 then
            -- Converte CFrame para componentes numéricos para o seu UNPACK
            local cf = {v.Transform:GetComponents()}
            -- Encurta os números para economizar memória e evitar crash na cópia
            for k, val in ipairs(cf) do cf[k] = math.floor(val * 1000) / 1000 end
            
            table.insert(ps, {
                Name = v.Part1.Name, 
                CFrame = cf          
            })
        end
    end
    
    table.insert(buffer, {
        Time = math.floor(currentTime * 100) / 100,
        Poses = ps
    })
end

