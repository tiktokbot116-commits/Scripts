-- [[ LÓGICA DE COMPRESSÃO ]] --
local function saveToClipboard()
    if not currentAnimID then return end
    btn.Visible = false
    title.Text = "COMPRIMINDO..."
    
    task.spawn(function()
        local success, seq = pcall(function() 
            return KeyframeSequenceProvider:GetKeyframeSequenceAsync("rbxassetid://"..currentAnimID) 
        end)
        
        if success then
            local data = {Keyframes = {}}
            local keyframes = seq:GetKeyframes()
            
            for i, kf in ipairs(keyframes) do
                -- Redução de frames (Grava 1 a cada 3) - Essencial para 20s+
                if i % 3 ~= 0 then continue end 
                
                local ps = {}
                local function scan(obj)
                    for _, v in ipairs(obj:GetChildren()) do
                        if v:IsA("Pose") then 
                            -- Arredonda os números para diminuir o texto
                            local c = {v.CFrame:GetComponents()}
                            for k, val in ipairs(c) do c[k] = math.floor(val * 1000) / 1000 end
                            
                            table.insert(ps, {
                                Name = v.Name, 
                                CFrame = c 
                            }) 
                            scan(v) 
                        end
                    end
                end
                scan(kf)
                table.insert(data.Keyframes, {Time = math.floor(kf.Time * 100) / 100, Poses = ps})
                
                if i % 10 == 0 then task.wait() end
            end
            
            -- JSONEncode sem espaços (Minificado)
            local json = HttpService:JSONEncode(data)
            
            if setclipboard then
                setclipboard(json)
                title.Text = "COPIADO! TAMANHO REDUZIDO."
                task.wait(2)
                isWaiting = false
                main:TweenPosition(UDim2.new(0.5, -150, 0, -100), "In", "Quad", 0.3)
            end
            json = nil
            data = nil
        end
        btn.Visible = true
    end)
end

btn.MouseButton1Click:Connect(saveToClipboard)

-- [[ MONITOR ]] --
local function monitor(char)
    local hum = char:WaitForChild("Humanoid")
    hum.AnimationPlayed:Connect(function(track)
        if isWaiting then return end
        local id = track.Animation.AnimationId:match("%d+")
        if id and not sessionSkip[id] then
            if track.Name:lower():find("walk") then return end
            isWaiting = true
            track.Stopped:Wait()
            currentAnimID = id
            title.Text = "ID: " .. id
            main:TweenPosition(UDim2.new(0.5, -150, 0, 10), "Out", "Back", 0.4)
        end
    end)
end

player.CharacterAdded:Connect(monitor)
monitor(character)
