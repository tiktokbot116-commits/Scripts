-- [[ LÓGICA DE CAPTURA ]] --
local function captureFrame()
    if not recording or not character then return end
    local ps = {}
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") and v.Part1 then
            local cf = {v.Transform:GetComponents()}
            -- Arredonda para 3 casas para o texto não ficar gigante
            for k, val in ipairs(cf) do cf[k] = math.floor(val * 1000) / 1000 end
            table.insert(ps, {
                Name = v.Part1.Name, -- poseData.Name
                CFrame = cf          -- poseData.CFrame
            })
        end
    end
    table.insert(buffer, {
        Time = math.floor((tick() - startTick) * 100) / 100,
        Poses = ps
    })
end

-- [[ BOTÕES ]] --

createBtn("REC", Color3.fromRGB(200, 0, 0), function()
    if not recording then
        buffer = {}
        startTick = tick()
        recording = true
        replaying = false
        title.Text = "🔴 GRAVANDO..."
    else
        recording = false
        title.Text = "PARADO ("..#buffer.." frames)"
    end
end)

createBtn("PLAY", Color3.fromRGB(0, 100, 200), function()
    if #buffer == 0 then title.Text = "NADA GRAVADO!" return end
    replaying = not replaying
    if not replaying then title.Text = "REPLAY PARADO" return end
    
    title.Text = "▶️ REPLAY DO BUFFER..."
    task.spawn(function()
        local startTime = tick()
        local idx = 1
        while replaying and idx <= #buffer do
            local elapsed = tick() - startTime
            if elapsed >= buffer[idx].Time then
                for _, pose in ipairs(buffer[idx].Poses) do
                    -- Busca o Motor6D e força a Transform (Ignora Animações do Roblox)
                    for _, m in ipairs(character:GetDescendants()) do
                        if m:IsA("Motor6D") and m.Part1 and m.Part1.Name == pose.Name then
                            m.Transform = CFrame.new(unpack(pose.CFrame))
                        end
                    end
                end
                idx = idx + 1
            end
            RunService.Stepped:Wait()
        end
        replaying = false
    end)
end)

