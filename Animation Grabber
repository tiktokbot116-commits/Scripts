createBtn("PLAY", Color3.fromRGB(0, 100, 200), function()
    if #buffer == 0 then return end
    replaying = true
    title.Text = "▶️ REPLAY (FORÇADO)"
    
    task.spawn(function()
        local start = tick()
        local idx = 1
        while replaying and idx <= #buffer do
            local elapsed = tick() - start
            if elapsed >= buffer[idx].Time then
                for _, p in ipairs(buffer[idx].Poses) do
                    for _, m in ipairs(character:GetDescendants()) do
                        if m:IsA("Motor6D") and m.Part1 and m.Part1.Name == p.Name then
                            -- Reconstrói o CFrame a partir dos 7 componentes
                            m.Transform = CFrame.new(p.CFrame[1], p.CFrame[2], p.CFrame[3]) * CFrame.fromQuaternion(p.CFrame[4], p.CFrame[5], p.CFrame[6], p.CFrame[7])
                        end
                    end
                end
                idx = idx + 1
            end
            RunService.Stepped:Wait() -- Prioridade sobre animações do Roblox
        end
        replaying = false
        title.Text = "REPLAY FIM"
    end)
end)

