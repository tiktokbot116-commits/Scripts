-- [[ CAPTURA ]] --
local function captureFrame()
    if not recording or not character then return end
    local ps = {}
    for _, v in ipairs(character:GetDescendants()) do
        if v:IsA("Motor6D") and v.Part1 then
            local cf = {v.Transform:GetComponents()}
            for k, val in ipairs(cf) do cf[k] = math.floor(val * 1000) / 1000 end
            table.insert(ps, {
                Name = v.Part1.Name,
                CFrame = cf
            })
        end
    end
    table.insert(buffer, {
        Time = math.floor((tick() - startTick) * 100) / 100,
        Poses = ps
    })
end

-- [[ BOTÕES ]] --

createBtn("REC", Color3.fromRGB(200, 0, 0), function()
    if not recording then
        buffer = {}
        startTick = tick()
        recording = true
        replaying = false
        title.Text = "🔴 GRAVANDO..."
    else
        recording = false
        title.Text = "PARADO ("..#buffer.." frames)"
    end
end)

-- PLAY (REPLAY DO BUFFER)
createBtn("PLAY", Color3.fromRGB(0, 100, 200), function()
    if #buffer == 0 then title.Text = "NADA GRAVADO!" return end
    if replaying then replaying = false task.wait(0.1) end
    
    replaying = true
    title.Text = "▶️ REPRODUZINDO REPLAY..."
    
    task.spawn(function()
        local startTime = tick()
        local currentIndex = 1
        
        -- O segredo é usar o Stepped para o replay não ser cancelado pelo Idle do Roblox
        while replaying and currentIndex <= #buffer do
            local elapsed = tick() - startTime
            local kf = buffer[currentIndex]
            
            if elapsed >= kf.Time then
                for _, pose in ipairs(kf.Poses) do
                    -- Procura a junta no personagem de forma eficiente
                    for _, m in ipairs(character:GetDescendants()) do
                        if m:IsA("Motor6D") and m.Part1 and m.Part1.Name == pose.Name then
                            m.Transform = CFrame.new(unpack(pose.CFrame))
                        end
                    end
                end
                currentIndex = currentIndex + 1
            end
            RunService.Stepped:Wait()
        end
        replaying = false
        title.Text = "REPLAY FINALIZADO"
    end)
end)

