local function extrairAbsolutamenteTodosOsIds(desc)
    local ids = {}
    for _, prop in ipairs(todasAsPropriedades) do
        local valor = desc[prop]
        if valor then
            local valorStr = tostring(valor)
            if valorStr ~= "" and valorStr ~= "0" then
                for id in string.gmatch(valorStr, "%d+") do
                    local num = tonumber(id)
                    if num and num > 0 and not table.find(ids, num) then 
                        table.insert(ids, num) 
                    end
                end
            end
        end
    end
    return ids
end

-- EXTRAÇÃO AVANÇADA (Rastreia cabelos complexos, malhas de cabeça e faces dinâmicas com segurança)
local function extrairDadosFisicosFaciaisECorporais(personagem, tabelaDestino)
    if not personagem then return end
    
    for _, objeto in ipairs(personagem:GetChildren()) do
        -- Captura Acessórios comuns, Cabelos, Acessórios de cabeça e roupas 3D (Layered Clothing)
        if objeto:IsA("Accessory") then
            local idFisico = objeto:GetAttribute("AssetId")
            
            -- Se não achar via Attribute, extrai da malha interna (Necessário para cabelos e faces dinâmicas híbridas)
            if not idFisico then
                local handle = objeto:FindFirstChild("Handle")
                local wrapLayer = handle and handle:FindFirstChildOfClass("WrapLayer")
                if wrapLayer and wrapLayer.CageMeshId ~= "" then
                    idFisico = tonumber(string.match(wrapLayer.CageMeshId, "%d+"))
                elseif handle then
                    local mesh = handle:FindFirstChildOfClass("SpecialMesh")
                    if mesh and mesh.MeshId ~= "" then
                        idFisico = tonumber(string.match(mesh.MeshId, "%d+"))
                    end
                end
            end
            
            if not idFisico then
                idFisico = objeto:FindFirstChild("ThumbnailId") and tonumber(objeto.ThumbnailId.Value)
            end
            
            if idFisico and idFisico > 0 and not table.find(tabelaDestino, idFisico) then
                table.insert(tabelaDestino, idFisico)
            end
            
        elseif objeto:IsA("Shirt") and objeto.ShirtTemplate ~= "" then
            local id = tonumber(string.match(objeto.ShirtTemplate, "%d+"))
            if id and not table.find(tabelaDestino, id) then table.insert(tabelaDestino, id) end
        elseif objeto:IsA("Pants") and objeto.PantsTemplate ~= "" then
            local id = tonumber(string.match(objeto.PantsTemplate, "%d+"))
            if id and not table.find(tabelaDestino, id) then table.insert(tabelaDestino, id) end
        elseif objeto:IsA("ShirtGraphic") and objeto.Graphic ~= "" then
            local id = tonumber(string.match(objeto.Graphic, "%d+"))
            if id and not table.find(tabelaDestino, id) then table.insert(tabelaDestino, id) end
        end
    end
    
    -- Varredura profunda na cabeça para rastrear Faces Dinâmicas clássicas injetadas via Decal/Texture
    local head = personagem:FindFirstChild("Head")
    if head then
        local decal = head:FindFirstChildOfClass("Decal")
        if decal and decal.Texture ~= "" then
            local idFace = tonumber(string.match(decal.Texture, "%d+"))
            if idFace and not table.find(tabelaDestino, idFace) then table.insert(tabelaDestino, idFace) end
        end
    end
end

local function obterMeusIdsVestidos()
    local meusIds = {}
    local meuChar = LocalPlayer.Character
    if meuChar then
        extrairDadosFisicosFaciaisECorporais(meuChar, meusIds)
        
        local hum = meuChar:FindFirstChildOfClass("Humanoid")
        local sucessoDesc, atualDesc = pcall(function() return hum:GetAppliedDescription() end)
        if sucessoDesc and atualDesc then
            for _, prop in ipairs(todasAsPropriedades) do
                local val = atualDesc[prop]
                if val then
                    for id in string.gmatch(tostring(val), "%d+") do
                        local num = tonumber(id)
                        if num and num > 0 and not table.find(meusIds, num) then 
                            table.insert(meusIds, num) 
                        end
                    end
                end
            end
        end
    end
    return meusIds
end

local function atualizarStatusDeParidade()
    if #idsParaEquiparGlobal == 0 then return end
    
    local meusIdsAtuais = obterMeusIdsVestidos()
    local faltamItens = 0
    
    for _, id in ipairs(idsParaEquiparGlobal) do
        if not table.find(meusIdsAtuais, id) then faltamItens = faltamItens + 1 end
    end
    
    if faltamItens == 0 then
        canSaveGlobal = true
        ActionBtn.Text = "✔️ Tudo Equipado com Sucesso!"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 100, 80)
        
        SaveBtn.BackgroundColor3 = Color3.fromRGB(35, 145, 65)
        SaveBtn.TextColor3 = Color3.new(1, 1, 1)
        SaveBtn.Text = "💾 Salvar Skin (100% Sincronizado)"
        SaveBtn.AutoButtonColor = true
    else
        canSaveGlobal = false
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 130, 200)
        ActionBtn.TextColor3 = Color3.new(1, 1, 1)
        ActionBtn.Text = "⚡ Equipar Itens Faltantes (" .. faltamItens .. ") ⚡"
        ActionBtn.AutoButtonColor = true
        
        SaveBtn.BackgroundColor3 = Color3.fromRGB(55, 45, 45)
        SaveBtn.TextColor3 = Color3.fromRGB(150, 110, 110)
        SaveBtn.Text = "❌ Faltam " .. faltamItens .. " itens para liberar o Save"
        SaveBtn.AutoButtonColor = false
    end
end

-- [[ PROCESSADOR DE PREVIEW EXATO DO TRAJE CLICADO ]]
local function gerarPreviewDoTrajeSelecionado(humanoidDesc)
    if previewDummy then previewDummy:Destroy() end
    
    task.spawn(function()
        local sucesso, modelo = pcall(function()
            return Players:CreateHumanoidModelFromDescription(humanoidDesc, Enum.HumanoidRigType.R15)
        end)
        
        if sucesso and modelo then
            previewDummy = modelo
            previewDummy.Parent = Viewport
            
            local dummyHum = previewDummy:FindFirstChildOfClass("Humanoid")
            if dummyHum then
                pcall(function() dummyHum:ApplyDescription(humanoidDesc) end)
            end
            
            local hrp = previewDummy:WaitForChild("HumanoidRootPart")
            hrp.CFrame = CFrame.new(0, 0, 0) * CFrame.Angles(0, math.rad(180), 0)
            ViewCam.CFrame = CFrame.new(Vector3.new(0, 1.5, -7), hrp.Position + Vector3.new(0, 0.3, 0))
        end
    end)
end

-- FUNÇÃO ROTINA DE ESCANEAR ACESSADA PELA INTERFACE MANUAL OU CLIQUE LATERAL
local function executarEscaneamentoDoAlvo(nomeDoAlvo)
    limparLista()
    desativarBotoes()
    if previewDummy then previewDummy:Destroy() end
    
    if #nomeDoAlvo == 0 then return end
    
    local alvo = nil
    for _, p in ipairs(Players:GetPlayers()) do
        if string.lower(p.Name):sub(1, #nomeDoAlvo) == string.lower(nomeDoAlvo) or string.lower(p.DisplayName):sub(1, #nomeDoAlvo) == string.lower(nomeDoAlvo) then
            alvo = p
            break
        end
    end
    
    if not alvo then
        local erroLabel = Instance.new("TextLabel", CostumeScroll)
        erroLabel.Size = UDim2.new(1, -10, 0, 40)
        erroLabel.BackgroundTransparency = 1
        erroLabel.Text = "Jogador não encontrado!"
        erroLabel.TextColor3 = Color3.fromRGB(200, 50, 50)
        erroLabel.Font = Enum.Font.SourceSansBold
        erroLabel.TextSize = 14
        return
    end
    
    playerAlvoGlobal = alvo
    
    local costumesFolder = alvo:FindFirstChild("AE_Costumes")
    local listaTrajes = costumesFolder and costumesFolder:GetChildren() or {}
    local temTrajesValidos = false
    
    for _, item in ipairs(listaTrajes) do
        if item:IsA("HumanoidDescription") then temTrajesValidos = true; break end
    end
    
    if not temTrajesValidos then
        local erroLabel = Instance.new("TextLabel", CostumeScroll)
        erroLabel.Size = UDim2.new(1, -10, 0, 50)
        erroLabel.BackgroundTransparency = 1
        erroLabel.Text = "ERRO: Sem avatares salvos!"
        erroLabel.TextColor3 = Color3.fromRGB(220, 60, 60)
        erroLabel.Font = Enum.Font.SourceSansBold
        erroLabel.TextSize = 13
        return
    end
    
    CostumeScroll.CanvasSize = UDim2.new(0, 0, 0, #listaTrajes * 32)
    for _, item in ipairs(listaTrajes) do
        if item:IsA("HumanoidDescription") then
            local btn = Instance.new("TextButton", CostumeScroll)
            btn.Size = UDim2.new(1, -10, 0, 28)
            btn.BackgroundColor3 = Color3.fromRGB(45, 45, 55)
            btn.Text = "📁 " .. item.Name
            btn.TextColor3 = Color3.new(1, 1, 1)
            btn.Font = Enum.Font.SourceSansSemibold
            btn.TextSize = 14
            Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
            
            btn.MouseButton1Click:Connect(function()
                objetoDescriptionSelecionado = item
                idsParaEquiparGlobal = extrairAbsolutamenteTodosOsIds(item)
                
                local alvoChar = workspace:FindFirstChild(playerAlvoGlobal.Name)
                if alvoChar then
                    extrairDadosFisicosFaciaisECorporais(alvoChar, idsParaEquiparGlobal)
                end
                
                gerarPreviewDoTrajeSelecionado(item)
                atualizarStatusDeParidade()
            end)
        end
    end
end

ScanBtn.MouseButton1Click:Connect(function()
    executarEscaneamentoDoAlvo(TextBox.Text)
end)


