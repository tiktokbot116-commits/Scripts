local function atualizarListaLateralDePlayers()
    for _, filho in ipairs(PlayerScroll:GetChildren()) do
        if filho:IsA("TextButton") then filho:Destroy() end
    end
    
    local playersComSkinsValidas = {}
    
    for _, p in ipairs(Players:GetPlayers()) do
        local costumesFolder = p:FindFirstChild("AE_Costumes")
        if costumesFolder then
            local temSkins = false
            for _, item in ipairs(costumesFolder:GetChildren()) do
                if item:IsA("HumanoidDescription") then
                    temSkins = true
                    break
                end
            end
            if temSkins then
                table.insert(playersComSkinsValidas, p)
            end
        end
    end
    
    PlayerScroll.CanvasSize = UDim2.new(0, 0, 0, #playersComSkinsValidas * 32)
    
    for _, p in ipairs(playersComSkinsValidas) do
        local pBtn = Instance.new("TextButton", PlayerScroll)
        pBtn.Size = UDim2.new(1, -10, 0, 28)
        pBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 45)
        pBtn.Text = "👤 " .. p.DisplayName
        pBtn.TextColor3 = Color3.fromRGB(230, 220, 255)
        pBtn.Font = Enum.Font.SourceSansSemibold
        pBtn.TextSize = 13
        pBtn.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UICorner", pBtn).CornerRadius = UDim.new(0, 5)
        
        local padding = Instance.new("UIPadding", pBtn)
        padding.PaddingLeft = UDim.new(0, 8)
        
        pBtn.MouseButton1Click:Connect(function()
            TextBox.Text = p.Name
            executarEscaneamentoDoAlvo(p.Name)
        end)
    end
end

