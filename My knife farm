    local function estaEmCimaDaFloor(modelo, floor)
        if not modelo or not floor then return false end
        local p = modelo.PrimaryPart or modelo:FindFirstChildOfClass("Part") or modelo:FindFirstChildOfClass("MeshPart")
        if not p then return false end
        local posM, posF, sizeF = p.Position, floor.Position, floor.Size
