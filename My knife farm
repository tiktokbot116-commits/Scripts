-- // FUNÇÃO AUXILIAR: TWEEN/TELEPORTE SUAVE
local function voarAte(cframeDestino, velocidade)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root or not cframeDestino then return end
    
    velocidade = velocidade or 85
    local distancia = (root.Position - cframeDestino.Position).Magnitude
    local tempo = distancia / velocidade
    
    -- Se estiver muito perto ou for o retorno base, faz um ajuste rápido
    if distancia < 5 then return end
    
    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(root, tweenInfo, {CFrame = cframeDestino})
    tween:Play()
    tween.Completed:Wait()
end

-- // FUNÇÃO AUXILIAR: VERIFICA SE O MODELO ESTÁ EM CIMA DA CELESTIAL FLOOR
local function estaEmCimaDaFloor(modelo, floor)
    if not modelo or not floor or not modelo:IsA("Model") then return false end
    
    local primaryPart = modelo.PrimaryPart or modelo:FindFirstChildOfClass("Part") or modelo:FindFirstChildOfClass("MeshPart")
    if not primaryPart then return false end
    
    -- Cálculos de bounding box tridimensional simplificado para checar sobreposição vertical (eixos X e Z)
    local posM = primaryPart.Position
    local posF = floor.Position
    local tamanhoF = floor.Size
    
    local dentroX = posM.X >= (posF.X - tamanhoF.X/2) and posM.X <= (posF.X + tamanhoF.X/2)
    local dentroZ = posM.Z >= (posF.Z - tamanhoF.Z/2) and posM.Z <= (posF.Z + tamanhoF.Z/2)
    local acimaY = posM.Y >= posF.Y -- Precisa estar acima da plataforma
    
    return dentroX and dentroZ and acimaY
end

