-- // FUNÇÃO AUXILIAR UNIVERSAL: TWEEN / VOAR
local function voarAte(cframeDestino, velocidade)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root or not cframeDestino then return end
    
    velocidade = velocidade or 85
    local distancia = (root.Position - cframeDestino.Position).Magnitude
    local tempo = distancia / velocidade
    if distancia < 2 then return end
    
    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(root, tweenInfo, {CFrame = cframeDestino})
    tween:Play()
    tween.Completed:Wait()
end

