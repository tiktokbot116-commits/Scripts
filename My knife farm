-- // FUNÇÃO AUXILIAR: ENCONTRAR O PLOT DO JOGADOR (Verifica os caminhos comuns passados)
local function obterPlotDoJogador()
    local plotsFolder = workspace:FindFirstChild("Plots")
    if not plotsFolder then return nil end
    
    for _, plot in ipairs(plotsFolder:GetChildren()) do
        if plot.Name == LocalPlayer.Name or 
           string.find(plot.Name, LocalPlayer.Name .. "'s Plot") or 
           string.find(string.lower(plot.Name), string.lower(LocalPlayer.Name)) then
            return plot
        end
    end
    return nil
end

-- // FUNÇÃO AUXILIAR: TWEEN SUAVE ATÉ OS OBJETOS do PLOT
local function darTween(destino)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root or not destino then return end
    
    local distancia = (root.Position - destino.Position).Magnitude
    local velocidade = 75 -- Ajuste a velocidade do voo aqui
    local tempo = distancia / velocidade
    
    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(root, tweenInfo, {CFrame = destino.CFrame})
    tween:Play()
    tween.Completed:Wait()
end

