-- Smooth Dragging
local dragging, dragInput, dragStart, startPos
Topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)
Topbar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then dragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local function populateList()
    for _, child in ipairs(List:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    table.clear(particleButtons)
    
    local count = 0
    for _, obj in pairs(Workspace:GetDescendants()) do
        -- Protege contra instâncias destruídas ou sem permissão
        pcall(function()
            if obj:IsA("ParticleEmitter") then
                local btn = Instance.new("TextButton", List)
                btn.Size = UDim2.new(1, -10, 0, 30)
                btn.BackgroundColor3 = Color3.fromRGB(35, 35, 40)
                btn.Text = " " .. obj.Name
                btn.TextColor3 = Color3.fromRGB(220, 220, 220)
                btn.Font = Enum.Font.Gotham
                btn.TextSize = 12
                btn.TextXAlignment = Enum.TextXAlignment.Left
                btn.TextTruncate = Enum.TextTruncate.AtEnd
                Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 4)
                
                table.insert(particleButtons, {Button = btn, Name = obj.Name:lower()})
                count = count + 1
                
                btn.MouseButton1Click:Connect(function()
                    selectedParticle = obj
                    NameLabel.Text = obj.Name
                    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    
                    -- Limpa a parte de projeção real
                    PreviewPart:ClearAllChildren()
                    
                    -- Clona a partícula para o mundo real
                    local clone = obj:Clone()
                    clone.Parent = PreviewPart
                    clone.Enabled = true
                    
                    -- Inicia a projeção 3D que trava a parte na frente da câmera do jogador
                    if renderConnection then renderConnection:Disconnect() end
                    
                    local angle = 0
                    renderConnection = RunService.RenderStepped:Connect(function(dt)
                        -- Faz a partícula girar lentamente para mostrar todas as direções (3D Orbital)
                        angle = angle + math.rad(45 * dt)
                        
                        -- CFrame mágico: Trava a parte à direita da câmera (onde a UI está) e um pouco à frente
                        local camCFrame = Workspace.CurrentCamera.CFrame
                        -- X = 2 (Para a direita), Y = 0 (Centro), Z = -6 (Distância pra frente)
                        local offset = CFrame.new(2, 0, -6) * CFrame.Angles(0, angle, 0)
                        
                        PreviewPart.CFrame = camCFrame * offset
                    end)
                end)
            end
        end)
    end
    List.CanvasSize = UDim2.new(0, 0, 0, count * 35)
end

