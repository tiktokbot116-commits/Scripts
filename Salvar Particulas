-- 5. LÓGICA CORE (CÂMERA, LISTA E SALVAMENTO)
-- ==========================================
local selectedParticle = nil
local isViewing = false
local cam = Workspace.CurrentCamera
local orbitalConnection = nil

local function updateVoidRoom()
    PreviewBase:ClearAllChildren()
    if selectedParticle and isViewing then
        local clone = selectedParticle:Clone()
        clone.Parent = PreviewBase
        clone.Enabled = true
    end
end

local function toggleCamera()
    isViewing = not isViewing
    if isViewing then
        cam.CameraType = Enum.CameraType.Scriptable
        updateVoidRoom()
        ViewBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        ViewBtn.Text = "PARAR CÂMERA"
        
        local angle = 0
        local height = 2 
        
        if orbitalConnection then orbitalConnection:Disconnect() end
        orbitalConnection = RunService.RenderStepped:Connect(function(dt)
            angle = angle + math.rad(45 * dt)
            local camPos = PreviewBase.Position + Vector3.new(math.sin(angle) * cameraRadius, height, math.cos(angle) * cameraRadius)
            cam.CFrame = CFrame.lookAt(camPos, PreviewBase.Position)
        end)
    else
        if orbitalConnection then orbitalConnection:Disconnect() end
        PreviewBase:ClearAllChildren()
        cam.CameraType = Enum.CameraType.Custom
        local localChar = LocalPlayer.Character
        if localChar and localChar:FindFirstChild("Humanoid") then
            cam.CameraSubject = localChar.Humanoid
        end
        ViewBtn.BackgroundColor3 = ACCENT_COLOR
        ViewBtn.Text = "INICIAR CÂMERA"
    end
end

ViewBtn.MouseButton1Click:Connect(function()
    if not selectedParticle and not isViewing then return end
    toggleCamera()
end)

local function dumpAllProperties(part)
    local rawText = " [ " .. part.ClassName .. " ]\n\n"
    for _, propName in ipairs(particleProperties) do
        local ok, val = pcall(function() return part[propName] end)
        if ok then
            rawText = rawText .. " 🔸 " .. propName .. ": " .. formatValueForUI(val) .. "\n"
        end
    end
    StatsText.Text = rawText
    task.wait(0.05)
    StatsScroll.CanvasSize = UDim2.new(0, 0, 0, StatsText.TextBounds.Y + 20)
end

