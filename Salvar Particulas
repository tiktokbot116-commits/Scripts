-- 1. CONFIGURAÇÕES E SERIALIZADOR
-- ==========================================
local particleProperties = {
    "Enabled", "Rate", "Lifetime", "Speed", "Drag", "Acceleration", "VelocityInheritance",
    "Texture", "Color", "Transparency", "Size", "LightEmission", "LightInfluence", "Orientation",
    "EmissionDirection", "Shape", "ShapeInOut", "ShapePartial", "SpreadAngle",
    "FlipbookLayout", "FlipbookFramerate", "FlipbookMode", "FlipbookStartRandom",
    "Rotation", "RotationSpeed", "Squash", "VelocitySpread", "ZOffset"
}

local function serializeValue(val)
    local t = typeof(val)
    if t == "NumberSequence" then
        local data = {}
        for _, kp in ipairs(val.Keypoints) do table.insert(data, {Time = kp.Time, Value = kp.Value, Envelope = kp.Envelope}) end
        return {Type = "NumberSequence", Data = data}
    elseif t == "ColorSequence" then
        local data = {}
        for _, kp in ipairs(val.Keypoints) do table.insert(data, {Time = kp.Time, Color = {R = kp.Value.R, G = kp.Value.G, B = kp.Value.B}, Envelope = kp.Envelope}) end
        return {Type = "ColorSequence", Data = data}
    elseif t == "NumberRange" then return {Type = "NumberRange", Min = val.Min, Max = val.Max}
    elseif t == "EnumItem" then return tostring(val)
    elseif t == "Vector3" then return {X = val.X, Y = val.Y, Z = val.Z}
    elseif t == "Color3" then return {R = val.R, G = val.G, B = val.B}
    else return val end
end

local function saveParticleData(particle)
    local success, info = pcall(function() return MarketplaceService:GetProductInfo(game.PlaceId) end)
    local gameName = success and info.Name:gsub("[\\/:*?\"<>|]", "_") or "Desconhecido"
    local rootFolder = "Partículas Salvas"
    local gameFolder = rootFolder .. "/" .. gameName
    
    if not isfolder(rootFolder) then makefolder(rootFolder) end
    if not isfolder(gameFolder) then makefolder(gameFolder) end

    local serializedData = {ClassName = particle.ClassName, ParentName = particle.Parent.Name}
    for _, propName in ipairs(particleProperties) do
        local ok, value = pcall(function() return particle[propName] end)
        if ok then serializedData[propName] = serializeValue(value) end
    end

    local fileName = gameFolder .. "/" .. particle.Name:gsub("[\\/:*?\"<>|]", "_") .. "_" .. math.random(1000, 9999) .. ".txt"
    writefile(fileName, HttpService:JSONEncode(serializedData))
    return fileName
end

