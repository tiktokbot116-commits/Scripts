-- 2. SERIALIZADOR AVANÇADO (PARA JSON)
-- ==========================================
local particleProperties = {
    "Enabled", "Rate", "Lifetime", "Speed", "Drag", "Acceleration", "VelocityInheritance",
    "Texture", "Color", "Transparency", "Size", "LightEmission", "LightInfluence", "Orientation",
    "EmissionDirection", "Shape", "ShapeInOut", "ShapePartial", "SpreadAngle",
    "FlipbookLayout", "FlipbookFramerate", "FlipbookMode", "FlipbookStartRandom",
    "Rotation", "RotationSpeed", "Squash", "VelocitySpread", "ZOffset", "TimeScale"
}

-- Serialização completa para salvar no arquivo JSON
local function serializeValueForJSON(val)
    local t = typeof(val)
    if t == "NumberSequence" then
        local data = {}
        for _, kp in ipairs(val.Keypoints) do table.insert(data, {Time = kp.Time, Value = kp.Value, Envelope = kp.Envelope}) end
        return {Type = "NumberSequence", Keypoints = data}
    elseif t == "ColorSequence" then
        local data = {}
        for _, kp in ipairs(val.Keypoints) do table.insert(data, {Time = kp.Time, Color = {R = kp.Value.R, G = kp.Value.G, B = kp.Value.B}}) end
        return {Type = "ColorSequence", Keypoints = data}
    elseif t == "NumberRange" then return {Type = "NumberRange", Min = val.Min, Max = val.Max}
    elseif t == "Vector3" then return {Type = "Vector3", X = val.X, Y = val.Y, Z = val.Z}
    elseif t == "Vector2" then return {Type = "Vector2", X = val.X, Y = val.Y}
    elseif t == "Color3" then return {Type = "Color3", R = val.R, G = val.G, B = val.B}
    elseif t == "EnumItem" then return val.Name
    else return val end
end

-- Formatação amigável apenas para visualização na UI
local function formatValueForUI(val)
    local t = typeof(val)
    if t == "NumberRange" then return string.format("%.2f - %.2f", val.Min, val.Max)
    elseif t == "ColorSequence" or t == "NumberSequence" then return "[" .. t .. "]"
    elseif t == "Vector3" then return string.format("%.1f, %.1f, %.1f", val.X, val.Y, val.Z)
    elseif t == "Color3" then return string.format("%d, %d, %d", math.floor(val.R*255), math.floor(val.G*255), math.floor(val.B*255))
    elseif t == "EnumItem" then return val.Name
    else return tostring(val) end
end

