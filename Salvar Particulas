-- SISTEMA DE BUSCA GERAL DE PARTÍCULAS
-- ==========================================
local allButtons = {}
local seenNames = {}

-- Define os principais serviços acessíveis ao cliente para buscar
local servicesToScan = {
    Workspace,
    game:GetService("ReplicatedStorage"),
    game:GetService("Lighting"),
    game:GetService("MaterialService"),
    game:GetService("Players"),
    game:GetService("StarterGui"),
    game:GetService("StarterPack"),
    game:GetService("StarterPlayer")
}

for _, service in ipairs(servicesToScan) do
    pcall(function() -- Usa pcall para evitar erros em objetos bloqueados
        for _, obj in ipairs(service:GetDescendants()) do
            if obj:IsA("ParticleEmitter") then
                if not seenNames[obj.Name] then
                    seenNames[obj.Name] = true
                    
                    local btn = Instance.new("TextButton", List)
                    btn.Size = UDim2.new(1, 0, 0, 28)
                    btn.BackgroundColor3 = PANEL_COLOR
                    btn.Text = "  " .. obj.Name
                    btn.TextColor3 = TEXT_COLOR
                    btn.Font = Enum.Font.GothamMedium
                    btn.TextSize = 12
                    btn.TextXAlignment = Enum.TextXAlignment.Left
                    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
                    
                    table.insert(allButtons, {btn = btn, name = obj.Name:lower()})
                    
                    btn.MouseButton1Click:Connect(function()
                        selectedParticle = obj
                        SelName.Text = obj.Name
                        dumpAllProperties(obj)
                        
                        for _, item in ipairs(allButtons) do item.btn.BackgroundColor3 = PANEL_COLOR end
                        btn.BackgroundColor3 = ACCENT_COLOR
                        
                        if isViewing then updateVoidRoom() end
                    end)
                end
            end
        end
    end)
end
List.CanvasSize = UDim2.new(0, 0, 0, #allButtons * 33)

SearchBox:GetPropertyChangedSignal("Text"):Connect(function()
    local text = SearchBox.Text:lower()
    local count = 0
    for _, item in ipairs(allButtons) do
        if text == "" or string.find(item.name, text) then
            item.btn.Visible = true; count = count + 1
        else
            item.btn.Visible = false
        end
    end
    List.CanvasSize = UDim2.new(0, 0, 0, count * 33)
end)

-- SISTEMA DE EXPORTAÇÃO (ATUALIZADO COM SUBPASTAS DE JOGOS)
SaveBtn.MouseButton1Click:Connect(function()
    if not selectedParticle then return end

    local baseFolder = "ParticleBackups"
    local fullPathFolder = baseFolder .. "/" .. gameFolderName
    
    -- Garante que a pasta principal e a do jogo existam
    if isfolder and makefolder then
        local success, err = pcall(function()
            if not isfolder(baseFolder) then
                makefolder(baseFolder)
            end
            if not isfolder(fullPathFolder) then
                makefolder(fullPathFolder)
            end
        end)
        
        if not success then
            warn("Erro ao criar pastas: " .. tostring(err))
            SaveBtn.Text = "❌ ERRO: FOLDERS"
            task.wait(2)
            SaveBtn.Text = "📥 EXPORTAR JSON (PASTA DO JOGO)"
            return
        end
    end

    local exportData = {
        ParticleName = selectedParticle.Name,
        OriginalParent = selectedParticle.Parent and selectedParticle.Parent.Name or "Unknown",
        PlaceId = game.PlaceId,
        GameName = gameFolderName,
        Properties = {}
    }

    for _, prop in ipairs(particleProperties) do
        local ok, val = pcall(function() return selectedParticle[prop] end)
        if ok then
            exportData.Properties[prop] = serializeValueForJSON(val)
        end
    end

    local jsonString = HttpService:JSONEncode(exportData)
    -- Salva diretamente dentro da subpasta do jogo atual
    local fileName = fullPathFolder .. "/" .. selectedParticle.Name .. "_" .. tostring(math.random(100, 999)) .. ".json"

    if writefile then
        local success, err = pcall(function() 
            writefile(fileName, jsonString) 
        end)
        
        if success then
            SaveBtn.Text = "✅ SALVO COM SUCESSO!"
            SaveBtn.BackgroundColor3 = Color3.fromRGB(0, 140, 255)
        else
            warn("Erro ao salvar arquivo: " .. tostring(err))
            SaveBtn.Text = "❌ ERRO: WRITEFILE"
            SaveBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
        end
    else
        SaveBtn.Text = "❌ ERRO: WRITEFILE NULO"
        SaveBtn.BackgroundColor3 = Color3.fromRGB(220, 60, 60)
    end

    task.wait(2)
    SaveBtn.Text = "📥 EXPORTAR JSON (PASTA DO JOGO)"
    SaveBtn.BackgroundColor3 = Color3.fromRGB(30, 180, 100)
end)
