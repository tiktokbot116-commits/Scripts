        TweenService:Create(SaveBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(0, 100, 255)}):Play()
        SaveBtn.Text = "⏳ PROCESSANDO..."
        
        saveParticleData(selectedParticle)
        
        SaveBtn.Text = "✅ SALVO COM SUCESSO!"
        task.wait(1.5)
        TweenService:Create(SaveBtn, TweenInfo.new(0.5), {BackgroundColor3 = originalColor}):Play()
        SaveBtn.Text = "📥 SERIALIZAR E SALVAR"
    end
end)

-- Sistema de Pesquisa/Filtro
SearchBar:GetPropertyChangedSignal("Text"):Connect(function()
    local searchText = SearchBar.Text:lower()
    local visibleCount = 0
    
    for _, item in ipairs(particleButtons) do
        if searchText == "" or string.find(item.Name, searchText) then
            item.Button.Visible = true
            visibleCount = visibleCount + 1
        else
            item.Button.Visible = false
        end
    end
    List.CanvasSize = UDim2.new(0, 0, 0, visibleCount * 35)
end)

-- Refresh
RefreshBtn.MouseButton1Click:Connect(function()
    TweenService:Create(RefreshBtn, TweenInfo.new(0.5, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {Rotation = RefreshBtn.Rotation + 360}):Play()
    if renderConnection then renderConnection:Disconnect() end
    PreviewPart:ClearAllChildren()
    populateList()
end)

