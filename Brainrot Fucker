    -- ROTINA DE DEBUG DO GITHUB (LOADSTRING TRATA TUDO)
    local function rodarScriptNoAmbienteGlobal()
        local urls = {
            "https://raw.githubusercontent.com/tiktokbot116-commits/Scripts/refs/heads/main/My%20knife%20farm",
            "https://raw.githubusercontent.com/tiktokbot116-commits/Scripts/main/My%20knife%20farm"
        }
        
        local codigoBruto = nil
        for index, url in ipairs(urls) do
            print("[Tentativa " .. tostring(index) .. "] Baixando de: " .. url)
            local sucesso, resultado = pcall(function() return game:HttpGet(url) end)
            if sucesso and resultado and #resultado > 0 then
                codigoBruto = resultado
                print("[Sucesso HTTP] Conteúdo retornado com " .. tostring(#resultado) .. " caracteres.")
                break
            else
                warn("[Falha HTTP] URL " .. tostring(index) .. " falhou. Erro: " .. tostring(resultado))
            end
        end
        
        if codigoBruto then
            local funcaoCarregada, erroCompilacao = loadstring(codigoBruto)
            if funcaoCarregada then
                setfenv(funcaoCarregada, setmetatable({}, {
                    __index = function(_, chave) return _G[chave] or shared[chave] or getfenv(0)[chave] end,
                    __newindex = function(_, chave, valor) _G[chave] = valor end
                }))
                task.spawn(funcaoCarregada)
                print("[Loadstring] Executado com sucesso no ambiente global!")
            else
                warn("[Erro Crítico] Seu arquivo no GitHub tem um erro de digitação/sintaxe do Lua e não pôde ser compilado: " .. tostring(erroCompilacao))
            end
        else
            warn("[Erro de Conexão] O executor não conseguiu puxar nenhum dado do GitHub. Verifique se o link raw está correto ou se o site está instável.")
        end
    end

    ToggleBtn.MouseButton1Click:Connect(function()
        _G.AutoFarm = not _G.AutoFarm
        if _G.AutoFarm then
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(35, 150, 85)
            ToggleBtn.Text = "Auto Farm: ATIVO"
            
            -- Dispara o loadstring e deixa ele lidar com toda a lógica externa
            rodarScriptNoAmbienteGlobal()
        else
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(160, 45, 45)
            ToggleBtn.Text = "Auto Farm: INATIVO"
        end
    end)
