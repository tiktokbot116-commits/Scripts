    local function converterSufixo(texto)
        texto = string.upper(string.gsub(texto, "%s+", ""))
        local numero = tonumber(string.match(texto, "^[%d%.]+"))
        if not numero then return 0 end
        
        if string.find(texto, "K") then return numero * 10^3
        elseif string.find(texto, "M") then return numero * 10^6
        elseif string.find(texto, "B") then return numero * 10^9
        elseif string.find(texto, "T") then return numero * 10^12
        elseif string.find(texto, "QD") then return numero * 10^15
        elseif string.find(texto, "QT") or string.find(texto, "QN") then return numero * 10^18
        elseif string.find(texto, "SX") then return numero * 10^21
        elseif string.find(texto, "SP") then return numero * 10^24
        elseif string.find(texto, "OC") then return numero * 10^27
        elseif string.find(texto, "NO") then return numero * 10^30
        elseif string.find(texto, "DC") then return numero * 10^33
        elseif string.find(texto, "UD") then return numero * 10^36
        elseif string.find(texto, "DD") then return numero * 10^39
        elseif string.find(texto, "TD") then return numero * 10^42
        elseif string.find(texto, "QDD") then return numero * 10^45
        elseif string.find(texto, "QTD") then return numero * 10^48
        elseif string.find(texto, "SXD") then return numero * 10^51
        elseif string.find(texto, "SPD") then return numero * 10^54
        elseif string.find(texto, "OCD") then return numero * 10^57
        elseif string.find(texto, "NOD") then return numero * 10^60
        elseif string.find(texto, "VG") then return numero * 10^63
        elseif string.find(texto, "UVG") then return numero * 10^66
        elseif string.find(texto, "DVG") then return numero * 10^69
        elseif string.find(texto, "TVG") then return numero * 10^72
        elseif string.find(texto, "TG") then return numero * 10^93
        elseif string.find(texto, "QG") then return numero * 10^123
        elseif string.find(texto, "PC") then return numero * 10^153
        elseif string.find(texto, "HX") then return numero * 10^183
        elseif string.find(texto, "HP") then return numero * 10^213
        elseif string.find(texto, "OG") then return numero * 10^243
        elseif string.find(texto, "NW") then return numero * 10^273
        elseif string.find(texto, "CN") then return numero * 10^303
        end
        return numero
    end

    local function rodarScriptNoAmbienteGlobal(url)
        local sucesso, codigoBruto = pcall(function() return game:HttpGet(url) end)
        if sucesso and codigoBruto then
            local funcaoCarregada, erroCompilacao = loadstring(codigoBruto)
            if funcaoCarregada then
                setfenv(funcaoCarregada, setmetatable({}, {
                    __index = function(_, chave) return _G[chave] or shared[chave] or getfenv(0)[chave] end,
                    __newindex = function(_, chave, valor) _G[chave] = valor end
                }))
                task.spawn(funcaoCarregada)
            else
                warn("Erro de Compilação: " .. tostring(erroCompilacao))
            end
        else
            warn("Erro de Comunicação HTTP com o repositório.")
        end
    end

