local function estilizarBotaoMenu(botao, texto, pos)
    botao.Size = UDim2.new(0, 130, 0, 38)
    botao.Position = UDim2.new(0, 10, 0, pos)
    botao.Text = "  " .. texto
    botao.TextColor3 = Color3.fromRGB(200, 200, 200)
    botao.Font = Enum.Font.GothamBold
    botao.TextSize = 14
    botao.TextXAlignment = Enum.TextXAlignment.Left
    botao.Parent = Sidebar
    
    local corner = Instance.new("UICorner", botao)
    corner.CornerRadius = UDim.new(0, 8)
    
    local stroke = Instance.new("UIStroke", botao)
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(30, 30, 35)
    
    botao.MouseEnter:Connect(function()
        if botao.BackgroundColor3 ~= Color3.fromRGB(40, 40, 50) then
            botao.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
        end
    end)
    botao.MouseLeave:Connect(function()
        if botao.BackgroundColor3 ~= Color3.fromRGB(40, 40, 50) then
            botao.BackgroundColor3 = Color3.fromRGB(18, 18, 22)
        end
    end)
end

