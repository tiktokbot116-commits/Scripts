-- =============================================================================
-- LOGICA DE FARM CORRIGIDA CONTRA ERROS DE TIPO E COORDENADAS
-- =============================================================================

local function voarAte(cframeDestino, velocidade)
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = character:FindFirstChild("HumanoidRootPart")
    if not root or not cframeDestino then return end
    
    velocidade = velocidade or 95
    local distancia = (root.Position - cframeDestino.Position).Magnitude
    local tempo = distancia / velocidade
    if distancia < 1.5 then return end
    
    local tweenInfo = TweenInfo.new(tempo, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(root, tweenInfo, {CFrame = cframeDestino})
    tween:Play()
    tween.Completed:Wait()
end

local function executarFarmPorId()
    if workspace:FindFirstChild("Break_Map") or game.PlaceId == 137069154816703 then
        task.spawn(function()
            print("[VTZ Hub] Iniciando Celestial Farm sem erros de validação...")

            -- Filtra estritamente objetos físicos com a propriedade .Position ativa
            local function estaEmCimaDaFloor(modelo, floor)
                if not modelo or not floor or floor:IsA("Folder") then return false end
                local p = modelo.PrimaryPart or modelo:FindFirstChildOfClass("Part") or modelo:FindFirstChildOfClass("MeshPart")
                if not p then return false end
                
                local sucesso, resultado = pcall(function()
                    return p.Position.X >= (floor.Position.X - floor.Size.X/2) and p.Position.X <= (floor.Position.X + floor.Size.X/2)
                end)
                return sucesso and resultado
            end

            while AutoFarmAtivo do
                task.wait(0.15)
                
                local locations = workspace.Break_Map:FindFirstChild("Locations")
                local entities = workspace:FindFirstChild("EntitiesFolder")
                
                local floor = nil
                if locations then
                    local celestialBest = locations:FindFirstChild("CelestialFloorBest")
                    -- Se existir e for um bloco válido, usa ele. Caso contrário, caça o primeiro bloco utilizável da pasta.
                    if celestialBest and not celestialBest:IsA("Folder") and (celestialBest:IsA("Part") or celestialBest:IsA("MeshPart")) then
                        floor = celestialBest
                    else
                        for _, obj in ipairs(locations:GetChildren()) do
                            if not obj:IsA("Folder") and (obj:IsA("Part") or obj:IsA("MeshPart")) then
                                floor = obj
                                break
                            end
                        end
                    end
                end
                
                if floor and entities then
                    local alvo = nil
                    for _, ent in ipairs(entities:GetChildren()) do
                        if ent:IsA("Model") and estaEmCimaDaFloor(ent, floor) then
                            if ent:FindFirstChildOfClass("ProximityPrompt") or ent:FindFirstChild("ProximityPrompt", true) then
                                alvo = ent
                                break
                            end
                        end
                    end
                    
                    if alvo then
                        local prompt = alvo:FindFirstChildOfClass("ProximityPrompt") or alvo:FindFirstChild("ProximityPrompt", true)
                        local part = alvo.PrimaryPart or alvo:FindFirstChildOfClass("Part") or alvo:FindFirstChildOfClass("MeshPart")
                        
                        if prompt and part then
                            -- Teleporta ligeiramente acima do bloco alvo para garantir a ativação do ProximityPrompt
                            local posicaoAlvo = part.CFrame * CFrame.new(0, 2, 0)
                            
                            voarAte(posicaoAlvo, 95)
                            
                            if not AutoFarmAtivo then break end 
                            
                            fireproximityprompt(prompt, 1) 
                            task.wait(0.05)
                        end
                    end
                end
            end
            print("[VTZ Hub] Celestial Farm finalizado com segurança.")
        end)

    -- PLACEHOLDERS DA CÓPIA (2 AO 10)
    elseif game.PlaceId == 000000002 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000003 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000004 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000005 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000006 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000007 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000008 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000009 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    elseif game.PlaceId == 000000010 then
        task.spawn(function() while AutoFarmAtivo do task.wait(1) end end)
    end
end

