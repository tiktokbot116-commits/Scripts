            rodarScriptNoAmbienteGlobal(urlDoSeuScriptFarm)
        else
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50)
            ToggleBtn.Text = "Auto Farm: OFF"
        end
    end)
