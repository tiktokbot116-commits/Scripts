-- --- COMPONENTES ---

local function AddLabel(text)
    local L = Instance.new("TextLabel", Scroll)
    L.Size = UDim2.new(0.9, 0, 0, 20)
    L.Text = text:upper()
    L.TextColor3 = Color3.fromRGB(0, 170, 255)
    L.Font = Enum.Font.GothamBold
    L.TextSize = 9
    L.BackgroundTransparency = 1
end

local function AddInput(label, placeholder, func)
    local L = Instance.new("TextLabel", Scroll)
    L.Size = UDim2.new(0.9, 0, 0, 12)
    L.Text = label
    L.TextColor3 = Color3.fromRGB(100, 100, 100)
    L.Font = Enum.Font.GothamBold
    L.TextSize = 7
    L.BackgroundTransparency = 1

    local I = Instance.new("TextBox", Scroll)
    I.Size = UDim2.new(0.9, 0, 0, 22)
    I.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    I.PlaceholderText = placeholder
    I.Text = ""
    I.TextColor3 = Color3.fromRGB(255, 255, 255)
    I.Font = Enum.Font.Gotham
    I.TextSize = 10
    Instance.new("UICorner", I).CornerRadius = UDim.new(0, 4)
    I.FocusLost:Connect(function(e) if e then func(I.Text) end end)
    return I
end

local function AddBtn(text, color, func)
    local B = Instance.new("TextButton", Scroll)
    B.Size = UDim2.new(0.9, 0, 0, 25)
    B.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
    B.Text = text
    B.TextColor3 = color
    B.Font = Enum.Font.GothamBold
    B.TextSize = 9
    Instance.new("UICorner", B).CornerRadius = UDim.new(0, 4)
    B.MouseButton1Click:Connect(func)
    return B
end

-- --- LÓGICA DE NEGÓCIO ---

local function FireMarket(itemName)
    for i = 1, MarketAmount do
        task.spawn(function()
            local args = {
                [1] = "Market",
                [2] = {
                    ["DisplayName"] = itemName,
                    ["Name"] = itemName,
                    ["Rarity"] = "Mythic",
                    ["Price"] = 0,
                    ["Ingredients"] = {["Auras"] = {}, ["Itens"] = {["LuckPotionFifteen"] = 0, ["LuckPotionFiveMinutes"] = 0, ["LuckPotionThirty"] = 0}},
                    ["Data"] = {
                        ["Type"] = "Iten", ["Name"] = itemName, ["Percentual"] = 1, ["RarityName"] = "Mythic",
                        ["Data"] = {["CannotUse"] = false, ["Description"] = "???", ["DisplayName"] = itemName},
                        ["CoreData"] = {["Color"] = Color3.new(1,1,1), ["Itens"] = {[itemName] = {}}, ["Percent"] = 1, ["Weight"] = 5}
                    },
                    ["Rank"] = 5
                },
                [3] = itemName
            }
            args[2].Data.CoreData.Itens[itemName] = args[2].Data.Data
            CoreEvent:FireServer(unpack(args))
        end)
    end
end

local function FireCraft(itemName)
    task.spawn(function()
        local args = {
            [1] = "Craft",
            [2] = {
                ["Price"] = 0,
                ["Ingredient"] = {
                    ["Itens"] = {},
                    ["Auras"] = {["Worm"] = 0, ["Worm"] = 0, ["Worm"] = 0, ["Worm"] = 0, ["Worm"] = 0}
                },
                ["EquippedAura"] = "", ["Rolls"] = 0
            },
            [3] = CraftAmount,
            [4] = itemName
        }
        CoreEvent:FireServer(unpack(args))
    end)
end

-- --- CONSTRUÇÃO DA UI ---

AddLabel("Main Rolls")
AddInput("HYPER ROLL", "Qtd...", function(val)
