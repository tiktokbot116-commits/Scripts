        for i = 1, amt do
            task.spawn(function() RollRemote:FireServer({["Action"] = "AddRoll"}) end)
        end
    end
end)

--- MARKET SECTION ---
AddLabel("Market System")
AddInput("MARKET ITEM (NOME)", "Item name ou All...", function(val) SelectedMarketItem = val end)
AddInput("MARKET QTD", "Quantidade...", function(val) MarketAmount = tonumber(val) or 1 end)
AddBtn("EXECUTE MARKET", Color3.fromRGB(0, 255, 150), function()
    if SelectedMarketItem:lower() == "all" then
        for _, item in pairs(FolderItens:GetChildren()) do FireMarket(item.Name) end
    else
        FireMarket(SelectedMarketItem)
    end
end)

--- CRAFT SECTION ---
AddLabel("Craft System")
AddInput("CRAFT ITEM (NOME)", "Item name ou All...", function(val) SelectedCraftItem = val end)
AddInput("CRAFT QTD (VALOR)", "Quantidade...", function(val) CraftAmount = tonumber(val) or 1 end)
AddBtn("EXECUTE CRAFT", Color3.fromRGB(255, 200, 0), function()
    if SelectedCraftItem:lower() == "all" then
        for _, item in pairs(FolderItens:GetChildren()) do FireCraft(item.Name) end
    else
        FireCraft(SelectedCraftItem)
    end
end)

