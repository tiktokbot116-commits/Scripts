-- --- LÓGICA UNIFICADA (MARKET + CRAFT) ---
local function ExecuteUnified(name, amount)
    for i = 1, amount do
        task.spawn(function()
            -- Código do Market
            local marketArgs = {[1]="Market",[2]={["DisplayName"]=name,["Name"]=name,["Rarity"]="Mythic",["Price"]=0,["Ingredients"]={["Auras"]={},["Itens"]={["LuckPotionFifteen"]=0}},["Data"]={["Type"]="Iten",["Name"]=name,["RarityName"]="Mythic",["Data"]={["DisplayName"]=name},["CoreData"]={["Itens"]={[name]={}},["Percent"]=1}},["Rank"]=5},[3]=name}
            CoreEvent:FireServer(unpack(marketArgs))
            
            -- Código do Craft (Dispara junto)
            local craftArgs = {[1]="Craft",[2]={["Price"]=0,["Ingredient"]={["Itens"]={},["Auras"]={["Worm"]=0}},["Rolls"]=0},[3]=1, [4]=name}
            CoreEvent:FireServer(unpack(craftArgs))
        end)
    end
end

-- --- DROPDOWN REAL ---
local function CreateItemDropdown(parent, callback)
    local IsOpen = false
    local Drop = Instance.new("Frame", parent)
    Drop.Size = UDim2.new(0.9, 0, 0, 40)
    Drop.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    Instance.new("UICorner", Drop)

    local Display = Instance.new("TextButton", Drop)
    Display.Size = UDim2.new(1, 0, 1, 0)
    Display.BackgroundTransparency = 1
    Display.Text = "SELECIONAR ITEM: All"
    Display.TextColor3 = Color3.fromRGB(0, 170, 255)
    Display.Font = "GothamBold"

    local List = Instance.new("ScrollingFrame", Drop)
    List.Size = UDim2.new(1, 0, 0, 150)
    List.Position = UDim2.new(0, 0, 1, 5)
    List.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
    List.Visible = false
    List.ZIndex = 10
    Instance.new("UIListLayout", List)
    Instance.new("UICorner", List)

    local function Populate()
        for _, c in pairs(List:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
        local options = {"All"}
        for _, v in pairs(FolderItens:GetChildren()) do table.insert(options, v.Name) end
        for _, opt in pairs(options) do
            local b = Instance.new("TextButton", List)
            b.Size = UDim2.new(1, 0, 0, 30)
            b.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
            b.Text = opt
            b.TextColor3 = Color3.new(1,1,1)
            b.ZIndex = 11
            b.MouseButton1Click:Connect(function()
                SelectedItem = opt
                Display.Text = "ITEM: " .. opt
                List.Visible = false
                IsOpen = false
                callback(opt)
            end)
        end
        List.CanvasSize = UDim2.new(0,0,0, #options * 30)
    end

    Display.MouseButton1Click:Connect(function()
        IsOpen = not IsOpen
        if IsOpen then Populate() end
        List.Visible = IsOpen
    end)
end

-- --- COMPONENTES ---
local function CreateInput(parent, label, callback)
    local I = Instance.new("TextBox", parent)
    I.Size = UDim2.new(0.9, 0, 0, 35)
    I.BackgroundColor3 = Color3.fromRGB(20, 20, 25)
    I.PlaceholderText = label
    I.Text = ""
    I.TextColor3 = Color3.new(1,1,1)
    Instance.new("UICorner", I)
    I.FocusLost:Connect(function() callback(I.Text) end)
end

local function CreateBtn(parent, text, color, callback)
    local B = Instance.new("TextButton", parent)
    B.Size = UDim2.new(0.9, 0, 0, 40)
    B.BackgroundColor3 = color
    B.Text = text:upper()
    B.TextColor3 = Color3.new(1,1,1)
    B.Font = "GothamBold"
    Instance.new("UICorner", B)
    B.MouseButton1Click:Connect(callback)
end

