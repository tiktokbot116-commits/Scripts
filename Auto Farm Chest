-- [[ VTZ HUB - CHEST ENGINE: LEGACY & HYDRA ]]
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

_G.AutoCollectAll = true

local function collectChests()
    while _G.AutoCollectAll do
        local IslandFolder = workspace:FindFirstChild("Island")
        
        if IslandFolder then
            for _, folder in ipairs(IslandFolder:GetChildren()) do
                if not _G.AutoCollectAll then break end

                -- [[ LÓGICA 1: SEA BEAST / LEGACY ISLAND ]]
                -- Estrutura: Island -> Legacy Island(num) -> Spawner -> Chest
                if string.find(folder.Name, "Legacy Island") then
                    local spawner = folder:FindFirstChild("Spawner")
                    if spawner then
                        for _, chest in ipairs(spawner:GetChildren()) do
                            if chest:IsA("Model") and string.find(chest.Name, "Chest") then
                                local char = LocalPlayer.Character
                                if char and char:FindFirstChild("HumanoidRootPart") then
                                    local cf = chest:GetModelCFrame()
                                    char.HumanoidRootPart.CFrame = cf
                                    task.wait(0.3)
                                end
                            end
                        end
                    end

                -- [[ LÓGICA 2: HYDRA ]]
                -- Estrutura: Island -> Sea King(Ice, Thunder, Lava, etc) -> Modelo solto (Thunder Chest, etc)
                elseif string.find(folder.Name, "Sea King") then
                    for _, model in ipairs(folder:GetChildren()) do
                        -- Procura o modelo solto que tenha "Chest" no nome (ex: Thunder Chest, Lava Chest)
                        if model:IsA("Model") and string.find(model.Name, "Chest") then
                            local char = LocalPlayer.Character
                            if char and char:FindFirstChild("HumanoidRootPart") then
                                local cf = model:GetModelCFrame()
                                char.HumanoidRootPart.CFrame = cf
                                task.wait(0.4) -- Delay levemente maior para baús de evento
                            end
                        end
                    end
                end
            end
        end
        task.wait(0.5) -- Scan constante do mapa
    end
end

task.spawn(collectChests)
